<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="CanfarDesktop.Views.Dialogs.SettingsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:dialogs="using:CanfarDesktop.Views.Dialogs"
    xmlns:notebook="using:CanfarDesktop.Views.Notebook"
    Title="Settings"
    CloseButtonText="Close"
    DefaultButton="Close">

    <ContentDialog.Resources>
        <!-- The default ContentDialogMaxWidth (548) would clip the 640-wide NavigationView (the content
             ScrollViewer doesn't scroll horizontally), hiding the right edge — widen the cap. -->
        <x:Double x:Key="ContentDialogMaxWidth">680</x:Double>
    </ContentDialog.Resources>

    <muxc:NavigationView x:Name="Nav" PaneDisplayMode="Left" OpenPaneLength="168"
                         IsSettingsVisible="False" IsBackButtonVisible="Collapsed"
                         IsPaneToggleButtonVisible="False"
                         SelectionChanged="OnNavSelectionChanged"
                         Width="640" Height="460">
        <muxc:NavigationView.MenuItems>
            <muxc:NavigationViewItem Content="General" Tag="general">
                <muxc:NavigationViewItem.Icon><SymbolIcon Symbol="Setting" /></muxc:NavigationViewItem.Icon>
            </muxc:NavigationViewItem>
            <muxc:NavigationViewItem Content="AI agent" Tag="agent">
                <muxc:NavigationViewItem.Icon><FontIcon Glyph="&#xE99A;" /></muxc:NavigationViewItem.Icon>
            </muxc:NavigationViewItem>
            <muxc:NavigationViewItem Content="Image discovery" Tag="discovery">
                <muxc:NavigationViewItem.Icon><FontIcon Glyph="&#xE71D;" /></muxc:NavigationViewItem.Icon>
            </muxc:NavigationViewItem>
            <muxc:NavigationViewItem Content="AI compute" Tag="compute">
                <muxc:NavigationViewItem.Icon><FontIcon Glyph="&#xE753;" /></muxc:NavigationViewItem.Icon>
            </muxc:NavigationViewItem>
            <muxc:NavigationViewItem Content="Notebook" Tag="notebook">
                <muxc:NavigationViewItem.Icon><FontIcon Glyph="&#xE7C3;" /></muxc:NavigationViewItem.Icon>
            </muxc:NavigationViewItem>
            <muxc:NavigationViewItem Content="About" Tag="about">
                <muxc:NavigationViewItem.Icon><SymbolIcon Symbol="Help" /></muxc:NavigationViewItem.Icon>
            </muxc:NavigationViewItem>
        </muxc:NavigationView.MenuItems>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20,12,20,12">
            <Grid>
                <!-- General -->
                <StackPanel x:Name="GeneralPanel" Spacing="14">
                    <TextBlock Text="General" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <ComboBox x:Name="ThemeCombo" Header="Theme" Width="220" SelectionChanged="OnThemeChanged">
                        <ComboBoxItem Content="System" Tag="System" />
                        <ComboBoxItem Content="Light" Tag="Light" />
                        <ComboBoxItem Content="Dark" Tag="Dark" />
                    </ComboBox>

                    <TextBlock Text="Defaults" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <ComboBox x:Name="SessionTypeCombo" Header="Default session type" Width="220" SelectionChanged="OnGeneralChanged">
                        <ComboBoxItem Content="notebook" Tag="notebook" />
                        <ComboBoxItem Content="desktop" Tag="desktop" />
                        <ComboBoxItem Content="carta" Tag="carta" />
                        <ComboBoxItem Content="contributed" Tag="contributed" />
                    </ComboBox>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <muxc:NumberBox x:Name="CoresBox" Header="Default cores" Minimum="1" Maximum="64"
                                        SpinButtonPlacementMode="Inline" Width="130" ValueChanged="OnGeneralNumberChanged" />
                        <muxc:NumberBox x:Name="RamBox" Header="Default RAM (GB)" Minimum="1" Maximum="256"
                                        SpinButtonPlacementMode="Inline" Width="130" ValueChanged="OnGeneralNumberChanged" />
                    </StackPanel>

                    <TextBlock Text="Advanced" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <TextBox x:Name="ApiBaseUrlBox" Header="CADC API base URL" Width="360"
                             PlaceholderText="https://ws-cadc.canfar.net" LostFocus="OnGeneralChanged" />
                    <TextBlock Style="{StaticResource CaptionTextBlockStyle}" TextWrapping="Wrap"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                               Text="Changes are saved automatically." />
                </StackPanel>

                <!-- AI agent (embedded MCP panel + the guided wizard) -->
                <StackPanel x:Name="AgentPanel" Spacing="12" Visibility="Collapsed">
                    <TextBlock Text="AI agent" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <Button Content="Connect an AI agent (guided)…" Click="OnOpenWizard" Style="{StaticResource AccentButtonStyle}" />
                    <dialogs:McpServerSettingsPanel />
                </StackPanel>

                <!-- Image discovery (embedded) -->
                <StackPanel x:Name="DiscoveryPanel" Spacing="12" Visibility="Collapsed">
                    <TextBlock Text="Image discovery" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <dialogs:ImageDiscoverySettingsPanel Width="440" />
                </StackPanel>

                <!-- AI compute (embedded) -->
                <StackPanel x:Name="ComputePanel" Spacing="12" Visibility="Collapsed">
                    <TextBlock Text="AI compute" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <dialogs:AIComputeSettingsPanel Width="440" />
                </StackPanel>

                <!-- Notebook (embedded) -->
                <StackPanel x:Name="NotebookPanel" Spacing="12" Visibility="Collapsed">
                    <TextBlock Text="Notebook" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <notebook:NotebookSettingsPanel />
                </StackPanel>

                <!-- About -->
                <StackPanel x:Name="AboutPanel" Spacing="6" Visibility="Collapsed" HorizontalAlignment="Center"
                            Margin="0,24,0,0">
                    <FontIcon Glyph="&#xE9A9;" FontSize="44" HorizontalAlignment="Center"
                              Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                    <TextBlock Text="Verbinal" Style="{StaticResource TitleTextBlockStyle}" HorizontalAlignment="Center" />
                    <TextBlock x:Name="VersionText" Style="{StaticResource CaptionTextBlockStyle}" HorizontalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    <TextBlock TextWrapping="Wrap" TextAlignment="Center" MaxWidth="360" Margin="0,8,0,0"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Text="A native Windows client for the Canadian Astronomy Data Centre and CANFAR Science Platform — search, view, compute, and storage." />
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </muxc:NavigationView>
</ContentDialog>
