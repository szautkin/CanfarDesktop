<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="CanfarDesktop.Views.Dialogs.BatchJobsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Batch Jobs"
    CloseButtonText="Close"
    DefaultButton="Close">

    <ContentDialog.Resources>
        <DataTemplate x:Key="JobRowTemplate">
            <Grid Padding="4,6" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding Id}" Opacity="0.6"
                           FontFamily="Consolas" FontSize="12" VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" Text="{Binding SessionName}"
                           Style="{StaticResource BodyStrongTextBlockStyle}" VerticalAlignment="Center" />
                <TextBlock Grid.Column="2" Text="{Binding ImageLabel}" Opacity="0.7"
                           FontSize="12" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <Button Tag="{Binding Id}" Click="OnEventsClick"
                            ToolTipService.ToolTip="Events" Padding="6,4"
                            Background="Transparent" BorderThickness="0">
                        <FontIcon Glyph="&#xE81C;" FontSize="12" />
                    </Button>
                    <Button Tag="{Binding Id}" Click="OnLogsClick"
                            ToolTipService.ToolTip="Logs" Padding="6,4"
                            Background="Transparent" BorderThickness="0">
                        <FontIcon Glyph="&#xE756;" FontSize="12" />
                    </Button>
                    <Button Tag="{Binding Id}" Click="OnDeleteClick"
                            ToolTipService.ToolTip="Delete" Padding="6,4"
                            Background="Transparent" BorderThickness="0">
                        <FontIcon Glyph="&#xE74D;" FontSize="12" Foreground="#FFF44336" />
                    </Button>
                </StackPanel>
            </Grid>
        </DataTemplate>
    </ContentDialog.Resources>

    <Grid x:Name="ContentRoot">
        <Pivot x:Name="TabPivot" IsHeaderItemsCarouselEnabled="False">
            <PivotItem x:Name="PendingTab">
                <PivotItem.Header>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Ellipse Width="8" Height="8" Fill="#FFFF9800" VerticalAlignment="Center" />
                        <TextBlock x:Name="PendingHeader" />
                    </StackPanel>
                </PivotItem.Header>
                <ListView x:Name="PendingList" SelectionMode="None"
                          ItemTemplate="{StaticResource JobRowTemplate}" />
            </PivotItem>

            <PivotItem x:Name="RunningTab">
                <PivotItem.Header>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Ellipse Width="8" Height="8" Fill="#FF4CAF50" VerticalAlignment="Center" />
                        <TextBlock x:Name="RunningHeader" />
                    </StackPanel>
                </PivotItem.Header>
                <ListView x:Name="RunningList" SelectionMode="None"
                          ItemTemplate="{StaticResource JobRowTemplate}" />
            </PivotItem>

            <PivotItem x:Name="CompletedTab">
                <PivotItem.Header>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Ellipse Width="8" Height="8" Fill="#FF2196F3" VerticalAlignment="Center" />
                        <TextBlock x:Name="CompletedHeader" />
                    </StackPanel>
                </PivotItem.Header>
                <ListView x:Name="CompletedList" SelectionMode="None"
                          ItemTemplate="{StaticResource JobRowTemplate}" />
            </PivotItem>

            <PivotItem x:Name="FailedTab">
                <PivotItem.Header>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Ellipse Width="8" Height="8" Fill="#FFF44336" VerticalAlignment="Center" />
                        <TextBlock x:Name="FailedHeader" />
                    </StackPanel>
                </PivotItem.Header>
                <ListView x:Name="FailedList" SelectionMode="None"
                          ItemTemplate="{StaticResource JobRowTemplate}" />
            </PivotItem>
        </Pivot>
    </Grid>
</ContentDialog>
