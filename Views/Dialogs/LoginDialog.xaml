<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="CanfarDesktop.Views.Dialogs.LoginDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Uid="LoginDialog"
    Title="Login to Verbinal"
    PrimaryButtonText="Login"
    CloseButtonText="Cancel"
    DefaultButton="Primary"
    PrimaryButtonClick="OnLoginClick">

    <StackPanel Spacing="16" MinWidth="350">
        <ProgressBar x:Name="LoginProgress" IsIndeterminate="True" Visibility="Collapsed" />

        <TextBox x:Name="UsernameBox" x:Uid="Login_UsernameBox" Header="Username"
                 PlaceholderText="CADC username" />

        <PasswordBox x:Name="PasswordBox" x:Uid="Login_PasswordBox" Header="Password"
                     PlaceholderText="Password" />

        <CheckBox x:Name="RememberMeBox" x:Uid="Login_RememberMeBox" Content="Remember me" IsChecked="True" />

        <InfoBar x:Name="ErrorBar" x:Uid="Login_ErrorBar" IsOpen="False"
                 Severity="Error" Title="Login Failed" />
    </StackPanel>
</ContentDialog>
