<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="CanfarDesktop.Views.Dialogs.DeleteSessionDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Uid="Sessions_DeleteDialog"
    Title="Delete Session"
    PrimaryButtonText="Delete"
    CloseButtonText="Cancel"
    DefaultButton="Close">

    <StackPanel Spacing="8">
        <TextBlock x:Name="MessageText" TextWrapping="Wrap" />
        <TextBlock x:Uid="Sessions_DeleteWarning" Text="This action cannot be undone." Opacity="0.6"
                   Style="{StaticResource CaptionTextBlockStyle}" />
    </StackPanel>
</ContentDialog>
