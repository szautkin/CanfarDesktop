<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="CanfarDesktop.Views.Dialogs.ImageDiscoveryDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:CanfarDesktop.Converters"
    xmlns:idctl="using:CanfarDesktop.Views.Controls.ImageDiscovery"
    Title="Find images by package"
    PrimaryButtonText="Use this image"
    CloseButtonText="Close"
    DefaultButton="Primary"
    IsPrimaryButtonEnabled="{Binding HasSelection}">

    <ContentDialog.Resources>
        <!-- Override the default ~548px cap so the two-pane layout isn't clipped. -->
        <x:Double x:Key="ContentDialogMaxWidth">1000</x:Double>

        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />

        <!-- Left pane: section header -->
        <DataTemplate x:Key="FilterSectionTemplate">
            <TextBlock Margin="0,10,0,2" Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                <Run Text="{Binding Title}" FontWeight="SemiBold" />
                <Run Text=" (" /><Run Text="{Binding CountBadge}" /><Run Text=")" />
            </TextBlock>
        </DataTemplate>

        <!-- Left pane: checkbox value row -->
        <DataTemplate x:Key="FilterValueTemplate">
            <CheckBox Content="{Binding Value}"
                      IsChecked="{Binding IsSelected, Mode=TwoWay}"
                      IsEnabled="{Binding IsEnabled}"
                      MinHeight="30" Margin="6,0,0,0" />
        </DataTemplate>

        <idctl:FilterItemTemplateSelector x:Key="FilterSelector"
            SectionTemplate="{StaticResource FilterSectionTemplate}"
            ValueTemplate="{StaticResource FilterValueTemplate}" />

        <!-- Active-filter chip -->
        <DataTemplate x:Key="ChipTemplate">
            <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                    CornerRadius="12" Padding="8,2,4,2" Margin="0,0,4,4">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock VerticalAlignment="Center" Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Text="{Binding CategoryLabel}" />
                    <TextBlock VerticalAlignment="Center" Text="{Binding Value}" />
                    <Button Padding="2" MinWidth="0" Background="Transparent" BorderThickness="0"
                            Command="{Binding RemoveCommand}" CommandParameter="{Binding}"
                            ToolTipService.ToolTip="Remove filter">
                        <FontIcon Glyph="&#xE894;" FontSize="11" />
                    </Button>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- Right pane: image row -->
        <DataTemplate x:Key="ImageRowTemplate">
            <Grid Padding="8,6" ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Label}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="{Binding DetailLine}" Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock Text="{Binding JobIdLine}" Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                               Visibility="{Binding HasJobLogs, Converter={StaticResource BoolToVis}}" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                    <Button Content="Inspect" Command="{Binding DiscoverCommand}"
                            Visibility="{Binding IsNeverDiscovered, Converter={StaticResource BoolToVis}}" />
                    <Button Content="Details" Command="{Binding DetailsCommand}"
                            Visibility="{Binding CanShowDetails, Converter={StaticResource BoolToVis}}" />
                    <Button Content="Re-inspect" Command="{Binding RediscoverCommand}"
                            Visibility="{Binding CanShowDetails, Converter={StaticResource BoolToVis}}" />
                    <Button Content="Dismiss" Command="{Binding DismissCommand}"
                            Visibility="{Binding IsFailed, Converter={StaticResource BoolToVis}}" />
                    <ProgressRing Width="16" Height="16" IsActive="{Binding IsRunning}"
                                  Visibility="{Binding IsRunning, Converter={StaticResource BoolToVis}}" />
                </StackPanel>
            </Grid>
        </DataTemplate>
    </ContentDialog.Resources>

    <Grid x:Name="Root" Width="900" Height="560" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" VerticalAlignment="Center"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="{Binding DiscoveredSubtitle}" />
            <Button Grid.Column="1" Content="Clear errors" Command="{Binding ClearAllFailuresCommand}"
                    Visibility="{Binding HasFailures, Converter={StaticResource BoolToVis}}" />
            <ProgressRing Grid.Column="2" Width="20" Height="20" IsActive="{Binding IsDiscoveryRunning}" />
        </Grid>

        <!-- Active filters bar -->
        <StackPanel Grid.Row="1" Spacing="4"
                    Visibility="{Binding HasActiveFilters, Converter={StaticResource BoolToVis}}">
            <Grid>
                <TextBlock Text="Active filters" VerticalAlignment="Center"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <HyperlinkButton Content="Clear all" HorizontalAlignment="Right"
                                 Command="{Binding ClearAllFiltersCommand}" />
            </Grid>
            <ScrollViewer HorizontalScrollBarVisibility="Auto" HorizontalScrollMode="Auto"
                          VerticalScrollBarVisibility="Disabled" VerticalScrollMode="Disabled">
                <ItemsControl ItemsSource="{Binding ActiveChips}" ItemTemplate="{StaticResource ChipTemplate}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </ScrollViewer>
        </StackPanel>

        <!-- Two-pane split -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left filter pane -->
            <Grid Grid.Column="0" RowSpacing="6" Margin="0,0,10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBox Grid.Row="0" PlaceholderText="Filter packages, OS, …"
                         Text="{Binding PackageSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <ComboBox Grid.Row="1" Header="Session type" HorizontalAlignment="Stretch"
                          ItemsSource="{Binding SessionTypeOptions}"
                          SelectedItem="{Binding SelectedSessionType, Mode=TwoWay}" />
                <ListView Grid.Row="2" ItemsSource="{Binding FilterItems}"
                          ItemTemplateSelector="{StaticResource FilterSelector}"
                          SelectionMode="None"
                          BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="4">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="MinHeight" Value="0" />
                            <Setter Property="Padding" Value="8,0" />
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>
                <HyperlinkButton Grid.Row="3" Content="Clear all filters"
                                 Command="{Binding ClearAllFiltersCommand}"
                                 Visibility="{Binding HasActiveFilters, Converter={StaticResource BoolToVis}}" />
            </Grid>

            <Border Grid.Column="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

            <!-- Right matching-images pane -->
            <Grid Grid.Column="2" RowSpacing="6" Margin="12,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBox Grid.Row="0" PlaceholderText="Search images…"
                         Text="{Binding ImageSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <Grid Grid.Row="1">
                    <ListView x:Name="MatchListView" SelectionMode="Single"
                              SelectedItem="{Binding SelectedRow, Mode=TwoWay}"
                              ItemTemplate="{StaticResource ImageRowTemplate}"
                              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="4">
                        <ListView.GroupStyle>
                            <GroupStyle>
                                <GroupStyle.HeaderTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Project}" FontWeight="SemiBold" Margin="4,8,0,2"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </DataTemplate>
                                </GroupStyle.HeaderTemplate>
                            </GroupStyle>
                        </ListView.GroupStyle>
                    </ListView>
                    <TextBlock Text="No images match the current filters"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                               Visibility="{Binding IsEmptyResult, Converter={StaticResource BoolToVis}}" />
                </Grid>
            </Grid>
        </Grid>

        <!-- Inline detail panel (swaps in over the two panes — no nested dialogs) -->
        <Grid Grid.Row="0" Grid.RowSpan="3" RowSpacing="8"
              Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
              Visibility="{Binding IsShowingDetail, Converter={StaticResource BoolToVis}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- detail header -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10">
                <Button Command="{Binding Detail.CloseCommand}">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <FontIcon Glyph="&#xE72B;" FontSize="12" />
                        <TextBlock Text="Back" />
                    </StackPanel>
                </Button>
                <TextBlock Text="{Binding Detail.Label}" VerticalAlignment="Center"
                           Style="{StaticResource SubtitleTextBlockStyle}" TextTrimming="CharacterEllipsis" />
            </StackPanel>

            <!-- detail body -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="10">
                    <!-- OS / kernel -->
                    <StackPanel Spacing="1" Visibility="{Binding Detail.HasManifest, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding Detail.OsLine}" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding Detail.KernelLine}" Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Visibility="{Binding Detail.HasKernel, Converter={StaticResource BoolToVis}}" />
                    </StackPanel>

                    <!-- capabilities -->
                    <ItemsControl ItemsSource="{Binding Detail.Capabilities}"
                                  Visibility="{Binding Detail.HasCapabilities, Converter={StaticResource BoolToVis}}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{ThemeResource SystemFillColorSuccessBackgroundBrush}"
                                        CornerRadius="10" Padding="8,2" Margin="0,0,4,4">
                                    <TextBlock Text="{Binding}" Style="{StaticResource CaptionTextBlockStyle}" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- ecosystem sections (collapsed; inner lists virtualized) -->
                    <ItemsControl ItemsSource="{Binding Detail.Sections}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Expander Margin="0,2" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                                    <Expander.Header>
                                        <TextBlock>
                                            <Run Text="{Binding Title}" FontWeight="SemiBold" />
                                            <Run Text=" (" /><Run Text="{Binding Count}" /><Run Text=")" />
                                        </TextBlock>
                                    </Expander.Header>
                                    <ListView ItemsSource="{Binding Packages}" SelectionMode="None" MaxHeight="280">
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <Grid ColumnSpacing="8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Name}" FontFamily="Consolas" />
                                                    <TextBlock Grid.Column="1" Text="{Binding Version}" FontFamily="Consolas"
                                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                                </Grid>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                </Expander>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- probe notes -->
                    <InfoBar Severity="Informational" IsClosable="False"
                             IsOpen="{Binding Detail.HasProbeNotes}"
                             Message="{Binding Detail.ProbeNotes}"
                             Visibility="{Binding Detail.HasProbeNotes, Converter={StaticResource BoolToVis}}" />

                    <!-- failure detail -->
                    <StackPanel Spacing="6" Visibility="{Binding Detail.IsFailure, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding Detail.FailureTitle}" FontWeight="SemiBold" />
                        <TextBox Text="{Binding Detail.FailureMessage}" IsReadOnly="True" TextWrapping="Wrap"
                                 FontFamily="Consolas" AcceptsReturn="True" MinHeight="60" />
                        <TextBlock Text="{Binding Detail.JobLine}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Visibility="{Binding Detail.HasJob, Converter={StaticResource BoolToVis}}" />
                        <StackPanel Orientation="Horizontal" Spacing="8"
                                    Visibility="{Binding Detail.HasJob, Converter={StaticResource BoolToVis}}">
                            <Button Content="Load probe logs" Command="{Binding Detail.LoadLogsCommand}" />
                            <ProgressRing Width="16" Height="16" IsActive="{Binding Detail.IsLoadingLogs}" />
                        </StackPanel>
                        <TextBox Text="{Binding Detail.LogsText}" IsReadOnly="True" TextWrapping="NoWrap"
                                 FontFamily="Consolas" AcceptsReturn="True" MaxHeight="240"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 Visibility="{Binding Detail.LogsLoaded, Converter={StaticResource BoolToVis}}" />
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>

            <!-- detail footer -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                <Button x:Name="CopyJsonButton" Content="Copy as JSON" Click="OnCopyJson"
                        Visibility="{Binding Detail.HasManifest, Converter={StaticResource BoolToVis}}" />
                <Button Content="Back" Command="{Binding Detail.CloseCommand}" />
            </StackPanel>
        </Grid>
    </Grid>
</ContentDialog>
