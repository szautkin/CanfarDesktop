<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="CanfarDesktop.Views.Dialogs.AgentProposalsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CanfarDesktop.Views.Dialogs"
    x:Uid="AgentProposalsDialog"
    CloseButtonText="Close"
    DefaultButton="Close">

    <ContentDialog.Resources>
        <x:Double x:Key="ContentDialogMinWidth">600</x:Double>
        <x:Double x:Key="ContentDialogMaxWidth">680</x:Double>
    </ContentDialog.Resources>

    <Grid RowSpacing="8" MinHeight="420" MinWidth="560">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10">
            <FontIcon Glyph="&#xE99A;" FontSize="20" Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
            <StackPanel Spacing="2">
                <TextBlock x:Uid="Proposals_Header" Text="Agent Proposals" Style="{StaticResource SubtitleTextBlockStyle}" />
                <TextBlock x:Uid="Proposals_HeaderCaption" Text="Review and apply changes proposed by AI agents."
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </StackPanel>

        <!-- Pending / History tabs -->
        <Pivot Grid.Row="1" x:Name="TabsPivot">
            <PivotItem x:Name="PendingTab" x:Uid="Proposals_PendingTab" Header="Pending">
                <Grid Padding="0,8,0,0">
                    <StackPanel x:Name="PendingEmptyState" Spacing="8"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                Visibility="Collapsed">
                        <FontIcon Glyph="&#xE7B8;" FontSize="36" HorizontalAlignment="Center"
                                  Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                        <TextBlock x:Uid="Proposals_PendingEmpty" Text="No pending proposals." HorizontalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                    <ListView x:Name="PendingList" SelectionMode="None" IsItemClickEnabled="False">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:ProposalRow">
                                <StackPanel Spacing="4" Padding="0,6">
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" CornerRadius="9" Padding="8,2"
                                                VerticalAlignment="Center"
                                                Background="{ThemeResource AccentFillColorDefaultBrush}"
                                                Opacity="0.85">
                                            <TextBlock Text="{x:Bind Kind}" FontSize="11" FontFamily="Consolas"
                                                       Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" />
                                        </Border>
                                        <TextBlock Grid.Column="1" Text="{x:Bind Summary}" TextWrapping="Wrap"
                                                   MaxLines="2" VerticalAlignment="Center" />
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6"
                                                    VerticalAlignment="Center">
                                            <ProgressRing Width="18" Height="18"
                                                          IsActive="{x:Bind IsBusy, Mode=OneWay}"
                                                          Visibility="{x:Bind BusyVisibility, Mode=OneWay}" />
                                            <Button x:Uid="Proposals_RejectButton" Content="Reject" Click="OnRejectClick"
                                                    Visibility="{x:Bind ButtonsVisibility, Mode=OneWay}" />
                                            <Button x:Uid="Proposals_ApplyButton" Content="Apply" Click="OnApplyClick"
                                                    Style="{StaticResource AccentButtonStyle}"
                                                    Visibility="{x:Bind ButtonsVisibility, Mode=OneWay}" />
                                        </StackPanel>
                                    </Grid>
                                    <TextBlock Text="{x:Bind Meta}" Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Text="{x:Bind Error, Mode=OneWay}" TextWrapping="Wrap"
                                               Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                               Visibility="{x:Bind ErrorVisibility, Mode=OneWay}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </PivotItem>
            <PivotItem x:Name="HistoryTab" x:Uid="Proposals_HistoryTab" Header="History">
                <Grid Padding="0,8,0,0">
                    <StackPanel x:Name="HistoryEmptyState" Spacing="8"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                Visibility="Collapsed">
                        <FontIcon Glyph="&#xE823;" FontSize="36" HorizontalAlignment="Center"
                                  Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                        <TextBlock x:Uid="Proposals_HistoryEmpty" Text="No agent activity yet." HorizontalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock x:Uid="Proposals_HistoryEmptyCaption" Text="Applied proposals, rejections, and live UI ops appear here."
                                   Style="{StaticResource CaptionTextBlockStyle}" HorizontalAlignment="Center"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    </StackPanel>
                    <ListView x:Name="HistoryList" SelectionMode="None" IsItemClickEnabled="False">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="local:HistoryRow">
                                <Grid ColumnSpacing="8" Padding="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Grid.Column="0" Glyph="{x:Bind Glyph}" FontSize="14"
                                              VerticalAlignment="Top" Margin="0,2,0,0"
                                              Foreground="{x:Bind GlyphBrush}" />
                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <TextBlock Text="{x:Bind Summary}" TextWrapping="Wrap" MaxLines="2" />
                                        <TextBlock Text="{x:Bind Subtitle}" Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </PivotItem>
        </Pivot>

        <!-- Footer -->
        <Grid Grid.Row="2">
            <TextBlock x:Name="PendingCountText" Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <TextBlock x:Uid="Proposals_FooterHint" Text="Apply runs the underlying operation; Reject discards."
                       Style="{StaticResource CaptionTextBlockStyle}" HorizontalAlignment="Right"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
        </Grid>
    </Grid>
</ContentDialog>
