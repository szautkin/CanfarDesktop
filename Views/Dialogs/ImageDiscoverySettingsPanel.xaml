<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="CanfarDesktop.Views.Dialogs.ImageDiscoverySettingsPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel Spacing="12">
        <TextBlock x:Uid="Discovery_SettingsIntro" TextWrapping="Wrap" Style="{StaticResource CaptionTextBlockStyle}"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                   Text="Choose the host image used to inspect non-headless images, and (optionally) registry credentials for pulling private images." />

        <TextBox x:Name="InspectorImageBox" x:Uid="Discovery_InspectorImageBox" Header="Inspector image"
                 PlaceholderText="images.canfar.net/skaha/terminal:1.1.2" />
        <TextBlock x:Uid="Discovery_InspectorCaption" Style="{StaticResource CaptionTextBlockStyle}" TextWrapping="Wrap"
                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                   Text="The headless host that runs syft against a non-headless target image. Must ship bash + python3 + curl/wget. Leave blank to use the default." />

        <TextBox x:Name="RegistryHostBox" x:Uid="Discovery_RegistryHostBox" Header="Registry host" PlaceholderText="images.canfar.net" />
        <TextBox x:Name="RegistryRepoBox" x:Uid="Discovery_RegistryRepoBox" Header="Registry repository (project)" PlaceholderText="skaha" />
        <TextBlock x:Uid="Discovery_RepoCaption" Style="{StaticResource CaptionTextBlockStyle}" TextWrapping="Wrap"
                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                   Text="Optional project/namespace used to expand a short inspector image name to host/project/name. A full image path is used as-is." />
        <TextBox x:Name="UsernameBox" x:Uid="Discovery_UsernameBox" Header="Registry username" />

        <StackPanel Spacing="4">
            <PasswordBox x:Name="SecretBox" x:Uid="Discovery_SecretBox" Header="Registry secret (Harbor CLI secret)" />
            <TextBlock x:Name="SecretStatus" Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" TextWrapping="Wrap" />
            <Button x:Name="RemoveSecretButton" x:Uid="Discovery_RemoveSecretButton" Content="Remove secret" Click="OnRemoveSecret"
                    HorizontalAlignment="Left" Visibility="Collapsed" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Spacing="8">
            <Button x:Name="SaveButton" x:Uid="Discovery_SaveButton" Content="Save" Click="OnSave" Style="{StaticResource AccentButtonStyle}" />
            <Button x:Name="TestButton" x:Uid="Discovery_TestButton" Content="Test credentials" Click="OnTestCredentials" />
        </StackPanel>

        <InfoBar x:Name="StatusBar" IsOpen="False" IsClosable="True" Severity="Informational" />

        <StackPanel x:Name="CacheSection" Spacing="6" Visibility="Collapsed">
            <TextBlock x:Uid="Discovery_CacheHeader" Text="Discovery cache" Style="{StaticResource BodyStrongTextBlockStyle}" />
            <TextBlock x:Name="CacheCountText" Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
            <Button x:Name="ClearCacheButton" x:Uid="Discovery_ClearCacheButton" Content="Clear cache" Click="OnClearCache" HorizontalAlignment="Left" />
        </StackPanel>

        <Button x:Name="ResetButton" x:Uid="Discovery_ResetButton" Content="Reset to defaults" Click="OnResetClick" HorizontalAlignment="Left" />
        <Border x:Name="ResetConfirmPanel" Visibility="Collapsed" CornerRadius="6" Padding="12,10"
                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
            <StackPanel Spacing="8">
                <TextBlock x:Uid="Discovery_ResetConfirmBody" TextWrapping="Wrap" Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Text="Reset the registry host, repository, username, inspector image, and the stored secret to defaults? Cached discovery manifests on disk are not affected." />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button x:Uid="Discovery_ResetConfirmButton" Content="Reset" Click="OnResetConfirm" Style="{StaticResource AccentButtonStyle}" />
                    <Button x:Uid="Discovery_ResetCancelButton" Content="Cancel" Click="OnResetCancel" />
                </StackPanel>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
