<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="CanfarDesktop.Views.Dialogs.McpServerSettingsPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel Spacing="14" Width="460">

        <TextBlock x:Uid="Mcp_Intro" TextWrapping="Wrap" Style="{StaticResource CaptionTextBlockStyle}"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                   Text="Let Claude (Desktop or Code) read your CADC/CANFAR data over a local, read-only MCP server — observation search, Skaha sessions, downloaded research, image discovery, and more. Off by default; nothing is exposed until you turn it on." />

        <ToggleSwitch x:Name="EnableToggle" x:Uid="Mcp_EnableToggle" Header="Enable MCP server"
                      OnContent="On" OffContent="Off" Toggled="OnEnableToggled" />

        <Border CornerRadius="6" Padding="12,10"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
            <StackPanel Spacing="4">
                <TextBlock x:Name="StatusText" Style="{StaticResource BodyStrongTextBlockStyle}" Text="Stopped" />
                <TextBlock x:Name="PipeText" FontFamily="Consolas" FontSize="12"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                           IsTextSelectionEnabled="True" TextWrapping="Wrap" Visibility="Collapsed" />
            </StackPanel>
        </Border>

        <TextBlock x:Uid="Mcp_AutonomyHeader" Text="Agent autonomy" Style="{StaticResource BodyStrongTextBlockStyle}" />
        <ToggleSwitch x:Name="AutoApplyToggle" x:Uid="Mcp_AutoApplyToggle" Header="Auto-apply agent writes"
                      OnContent="On" OffContent="Off" Toggled="OnAutoApplyToggled" />
        <TextBlock x:Uid="Mcp_AutoApplyCaption" Style="{StaticResource CaptionTextBlockStyle}" TextWrapping="Wrap"
                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                   Text="When on, an agent's writes (e.g. saving a query) apply immediately and show in the activity feed below. When off, they queue for you to review. Destructive writes (deletes) always queue regardless." />
        <ToggleSwitch x:Name="FollowActivityToggle" x:Uid="Mcp_FollowActivityToggle" Header="Follow agent activity"
                      OnContent="On" OffContent="Off" Toggled="OnFollowActivityToggled" />
        <TextBlock x:Uid="Mcp_FollowActivityCaption" Style="{StaticResource CaptionTextBlockStyle}" TextWrapping="Wrap"
                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                   Text="Navigate to the relevant view after an applied write." />

        <ToggleSwitch x:Name="ShowAiGuideToggle" x:Uid="Mcp_ShowAiGuideToggle" Header="Show AI Guide on landing"
                      OnContent="On" OffContent="Off" Toggled="OnShowAiGuideToggled" />
        <TextBlock x:Uid="Mcp_ShowAiGuideCaption" Style="{StaticResource CaptionTextBlockStyle}" TextWrapping="Wrap"
                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                   Text="Add an AI Guide tile to the landing page — re-tune each tool's description and add your own read-only guide tools. Your overrides stay active whether or not the tile is shown." />

        <TextBlock x:Uid="Mcp_ConnectHeader" Text="Connect Claude Desktop" Style="{StaticResource BodyStrongTextBlockStyle}" />
        <TextBlock x:Name="ConnectIntro" x:Uid="Mcp_ConnectIntro" TextWrapping="Wrap" Style="{StaticResource CaptionTextBlockStyle}"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                   Text="Add Verbinal to your Claude Desktop config. Your other MCP servers are preserved and a .bak is kept. Restart Claude Desktop afterwards." />

        <Button x:Name="ConnectButton" x:Uid="Mcp_ConnectButton" Content="Add to Claude Desktop…" Click="OnConnectClick" />

        <!-- Inline confirmation (no nested dialog) -->
        <Border x:Name="ConfirmPanel" Visibility="Collapsed" CornerRadius="6" Padding="12,10"
                Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
            <StackPanel Spacing="8">
                <TextBlock x:Uid="Mcp_ConfirmHeader" Text="Confirm config change" Style="{StaticResource BodyStrongTextBlockStyle}" />
                <TextBlock x:Name="ConfirmTargetText" TextWrapping="Wrap" Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock x:Uid="Mcp_CommandLabel" Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="Command:" />
                <TextBlock x:Name="ConfirmCommandText" FontFamily="Consolas" FontSize="12"
                           IsTextSelectionEnabled="True" TextWrapping="Wrap"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button x:Name="ConfirmWriteButton" x:Uid="Mcp_ConfirmWriteButton" Content="Write config" Click="OnConfirmWriteClick"
                            Style="{StaticResource AccentButtonStyle}" />
                    <Button x:Uid="Mcp_ConfirmCancelButton" Content="Cancel" Click="OnConfirmCancelClick" />
                </StackPanel>
            </StackPanel>
        </Border>

        <InfoBar x:Name="ResultBar" IsOpen="False" IsClosable="True" />

        <TextBlock x:Uid="Mcp_ClaudeCodeLabel" Text="…or, for Claude Code, run:" Style="{StaticResource CaptionTextBlockStyle}"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        <Grid ColumnSpacing="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="ClaudeCodeBox" Grid.Column="0" IsReadOnly="True"
                     FontFamily="Consolas" FontSize="12" TextWrapping="Wrap" />
            <Button x:Name="CopyCommandButton" x:Uid="Mcp_CopyCommandButton" Grid.Column="1" VerticalAlignment="Top"
                    Click="OnCopyCommandClick" ToolTipService.ToolTip="Copy">
                <FontIcon Glyph="&#xE8C8;" FontSize="14" />
            </Button>
        </Grid>

        <TextBlock x:Uid="Mcp_ClientsHeader" Text="Connected clients" Style="{StaticResource BodyStrongTextBlockStyle}" />
        <ToggleSwitch x:Name="RequireApprovalToggle" x:Uid="Mcp_RequireApprovalToggle" Header="Require approval for new clients"
                      OnContent="On" OffContent="Off" Toggled="OnRequireApprovalToggled" />
        <TextBlock x:Uid="Mcp_RequireApprovalCaption" Style="{StaticResource CaptionTextBlockStyle}" TextWrapping="Wrap"
                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                   Text="When on, only approved clients may connect — others are refused until you approve them below. The connection identity is self-reported, so this is for visibility and revocation; the real boundary is that the server only listens on your private per-user pipe." />
        <TextBlock x:Name="NoClientsText" x:Uid="Mcp_NoClients" Style="{StaticResource CaptionTextBlockStyle}"
                   Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="No clients have connected yet." />
        <ItemsControl x:Name="ClientsList">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="0,4" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="{Binding ClientId}" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding Subtitle}" Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                        </StackPanel>
                        <Button Grid.Column="1" Content="{Binding ActionLabel}" Tag="{Binding ClientId}"
                                Click="OnClientActionClick" VerticalAlignment="Center" />
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <TextBlock x:Uid="Mcp_ActivityHeader" Text="Recent agent activity" Style="{StaticResource BodyStrongTextBlockStyle}" />
        <TextBlock x:Name="NoActivityText" x:Uid="Mcp_NoActivity" Style="{StaticResource CaptionTextBlockStyle}"
                   Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="No agent activity yet." />
        <ItemsControl x:Name="ActivityList">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="0,4" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Grid.Column="0" Glyph="{Binding Glyph}" FontSize="14" VerticalAlignment="Top"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <StackPanel Grid.Column="1" Spacing="2">
                            <TextBlock Text="{Binding Summary}" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding Subtitle}" Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <Expander x:Uid="Mcp_DiagnosticsExpander" Header="Diagnostics" HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
            <StackPanel Spacing="8">
                <TextBlock x:Uid="Mcp_DiagnosticsCaption" TextWrapping="Wrap" Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Text="Check every link in the chain — server, listener, bridge exe, Claude clients, and the Claude Desktop config — with a one-click fix where one exists." />
                <Button x:Name="RunDiagnosticsButton" x:Uid="Mcp_RunDiagnosticsButton" Content="Run diagnostics" Click="OnRunDiagnosticsClick" />
                <ItemsControl x:Name="DiagnosticsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="0,4" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <FontIcon Grid.Column="0" Glyph="{Binding Glyph}" FontSize="14" VerticalAlignment="Top"
                                          Foreground="{Binding GlyphBrush}" />
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock Text="{Binding Title}" TextWrapping="Wrap" />
                                    <TextBlock Text="{Binding Message}" Style="{StaticResource CaptionTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                               IsTextSelectionEnabled="True" TextWrapping="Wrap" />
                                </StackPanel>
                                <Button Grid.Column="2" Content="{Binding FixLabel}" Tag="{Binding FixId}"
                                        Visibility="{Binding FixVisibility}" Click="OnDiagnosticFixClick"
                                        VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Expander>

    </StackPanel>
</UserControl>
