<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="CanfarDesktop.Views.Dialogs.SessionEventsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Session Details"
    CloseButtonText="Close"
    DefaultButton="Close">

    <ContentDialog.Resources>
        <x:Double x:Key="ContentDialogMinWidth">600</x:Double>
        <x:Double x:Key="ContentDialogMaxWidth">600</x:Double>
    </ContentDialog.Resources>

    <Grid MinHeight="200">
        <!-- Loading spinner (visible while fetching) -->
        <StackPanel x:Name="LoadingPanel" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
            <ProgressRing IsActive="True" Width="32" Height="32" />
            <TextBlock Text="Loading..." Style="{StaticResource CaptionTextBlockStyle}"
                       HorizontalAlignment="Center" Opacity="0.6" />
        </StackPanel>

        <!-- Tabbed content (hidden until loaded) -->
        <Pivot x:Name="ContentPivot" Visibility="Collapsed" IsEnabled="False">
            <PivotItem Header="Events">
                <ScrollViewer MaxHeight="400">
                    <TextBlock x:Name="EventsText" TextWrapping="Wrap" IsTextSelectionEnabled="True"
                               FontFamily="Consolas" FontSize="12" Padding="4" />
                </ScrollViewer>
            </PivotItem>
            <PivotItem Header="Logs">
                <ScrollViewer MaxHeight="400">
                    <TextBlock x:Name="LogsText" TextWrapping="Wrap" IsTextSelectionEnabled="True"
                               FontFamily="Consolas" FontSize="12" Padding="4" />
                </ScrollViewer>
            </PivotItem>
        </Pivot>
    </Grid>
</ContentDialog>
