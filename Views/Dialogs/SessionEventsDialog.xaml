<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="CanfarDesktop.Views.Dialogs.SessionEventsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Session Events"
    CloseButtonText="Close"
    DefaultButton="Close">

    <ScrollViewer MaxHeight="400" MinWidth="500">
        <TextBlock x:Name="EventsText" TextWrapping="Wrap" IsTextSelectionEnabled="True"
                   FontFamily="Consolas" FontSize="12" />
    </ScrollViewer>
</ContentDialog>
