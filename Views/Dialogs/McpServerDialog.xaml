<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="CanfarDesktop.Views.Dialogs.McpServerDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="MCP server"
    CloseButtonText="Close"
    DefaultButton="Close">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="14" Width="460">

            <TextBlock TextWrapping="Wrap" Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="Let Claude (Desktop or Code) read your CADC/CANFAR data over a local, read-only MCP server — observation search, Skaha sessions, downloaded research, image discovery, and more. Off by default; nothing is exposed until you turn it on." />

            <ToggleSwitch x:Name="EnableToggle" Header="Enable MCP server"
                          OnContent="On" OffContent="Off" Toggled="OnEnableToggled" />

            <Border CornerRadius="6" Padding="12,10"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="4">
                    <TextBlock x:Name="StatusText" Style="{StaticResource BodyStrongTextBlockStyle}" Text="Stopped" />
                    <TextBlock x:Name="PipeText" FontFamily="Consolas" FontSize="12"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                               IsTextSelectionEnabled="True" TextWrapping="Wrap" Visibility="Collapsed" />
                </StackPanel>
            </Border>

            <TextBlock Text="Connect Claude Desktop" Style="{StaticResource BodyStrongTextBlockStyle}" />
            <TextBlock x:Name="ConnectIntro" TextWrapping="Wrap" Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="Add Verbinal to your Claude Desktop config. Your other MCP servers are preserved and a .bak is kept. Restart Claude Desktop afterwards." />

            <Button x:Name="ConnectButton" Content="Add to Claude Desktop…" Click="OnConnectClick" />

            <!-- Inline confirmation (no nested dialog) -->
            <Border x:Name="ConfirmPanel" Visibility="Collapsed" CornerRadius="6" Padding="12,10"
                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="8">
                    <TextBlock Text="Confirm config change" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <TextBlock x:Name="ConfirmTargetText" TextWrapping="Wrap" Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="Command:" />
                    <TextBlock x:Name="ConfirmCommandText" FontFamily="Consolas" FontSize="12"
                               IsTextSelectionEnabled="True" TextWrapping="Wrap"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="ConfirmWriteButton" Content="Write config" Click="OnConfirmWriteClick"
                                Style="{StaticResource AccentButtonStyle}" />
                        <Button Content="Cancel" Click="OnConfirmCancelClick" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <InfoBar x:Name="ResultBar" IsOpen="False" IsClosable="True" />

            <TextBlock Text="…or, for Claude Code, run:" Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <Grid ColumnSpacing="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="ClaudeCodeBox" Grid.Column="0" IsReadOnly="True"
                         FontFamily="Consolas" FontSize="12" TextWrapping="Wrap" />
                <Button x:Name="CopyCommandButton" Grid.Column="1" VerticalAlignment="Top"
                        Click="OnCopyCommandClick" ToolTipService.ToolTip="Copy">
                    <FontIcon Glyph="&#xE8C8;" FontSize="14" />
                </Button>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</ContentDialog>
