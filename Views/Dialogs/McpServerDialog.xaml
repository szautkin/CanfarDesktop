<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="CanfarDesktop.Views.Dialogs.McpServerDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="MCP server"
    CloseButtonText="Close"
    DefaultButton="Close">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="14" Width="460">

            <TextBlock TextWrapping="Wrap" Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="Let Claude (Desktop or Code) read your CADC/CANFAR data over a local, read-only MCP server — observation search, Skaha sessions, downloaded research, image discovery, and more. Off by default; nothing is exposed until you turn it on." />

            <ToggleSwitch x:Name="EnableToggle" Header="Enable MCP server"
                          OnContent="On" OffContent="Off" Toggled="OnEnableToggled" />

            <Border CornerRadius="6" Padding="12,10"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="4">
                    <TextBlock x:Name="StatusText" Style="{StaticResource BodyStrongTextBlockStyle}" Text="Stopped" />
                    <TextBlock x:Name="PipeText" FontFamily="Consolas" FontSize="12"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                               IsTextSelectionEnabled="True" TextWrapping="Wrap" Visibility="Collapsed" />
                </StackPanel>
            </Border>

            <TextBlock Text="Agent autonomy" Style="{StaticResource BodyStrongTextBlockStyle}" />
            <ToggleSwitch x:Name="AutoApplyToggle" Header="Auto-apply agent writes"
                          OnContent="On" OffContent="Off" Toggled="OnAutoApplyToggled" />
            <TextBlock Style="{StaticResource CaptionTextBlockStyle}" TextWrapping="Wrap"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                       Text="When on, an agent's writes (e.g. saving a query) apply immediately and show in the activity feed below. When off, they queue for you to review." />
            <ToggleSwitch x:Name="FollowActivityToggle" Header="Follow agent activity"
                          OnContent="On" OffContent="Off" Toggled="OnFollowActivityToggled" />
            <TextBlock Style="{StaticResource CaptionTextBlockStyle}" TextWrapping="Wrap"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                       Text="Navigate to the relevant view after an applied write." />

            <ToggleSwitch x:Name="ShowAiGuideToggle" Header="Show AI Guide on landing"
                          OnContent="On" OffContent="Off" Toggled="OnShowAiGuideToggled" />
            <TextBlock Style="{StaticResource CaptionTextBlockStyle}" TextWrapping="Wrap"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                       Text="Add an AI Guide tile to the landing page — re-tune each tool's description and add your own read-only guide tools. Your overrides stay active whether or not the tile is shown." />

            <TextBlock Text="Connect Claude Desktop" Style="{StaticResource BodyStrongTextBlockStyle}" />
            <TextBlock x:Name="ConnectIntro" TextWrapping="Wrap" Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="Add Verbinal to your Claude Desktop config. Your other MCP servers are preserved and a .bak is kept. Restart Claude Desktop afterwards." />

            <Button x:Name="ConnectButton" Content="Add to Claude Desktop…" Click="OnConnectClick" />

            <!-- Inline confirmation (no nested dialog) -->
            <Border x:Name="ConfirmPanel" Visibility="Collapsed" CornerRadius="6" Padding="12,10"
                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="8">
                    <TextBlock Text="Confirm config change" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <TextBlock x:Name="ConfirmTargetText" TextWrapping="Wrap" Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="Command:" />
                    <TextBlock x:Name="ConfirmCommandText" FontFamily="Consolas" FontSize="12"
                               IsTextSelectionEnabled="True" TextWrapping="Wrap"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button x:Name="ConfirmWriteButton" Content="Write config" Click="OnConfirmWriteClick"
                                Style="{StaticResource AccentButtonStyle}" />
                        <Button Content="Cancel" Click="OnConfirmCancelClick" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <InfoBar x:Name="ResultBar" IsOpen="False" IsClosable="True" />

            <TextBlock Text="…or, for Claude Code, run:" Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <Grid ColumnSpacing="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox x:Name="ClaudeCodeBox" Grid.Column="0" IsReadOnly="True"
                         FontFamily="Consolas" FontSize="12" TextWrapping="Wrap" />
                <Button x:Name="CopyCommandButton" Grid.Column="1" VerticalAlignment="Top"
                        Click="OnCopyCommandClick" ToolTipService.ToolTip="Copy">
                    <FontIcon Glyph="&#xE8C8;" FontSize="14" />
                </Button>
            </Grid>

            <TextBlock Text="Connected clients" Style="{StaticResource BodyStrongTextBlockStyle}" />
            <ToggleSwitch x:Name="RequireApprovalToggle" Header="Require approval for new clients"
                          OnContent="On" OffContent="Off" Toggled="OnRequireApprovalToggled" />
            <TextBlock Style="{StaticResource CaptionTextBlockStyle}" TextWrapping="Wrap"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                       Text="When on, only approved clients may connect — others are refused until you approve them below. The connection identity is self-reported, so this is for visibility and revocation; the real boundary is that the server only listens on your private per-user pipe." />
            <TextBlock x:Name="NoClientsText" Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="No clients have connected yet." />
            <ItemsControl x:Name="ClientsList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="0,4" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock Text="{Binding ClientId}" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding Subtitle}" Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                            </StackPanel>
                            <Button Grid.Column="1" Content="{Binding ActionLabel}" Tag="{Binding ClientId}"
                                    Click="OnClientActionClick" VerticalAlignment="Center" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Text="Recent agent activity" Style="{StaticResource BodyStrongTextBlockStyle}" />
            <TextBlock x:Name="NoActivityText" Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="No agent activity yet." />
            <ItemsControl x:Name="ActivityList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="0,4" ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <FontIcon Grid.Column="0" Glyph="{Binding Glyph}" FontSize="14" VerticalAlignment="Top"
                                      Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock Text="{Binding Summary}" TextWrapping="Wrap" />
                                <TextBlock Text="{Binding Subtitle}" Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </ScrollViewer>
</ContentDialog>
