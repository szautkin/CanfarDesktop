<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="CanfarDesktop.Views.WorkflowsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:CanfarDesktop.Views">

    <Grid ColumnSpacing="12" Padding="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ── Left: workflow list ─────────────────────────────────────────── -->
        <Grid Grid.Column="0" RowSpacing="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="Workflows" Style="{StaticResource SubtitleTextBlockStyle}" VerticalAlignment="Center" />
                <Button x:Name="NewButton" Click="OnNewClick" ToolTipService.ToolTip="New workflow">
                    <FontIcon Glyph="&#xE710;" FontSize="14" />
                </Button>
                <Button x:Name="ImportButton" Click="OnImportClick" ToolTipService.ToolTip="Import a .workflow.md file">
                    <FontIcon Glyph="&#xE8E5;" FontSize="14" />
                </Button>
            </StackPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="4">
                    <TextBlock Text="TEMPLATES" Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="4,8,0,2" />
                    <ListView x:Name="BuiltInList" SelectionChanged="OnListSelectionChanged"
                              SelectionMode="Single" IsItemClickEnabled="False" />

                    <TextBlock Text="MY WORKFLOWS" Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" Margin="4,12,0,2" />
                    <ListView x:Name="LocalList" SelectionChanged="OnListSelectionChanged"
                              SelectionMode="Single" />
                    <TextBlock x:Name="LocalEmptyHint" Text="Pick a template and press “Use this workflow” to start."
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}" Margin="4,0,0,0" TextWrapping="Wrap" />

                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="4,12,0,2">
                        <TextBlock Text="VOSPACE" Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                        <Button x:Name="VosRefreshButton" Click="OnVosRefreshClick" Padding="4,2"
                                ToolTipService.ToolTip="Refresh vos:&lt;you&gt;/workflows">
                            <FontIcon Glyph="&#xE72C;" FontSize="11" />
                        </Button>
                    </StackPanel>
                    <ListView x:Name="VosList" SelectionChanged="OnListSelectionChanged" SelectionMode="Single" />
                    <TextBlock x:Name="VosHint" Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}" Margin="4,0,0,0" TextWrapping="Wrap" />
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ── Right: detail ───────────────────────────────────────────────── -->
        <Grid Grid.Column="1">

            <TextBlock x:Name="EmptyState" Text="Select a workflow to see its steps — or start from a template."
                       Style="{StaticResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />

            <Grid x:Name="DetailPane" Visibility="Collapsed" RowSpacing="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Spacing="4">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock x:Name="DetailTitle" Style="{StaticResource SubtitleTextBlockStyle}" TextWrapping="Wrap" />
                        <Border x:Name="SourceBadge" CornerRadius="4" Padding="6,1" VerticalAlignment="Center"
                                Background="{ThemeResource AccentFillColorTertiaryBrush}">
                            <TextBlock x:Name="SourceBadgeText" Style="{StaticResource CaptionTextBlockStyle}" />
                        </Border>
                    </StackPanel>
                    <TextBlock x:Name="DetailDescription" Style="{StaticResource BodyTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <ItemsControl x:Name="TagChips">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><StackPanel Orientation="Horizontal" Spacing="4" /></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="x:String">
                                    <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}" CornerRadius="8" Padding="8,2">
                                        <TextBlock Text="{x:Bind}" Style="{StaticResource CaptionTextBlockStyle}" />
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock x:Name="TimeText" Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}" VerticalAlignment="Center" />
                    </StackPanel>
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ProgressBar x:Name="ProgressBarCtl" VerticalAlignment="Center" />
                        <TextBlock x:Name="ProgressText" Grid.Column="1" Style="{StaticResource CaptionTextBlockStyle}" />
                    </Grid>
                </StackPanel>

                <!-- Steps -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="StepsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="views:WorkflowStepRow">
                                <Border Margin="0,0,8,8" Padding="12" CornerRadius="8"
                                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderThickness="{x:Bind AccentThickness, Mode=OneWay}"
                                        BorderBrush="{ThemeResource AccentFillColorDefaultBrush}">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Number roundel: number → accent check when done. Click toggles. -->
                                        <Button Width="36" Height="36" Padding="0" CornerRadius="18"
                                                VerticalAlignment="Top"
                                                Background="{x:Bind RoundelBrush, Mode=OneWay}"
                                                IsEnabled="{x:Bind CanToggle}"
                                                Click="OnStepToggleClick" Tag="{x:Bind Index}"
                                                ToolTipService.ToolTip="{x:Bind ToggleTooltip}">
                                            <Grid>
                                                <TextBlock Text="{x:Bind Number}" HorizontalAlignment="Center"
                                                           Visibility="{x:Bind NumberVisibility, Mode=OneWay}" />
                                                <FontIcon Glyph="&#xE73E;" FontSize="16"
                                                          Visibility="{x:Bind CheckVisibility, Mode=OneWay}" />
                                            </Grid>
                                        </Button>

                                        <StackPanel Grid.Column="1" Spacing="4">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="{x:Bind Title}" Style="{StaticResource BodyStrongTextBlockStyle}"
                                                           TextWrapping="Wrap" TextDecorations="{x:Bind TitleDecorations, Mode=OneWay}"
                                                           Opacity="{x:Bind BodyOpacity, Mode=OneWay}" />
                                                <Border Visibility="{x:Bind CurrentPillVisibility, Mode=OneWay}"
                                                        Background="{ThemeResource AccentFillColorTertiaryBrush}"
                                                        CornerRadius="8" Padding="8,1" VerticalAlignment="Center">
                                                    <TextBlock Text="current" Style="{StaticResource CaptionTextBlockStyle}" />
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{x:Bind Body}" TextWrapping="Wrap"
                                                       Visibility="{x:Bind BodyVisibility}"
                                                       Opacity="{x:Bind BodyOpacity, Mode=OneWay}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            <TextBlock Text="{x:Bind Note}" TextWrapping="Wrap" FontStyle="Italic"
                                                       Visibility="{x:Bind NoteVisibility}"
                                                       Style="{StaticResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <ItemsControl ItemsSource="{x:Bind Tools}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal" Spacing="4" /></ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="x:String">
                                                            <Button Padding="8,2" CornerRadius="10" Click="OnToolChipClick" Tag="{x:Bind}"
                                                                    Background="{ThemeResource AccentFillColorTertiaryBrush}"
                                                                    ToolTipService.ToolTip="Agent tool — click to copy the name">
                                                                <TextBlock FontFamily="Consolas" FontSize="12" Text="{x:Bind}" />
                                                            </Button>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                <HyperlinkButton Content="{x:Bind ViewLinkText}" Padding="4,0"
                                                                 Visibility="{x:Bind ViewLinkVisibility}"
                                                                 Click="OnViewLinkClick" Tag="{x:Bind ViewKey}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Actions -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
                    <Button x:Name="UseButton" Click="OnUseClick" Style="{StaticResource AccentButtonStyle}" Content="Use this workflow" />
                    <Button x:Name="EditButton" Click="OnEditClick" Content="Edit" />
                    <Button x:Name="DuplicateButton" Click="OnDuplicateClick" Content="Duplicate" />
                    <Button x:Name="PublishButton" Click="OnPublishClick" Content="Publish to VOSpace" />
                    <Button x:Name="CopyPromptButton" Click="OnCopyPromptClick" Content="Copy agent prompt" />
                    <Button x:Name="DeleteButton" Click="OnDeleteClick" Content="Delete" />
                </StackPanel>
            </Grid>

            <!-- ── Edit mode ──────────────────────────────────────────────── -->
            <Grid x:Name="EditPane" Visibility="Collapsed" RowSpacing="8" ColumnSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="Edit workflow (markdown checklist — changes preview live)"
                           Grid.ColumnSpan="2" Style="{StaticResource BodyStrongTextBlockStyle}" />
                <TextBox x:Name="EditorBox" Grid.Row="1" AcceptsReturn="True" TextWrapping="NoWrap"
                         FontFamily="Consolas" FontSize="13" TextChanged="OnEditorTextChanged"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto" />
                <ScrollViewer Grid.Row="1" Grid.Column="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="4">
                        <TextBlock x:Name="PreviewTitle" Style="{StaticResource SubtitleTextBlockStyle}" TextWrapping="Wrap" />
                        <ItemsControl x:Name="PreviewSteps" />
                    </StackPanel>
                </ScrollViewer>
                <TextBlock x:Name="EditorWarnings" Grid.Row="2" Grid.ColumnSpan="2" TextWrapping="Wrap"
                           Foreground="{ThemeResource SystemFillColorCautionBrush}"
                           Style="{StaticResource CaptionTextBlockStyle}" />
                <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Orientation="Horizontal" Spacing="8">
                    <Button x:Name="SaveEditButton" Click="OnSaveEditClick" Style="{StaticResource AccentButtonStyle}" Content="Save" />
                    <Button Click="OnCancelEditClick" Content="Cancel" />
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
