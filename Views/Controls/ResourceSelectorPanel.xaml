<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="CanfarDesktop.Views.Controls.ResourceSelectorPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel Spacing="12">
        <!-- CPU Cores -->
        <StackPanel Spacing="4">
            <StackPanel Orientation="Horizontal" Spacing="4">
                <TextBlock Text="CPU Cores" Style="{StaticResource BodyTextBlockStyle}" VerticalAlignment="Center" />
                <Button x:Name="CpuHelpBtn" Padding="2" MinWidth="0" MinHeight="0"
                        Background="Transparent" BorderThickness="0" Click="OnHelpClick">
                    <FontIcon Glyph="&#xE897;" FontSize="12" Opacity="0.5" />
                </Button>
                <TeachingTip x:Name="CpuTip" Target="{x:Bind CpuHelpBtn}"
                             Title="CPU Cores"
                             Subtitle="Number of cores used by the session." />
            </StackPanel>
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <NumberBox x:Name="CoresBox" Grid.Column="0"
                           SpinButtonPlacementMode="Inline" SmallChange="1" LargeChange="2"
                           Minimum="1" Width="130"
                           ValueChanged="OnCoresBoxChanged" />
                <Slider x:Name="CoresSlider" Grid.Column="1"
                        VerticalAlignment="Center"
                        StepFrequency="1" SnapsTo="StepValues"
                        TickPlacement="BottomRight" TickFrequency="1"
                        ValueChanged="OnCoresSliderChanged" />
            </Grid>
        </StackPanel>

        <!-- RAM (GB) — slider snaps to power-of-2 values -->
        <StackPanel Spacing="4">
            <StackPanel Orientation="Horizontal" Spacing="4">
                <TextBlock Text="RAM (GB)" Style="{StaticResource BodyTextBlockStyle}" VerticalAlignment="Center" />
                <Button x:Name="RamHelpBtn" Padding="2" MinWidth="0" MinHeight="0"
                        Background="Transparent" BorderThickness="0" Click="OnHelpClick">
                    <FontIcon Glyph="&#xE897;" FontSize="12" Opacity="0.5" />
                </Button>
                <TeachingTip x:Name="RamTip" Target="{x:Bind RamHelpBtn}"
                             Title="RAM (GB)"
                             Subtitle="System memory (RAM) to be used for the session. Slider snaps to powers of 2." />
            </StackPanel>
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <NumberBox x:Name="RamBox" Grid.Column="0"
                           SpinButtonPlacementMode="Inline" SmallChange="1" LargeChange="2"
                           Minimum="1" Width="130"
                           ValueChanged="OnRamBoxChanged" />
                <Slider x:Name="RamSlider" Grid.Column="1"
                        VerticalAlignment="Center"
                        StepFrequency="1" SnapsTo="StepValues"
                        TickPlacement="BottomRight" TickFrequency="1"
                        ValueChanged="OnRamSliderChanged" />
            </Grid>
        </StackPanel>

        <!-- GPUs -->
        <StackPanel Spacing="4">
            <StackPanel Orientation="Horizontal" Spacing="4">
                <TextBlock Text="GPUs" Style="{StaticResource BodyTextBlockStyle}" VerticalAlignment="Center" />
                <Button x:Name="GpuHelpBtn" Padding="2" MinWidth="0" MinHeight="0"
                        Background="Transparent" BorderThickness="0" Click="OnHelpClick">
                    <FontIcon Glyph="&#xE897;" FontSize="12" Opacity="0.5" />
                </Button>
                <TeachingTip x:Name="GpuTip" Target="{x:Bind GpuHelpBtn}"
                             Title="GPUs"
                             Subtitle="Number of GPUs to allocate for the session." />
            </StackPanel>
            <NumberBox x:Name="GpuBox" HorizontalAlignment="Left"
                       SpinButtonPlacementMode="Inline" SmallChange="1"
                       Minimum="0" Width="130"
                       ValueChanged="OnGpuBoxChanged" />
        </StackPanel>
    </StackPanel>
</UserControl>
