<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="CanfarDesktop.Views.Controls.BatchJobsControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Padding="16" CornerRadius="8"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1">
        <StackPanel Spacing="10">
            <TextBlock Text="Batch Jobs" Style="{StaticResource SubtitleTextBlockStyle}" />

            <Grid x:Name="StatsGrid" ColumnSpacing="12" RowSpacing="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Pending -->
                <Button x:Name="PendingButton" Grid.Row="0" Grid.Column="0"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                        Padding="8,6" Background="Transparent" BorderThickness="0"
                        Click="OnStateClick" Tag="Pending">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Ellipse Width="10" Height="10" VerticalAlignment="Center"
                                 Fill="#FFFF9800" />
                        <TextBlock x:Name="PendingCount" Style="{StaticResource BodyStrongTextBlockStyle}"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="Pending" Opacity="0.7" VerticalAlignment="Center"
                                   Style="{StaticResource CaptionTextBlockStyle}" />
                    </StackPanel>
                </Button>

                <!-- Running -->
                <Button x:Name="RunningButton" Grid.Row="0" Grid.Column="1"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                        Padding="8,6" Background="Transparent" BorderThickness="0"
                        Click="OnStateClick" Tag="Running">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Ellipse Width="10" Height="10" VerticalAlignment="Center"
                                 Fill="#FF4CAF50" />
                        <TextBlock x:Name="RunningCount" Style="{StaticResource BodyStrongTextBlockStyle}"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="Running" Opacity="0.7" VerticalAlignment="Center"
                                   Style="{StaticResource CaptionTextBlockStyle}" />
                    </StackPanel>
                </Button>

                <!-- Completed -->
                <Button x:Name="CompletedButton" Grid.Row="1" Grid.Column="0"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                        Padding="8,6" Background="Transparent" BorderThickness="0"
                        Click="OnStateClick" Tag="Succeeded">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Ellipse Width="10" Height="10" VerticalAlignment="Center"
                                 Fill="#FF2196F3" />
                        <TextBlock x:Name="CompletedCount" Style="{StaticResource BodyStrongTextBlockStyle}"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="Completed" Opacity="0.7" VerticalAlignment="Center"
                                   Style="{StaticResource CaptionTextBlockStyle}" />
                    </StackPanel>
                </Button>

                <!-- Failed -->
                <Button x:Name="FailedButton" Grid.Row="1" Grid.Column="1"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                        Padding="8,6" Background="Transparent" BorderThickness="0"
                        Click="OnStateClick" Tag="Failed">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Ellipse Width="10" Height="10" VerticalAlignment="Center"
                                 Fill="#FFF44336" />
                        <TextBlock x:Name="FailedCount" Style="{StaticResource BodyStrongTextBlockStyle}"
                                   VerticalAlignment="Center" />
                        <TextBlock Text="Failed" Opacity="0.7" VerticalAlignment="Center"
                                   Style="{StaticResource CaptionTextBlockStyle}" />
                    </StackPanel>
                </Button>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
