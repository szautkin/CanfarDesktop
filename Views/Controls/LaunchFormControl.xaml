<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="CanfarDesktop.Views.Controls.LaunchFormControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CanfarDesktop.Views.Controls"
    xmlns:converters="using:CanfarDesktop.Converters">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
    </UserControl.Resources>

    <Border Padding="16" CornerRadius="8"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1">
        <Grid RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock Grid.Row="0" Text="Launch Session" Style="{StaticResource SubtitleTextBlockStyle}" />

            <!-- Loading -->
            <ProgressBar Grid.Row="1" x:Name="LoadingBar" IsIndeterminate="True" Visibility="Collapsed" />

            <!-- Session limit warning -->
            <InfoBar Grid.Row="2" x:Name="SessionLimitBar" Severity="Warning"
                     Title="Session Limit" IsClosable="False" Visibility="Collapsed" />

            <!-- Tabs: Standard + Advanced -->
            <Pivot Grid.Row="3">
                <PivotItem Header="Standard">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,8,0,0">
                        <StackPanel Spacing="12">
                            <!-- Session Type -->
                            <StackPanel Spacing="2">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="Session Type" Style="{StaticResource BodyTextBlockStyle}" VerticalAlignment="Center" />
                                    <Button x:Name="StdTypeHelpBtn" Padding="2" MinWidth="0" MinHeight="0"
                                            Background="Transparent" BorderThickness="0" Click="OnHelpClick">
                                        <FontIcon Glyph="&#xE897;" FontSize="12" Opacity="0.5" />
                                    </Button>
                                    <TeachingTip x:Name="StdTypeTip" Target="{x:Bind StdTypeHelpBtn}"
                                                 Title="Session Type"
                                                 Subtitle="Choose a session type." />
                                </StackPanel>
                                <ComboBox x:Name="TypeCombo" HorizontalAlignment="Stretch"
                                          ItemsSource="{x:Bind ViewModel.SessionTypes}"
                                          SelectedItem="{x:Bind ViewModel.SelectedType, Mode=TwoWay}" />
                            </StackPanel>

                            <!-- Project -->
                            <StackPanel Spacing="2">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="Project" Style="{StaticResource BodyTextBlockStyle}" VerticalAlignment="Center" />
                                    <Button x:Name="StdProjectHelpBtn" Padding="2" MinWidth="0" MinHeight="0"
                                            Background="Transparent" BorderThickness="0" Click="OnHelpClick">
                                        <FontIcon Glyph="&#xE897;" FontSize="12" Opacity="0.5" />
                                    </Button>
                                    <TeachingTip x:Name="StdProjectTip" Target="{x:Bind StdProjectHelpBtn}"
                                                 Title="Project"
                                                 Subtitle="The project for which the image is used. Use the Skaha project to access the default CANFAR image list." />
                                </StackPanel>
                                <ComboBox x:Name="ProjectCombo" HorizontalAlignment="Stretch"
                                          ItemsSource="{x:Bind ViewModel.Projects}"
                                          SelectedItem="{x:Bind ViewModel.SelectedProject, Mode=TwoWay}" />
                            </StackPanel>

                            <!-- Image -->
                            <StackPanel Spacing="2">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="Container Image" Style="{StaticResource BodyTextBlockStyle}" VerticalAlignment="Center" />
                                    <Button x:Name="StdImageHelpBtn" Padding="2" MinWidth="0" MinHeight="0"
                                            Background="Transparent" BorderThickness="0" Click="OnHelpClick">
                                        <FontIcon Glyph="&#xE897;" FontSize="12" Opacity="0.5" />
                                    </Button>
                                    <TeachingTip x:Name="StdImageTip" Target="{x:Bind StdImageHelpBtn}"
                                                 Title="Container Image"
                                                 Subtitle="The Docker image for the session." />
                                </StackPanel>
                                <ComboBox x:Name="ImageCombo" HorizontalAlignment="Stretch"
                                          ItemsSource="{x:Bind ViewModel.Images}"
                                          SelectedItem="{x:Bind ViewModel.SelectedImage, Mode=TwoWay}"
                                          DisplayMemberPath="Label" />
                            </StackPanel>

                            <!-- Session Name -->
                            <StackPanel Spacing="2">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="Session Name" Style="{StaticResource BodyTextBlockStyle}" VerticalAlignment="Center" />
                                    <Button x:Name="StdNameHelpBtn" Padding="2" MinWidth="0" MinHeight="0"
                                            Background="Transparent" BorderThickness="0" Click="OnHelpClick">
                                        <FontIcon Glyph="&#xE897;" FontSize="12" Opacity="0.5" />
                                    </Button>
                                    <TeachingTip x:Name="StdNameTip" Target="{x:Bind StdNameHelpBtn}"
                                                 Title="Session Name"
                                                 Subtitle="Name for the session. Alphanumeric and '-' characters only." />
                                </StackPanel>
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0"
                                             Text="{x:Bind ViewModel.SessionName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Grid.Column="1" VerticalAlignment="Bottom" Click="OnGenerateNameClick"
                                            ToolTipService.ToolTip="Generate Name">
                                        <FontIcon Glyph="&#xE8EE;" FontSize="14" />
                                    </Button>
                                </Grid>
                            </StackPanel>

                            <!-- Resource Type -->
                            <StackPanel Spacing="2">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="Resource Type" Style="{StaticResource BodyTextBlockStyle}" VerticalAlignment="Center" />
                                    <Button x:Name="StdResTypeHelpBtn" Padding="2" MinWidth="0" MinHeight="0"
                                            Background="Transparent" BorderThickness="0" Click="OnHelpClick">
                                        <FontIcon Glyph="&#xE897;" FontSize="12" Opacity="0.5" />
                                    </Button>
                                    <TeachingTip x:Name="StdResTypeTip" Target="{x:Bind StdResTypeHelpBtn}"
                                                 Title="Resource Type"
                                                 Subtitle="Flexible: variable access to shared resources (up to 8 cores, 32 GB RAM). Fixed: guaranteed dedicated resources that may be harder to allocate." />
                                </StackPanel>
                                <RadioButtons SelectedIndex="0" SelectionChanged="OnResourceTypeChanged">
                                    <RadioButton Content="Flexible (platform-managed)" Tag="flexible" />
                                    <RadioButton Content="Fixed" Tag="fixed" />
                                </RadioButtons>
                            </StackPanel>

                            <!-- Resource options (visible when Fixed) -->
                            <local:ResourceSelectorPanel x:Name="StdResourcePanel" Visibility="Collapsed" />

                            <!-- Error -->
                            <InfoBar x:Name="StandardErrorBar" IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                                     Severity="Error" Title="Error"
                                     Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}" />

                            <!-- Launch button -->
                            <Button Style="{StaticResource AccentButtonStyle}"
                                    Click="OnLaunchClick" x:Name="LaunchButton">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE768;" FontSize="14" />
                                    <TextBlock Text="Launch" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>
                </PivotItem>

                <PivotItem Header="Advanced">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,8,0,0">
                        <StackPanel Spacing="12">
                            <!-- Session Type -->
                            <StackPanel Spacing="2">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="Session Type" Style="{StaticResource BodyTextBlockStyle}" VerticalAlignment="Center" />
                                    <Button x:Name="AdvTypeHelpBtn" Padding="2" MinWidth="0" MinHeight="0"
                                            Background="Transparent" BorderThickness="0" Click="OnHelpClick">
                                        <FontIcon Glyph="&#xE897;" FontSize="12" Opacity="0.5" />
                                    </Button>
                                    <TeachingTip x:Name="AdvTypeTip" Target="{x:Bind AdvTypeHelpBtn}"
                                                 Title="Session Type"
                                                 Subtitle="Choose a session type." />
                                </StackPanel>
                                <ComboBox HorizontalAlignment="Stretch"
                                          ItemsSource="{x:Bind ViewModel.SessionTypes}"
                                          SelectedItem="{x:Bind ViewModel.SelectedType, Mode=TwoWay}" />
                            </StackPanel>

                            <!-- Container Image: Host + Image in one row -->
                            <StackPanel Spacing="2">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="Container Image" Style="{StaticResource BodyTextBlockStyle}" VerticalAlignment="Center" />
                                    <Button x:Name="AdvImageHelpBtn" Padding="2" MinWidth="0" MinHeight="0"
                                            Background="Transparent" BorderThickness="0" Click="OnHelpClick">
                                        <FontIcon Glyph="&#xE897;" FontSize="12" Opacity="0.5" />
                                    </Button>
                                    <TeachingTip x:Name="AdvImageTip" Target="{x:Bind AdvImageHelpBtn}"
                                                 Title="Container Image"
                                                 Subtitle="Select the image registry containing your container images, then provide the project/name:tag." />
                                </StackPanel>
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" MinWidth="180" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <ComboBox Grid.Column="0" x:Name="RegistryHostCombo"
                                              HorizontalAlignment="Stretch" SelectedIndex="0">
                                        <x:String>images.canfar.net</x:String>
                                        <x:String>harbor.canfar.net</x:String>
                                        <x:String>ghcr.io</x:String>
                                        <x:String>docker.io</x:String>
                                    </ComboBox>
                                    <TextBox Grid.Column="1" x:Name="CustomImageBox"
                                             PlaceholderText="project/example-image:1.0.0"
                                             Text="{x:Bind ViewModel.CustomImageUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>
                            </StackPanel>

                            <!-- Registry Auth: Username + Secret in one row -->
                            <StackPanel Spacing="2">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="Registry Auth" Style="{StaticResource BodyTextBlockStyle}" VerticalAlignment="Center" />
                                    <Button x:Name="AdvAuthHelpBtn" Padding="2" MinWidth="0" MinHeight="0"
                                            Background="Transparent" BorderThickness="0" Click="OnHelpClick">
                                        <FontIcon Glyph="&#xE897;" FontSize="12" Opacity="0.5" />
                                    </Button>
                                    <TeachingTip x:Name="AdvAuthTip" Target="{x:Bind AdvAuthHelpBtn}"
                                                 Title="Registry Authentication"
                                                 Subtitle="Credentials for pulling images from a private registry. Leave blank for public images." />
                                </StackPanel>
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" x:Name="RepoUsernameBox"
                                             PlaceholderText="username"
                                             Text="{x:Bind ViewModel.RepositoryUsername, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <PasswordBox Grid.Column="1" x:Name="RepoSecretBox"
                                                 PlaceholderText="token or password" />
                                </Grid>
                            </StackPanel>

                            <!-- Session Name -->
                            <StackPanel Spacing="2">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="Session Name" Style="{StaticResource BodyTextBlockStyle}" VerticalAlignment="Center" />
                                    <Button x:Name="AdvNameHelpBtn" Padding="2" MinWidth="0" MinHeight="0"
                                            Background="Transparent" BorderThickness="0" Click="OnHelpClick">
                                        <FontIcon Glyph="&#xE897;" FontSize="12" Opacity="0.5" />
                                    </Button>
                                    <TeachingTip x:Name="AdvNameTip" Target="{x:Bind AdvNameHelpBtn}"
                                                 Title="Session Name"
                                                 Subtitle="Name for the session. Alphanumeric and '-' characters only." />
                                </StackPanel>
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0"
                                             Text="{x:Bind ViewModel.SessionName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Grid.Column="1" VerticalAlignment="Bottom" Click="OnGenerateNameClick"
                                            ToolTipService.ToolTip="Generate Name">
                                        <FontIcon Glyph="&#xE8EE;" FontSize="14" />
                                    </Button>
                                </Grid>
                            </StackPanel>

                            <!-- Resource Type -->
                            <StackPanel Spacing="2">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock Text="Resource Type" Style="{StaticResource BodyTextBlockStyle}" VerticalAlignment="Center" />
                                    <Button x:Name="AdvResTypeHelpBtn" Padding="2" MinWidth="0" MinHeight="0"
                                            Background="Transparent" BorderThickness="0" Click="OnHelpClick">
                                        <FontIcon Glyph="&#xE897;" FontSize="12" Opacity="0.5" />
                                    </Button>
                                    <TeachingTip x:Name="AdvResTypeTip" Target="{x:Bind AdvResTypeHelpBtn}"
                                                 Title="Resource Type"
                                                 Subtitle="Flexible: variable access to shared resources (up to 8 cores, 32 GB RAM). Fixed: guaranteed dedicated resources that may be harder to allocate." />
                                </StackPanel>
                                <RadioButtons SelectedIndex="0" SelectionChanged="OnAdvancedResourceTypeChanged">
                                    <RadioButton Content="Flexible (platform-managed)" Tag="flexible" />
                                    <RadioButton Content="Fixed" Tag="fixed" />
                                </RadioButtons>
                            </StackPanel>

                            <!-- Resource options -->
                            <local:ResourceSelectorPanel x:Name="AdvResourcePanel" Visibility="Collapsed" />

                            <!-- Error -->
                            <InfoBar x:Name="AdvancedErrorBar" IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                                     Severity="Error" Title="Error"
                                     Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}" />

                            <!-- Launch button -->
                            <Button Style="{StaticResource AccentButtonStyle}"
                                    Click="OnAdvancedLaunchClick" x:Name="AdvancedLaunchButton">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE768;" FontSize="14" />
                                    <TextBlock Text="Launch (Custom Image)" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </ScrollViewer>
                </PivotItem>
            </Pivot>
        </Grid>
    </Border>
</UserControl>
