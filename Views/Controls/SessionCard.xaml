<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="CanfarDesktop.Views.Controls.SessionCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Padding="14" CornerRadius="8" Width="380"
            HorizontalAlignment="Left"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1">
        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Left: Type image -->
            <Border Grid.Column="0" CornerRadius="6" Width="48" Height="48"
                    VerticalAlignment="Top" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                <Image x:Name="TypeImage" Width="36" Height="36"
                       HorizontalAlignment="Center" VerticalAlignment="Center" Stretch="Uniform" />
            </Border>

            <!-- Right: All info -->
            <Grid Grid.Column="1" RowSpacing="6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Row 0: Name + Status -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" x:Name="NameText" Style="{StaticResource BodyStrongTextBlockStyle}"
                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                    <Border Grid.Column="1" x:Name="StatusBadge" CornerRadius="10" Padding="8,2">
                        <TextBlock x:Name="StatusText" Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorInverseBrush}" />
                    </Border>
                </Grid>

                <!-- Row 1: Type label -->
                <Border Grid.Row="1" x:Name="TypeBadge" CornerRadius="4" Padding="6,1" HorizontalAlignment="Left">
                    <TextBlock x:Name="TypeText" Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorInverseBrush}" FontSize="11" />
                </Border>

                <!-- Row 2: Image name -->
                <TextBlock Grid.Row="2" x:Name="ImageText" Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis" />

                <!-- Row 3: Times + Resources -->
                <Grid Grid.Row="3" ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Spacing="2">
                        <TextBlock x:Name="StartText" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="11" />
                        <TextBlock x:Name="ExpiryText" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="11" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="2">
                        <TextBlock x:Name="CpuText" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="11" />
                        <TextBlock x:Name="RamText" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="11" />
                    </StackPanel>
                </Grid>

                <!-- Row 4: Action buttons -->
                <StackPanel Grid.Row="4" Orientation="Horizontal" Spacing="4" HorizontalAlignment="Right">
                    <Button x:Name="OpenButton" ToolTipService.ToolTip="Open in Browser" Click="OnOpenClick" Padding="6,4">
                        <FontIcon Glyph="&#xE8A7;" FontSize="13" />
                    </Button>
                    <Button x:Name="RenewButton" ToolTipService.ToolTip="Extend Time" Click="OnRenewClick" Padding="6,4">
                        <FontIcon Glyph="&#xE823;" FontSize="13" />
                    </Button>
                    <Button x:Name="EventsButton" ToolTipService.ToolTip="View Events" Click="OnEventsClick" Padding="6,4">
                        <FontIcon Glyph="&#xE7C1;" FontSize="13" />
                    </Button>
                    <Button x:Name="DeleteButton" ToolTipService.ToolTip="Delete" Click="OnDeleteClick" Padding="6,4">
                        <FontIcon Glyph="&#xE74D;" FontSize="13" Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</UserControl>
