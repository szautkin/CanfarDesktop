<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="CanfarDesktop.Views.LandingView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
        <StackPanel Spacing="32" HorizontalAlignment="Center">

            <!-- Branding -->
            <StackPanel Spacing="12" HorizontalAlignment="Center">
                <Image Source="Assets/Verbinal_icon.png" Width="80" Height="80" HorizontalAlignment="Center" />
                <TextBlock Text="Verbinal" Style="{StaticResource TitleLargeTextBlockStyle}"
                           HorizontalAlignment="Center" FontWeight="Bold" />
                <TextBlock x:Uid="Landing_Subtitle" Text="A CANFAR Science Portal and Research Platform"
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           HorizontalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <!-- Tiles: 3 columns × 2 rows -->
            <ItemsRepeater x:Name="TilesRepeater" HorizontalAlignment="Center">
                <ItemsRepeater.Layout>
                    <UniformGridLayout Orientation="Horizontal"
                                       MinItemWidth="170" MinItemHeight="160"
                                       MinColumnSpacing="20" MinRowSpacing="20"
                                       MaximumRowsOrColumns="3" />
                </ItemsRepeater.Layout>
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate>
                        <Button Width="170" Height="160" Padding="0"
                                HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch"
                                CornerRadius="8"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Tag="{Binding Key}"
                                Click="OnTileClicked"
                                AutomationProperties.Name="{Binding Title}"
                                ToolTipService.ToolTip="{Binding ToolTip}">
                            <Grid>
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="14"
                                            Opacity="{Binding TileOpacity}">
                                    <FontIcon Glyph="{Binding Glyph}" FontSize="44" HorizontalAlignment="Center"
                                              Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                                    <StackPanel Spacing="4" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding Title}" Style="{StaticResource SubtitleTextBlockStyle}"
                                                   FontWeight="Bold" HorizontalAlignment="Center" />
                                        <TextBlock Text="{Binding Subtitle}"
                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   HorizontalAlignment="Center" />
                                    </StackPanel>
                                </StackPanel>
                                <!-- Auth-gate badge: top-right lock while signed out (macOS parity) -->
                                <FontIcon Glyph="&#xE72E;" FontSize="12"
                                          HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,10,10,0"
                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                          Visibility="{Binding LockVisibility}" />
                            </Grid>
                        </Button>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>

            <!-- Status -->
            <TextBlock x:Name="StatusText" HorizontalAlignment="Center"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
        </StackPanel>
    </Grid>
</UserControl>
