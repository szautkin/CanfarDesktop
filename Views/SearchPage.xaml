<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CanfarDesktop.Views.SearchPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:CanfarDesktop.Converters"
    xmlns:controls="using:CanfarDesktop.Views.Controls"
    >

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
    </Page.Resources>

    <Grid Padding="24" ColumnSpacing="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="260" />
        </Grid.ColumnDefinitions>

        <!-- Main content -->
        <Grid Grid.Column="0" RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" x:Uid="Search_Title" Text="CADC Archive Search" Style="{StaticResource TitleTextBlockStyle}" />

            <Pivot Grid.Row="1" x:Name="MainPivot">
                <!-- SEARCH FORM -->
                <PivotItem x:Uid="Search_FormPivot" Header="Search Form">
                    <Grid RowSpacing="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="0,8,0,0">
                        <StackPanel Spacing="12">
                            <!-- 4 constraint columns side-by-side (matches CADC web) -->
                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- Col 1: Observation -->
                                <StackPanel Grid.Column="0" Spacing="8">
                                    <TextBlock x:Uid="Search_ObservationSection" Text="Observation" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <TextBox x:Uid="Search_ObservationIdBox" Header="Observation ID" PlaceholderText="e.g. jw01345*"
                                             Text="{x:Bind ViewModel.ObservationId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox x:Uid="Search_PiNameBox" Header="PI Name" PlaceholderText="e.g. Smith"
                                             Text="{x:Bind ViewModel.ProposalPi, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox x:Uid="Search_ProposalIdBox" Header="Proposal ID"
                                             Text="{x:Bind ViewModel.ProposalId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox x:Uid="Search_ProposalTitleBox" Header="Proposal Title"
                                             Text="{x:Bind ViewModel.ProposalTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox x:Uid="Search_KeywordsBox" Header="Keywords"
                                             Text="{x:Bind ViewModel.ProposalKeywords, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox x:Uid="Search_DataReleaseBox" Header="Data Release" PlaceholderText="e.g. > 2023-01-01"
                                             Text="{x:Bind ViewModel.DataRelease, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <CheckBox x:Uid="Search_PublicOnlyCheck" Content="Public only" IsChecked="{x:Bind ViewModel.PublicOnly, Mode=TwoWay}" />
                                    <ComboBox x:Uid="Search_IntentCombo" Header="Intent" HorizontalAlignment="Stretch"
                                              SelectedItem="{x:Bind ViewModel.Intent, Mode=TwoWay}">
                                        <x:String></x:String>
                                        <x:String>science</x:String>
                                        <x:String>calibration</x:String>
                                    </ComboBox>
                                </StackPanel>

                                <!-- Col 2: Spatial -->
                                <StackPanel Grid.Column="1" Spacing="8">
                                    <TextBlock x:Uid="Search_SpatialSection" Text="Spatial" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <TextBox x:Uid="Search_TargetBox" Header="Target or Coordinates" PlaceholderText="e.g. M31, NGC 1234"
                                             Text="{x:Bind ViewModel.Target, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <ComboBox x:Uid="Search_ResolverCombo" Header="Resolver" HorizontalAlignment="Stretch"
                                              ItemsSource="{x:Bind ViewModel.ResolverServices}"
                                              SelectedItem="{x:Bind ViewModel.ResolverService, Mode=TwoWay}" />
                                    <!-- Resolver status -->
                                    <Border Padding="8,6" CornerRadius="4"
                                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                            Visibility="{x:Bind ViewModel.IsResolving, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <ProgressRing IsActive="True" Width="14" Height="14" />
                                            <TextBlock x:Uid="Search_ResolvingText" Text="Resolving..." Style="{StaticResource CaptionTextBlockStyle}" />
                                        </StackPanel>
                                    </Border>
                                    <TextBlock x:Name="ResolverStatusText" Text="{x:Bind ViewModel.ResolverStatus, Mode=OneWay}"
                                               Style="{StaticResource CaptionTextBlockStyle}" Opacity="0.7" TextWrapping="Wrap" />
                                    <NumberBox x:Uid="Search_RadiusBox" Header="Radius (deg)" Value="{x:Bind ViewModel.SearchRadius, Mode=TwoWay}"
                                               Minimum="0" SmallChange="0.01" SpinButtonPlacementMode="Compact" />
                                    <Grid ColumnSpacing="4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" x:Uid="Search_PixelScaleBox" Header="Pixel Scale" PlaceholderText="e.g. 0.1..1.0"
                                                 Text="{x:Bind ViewModel.PixelScale, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <ComboBox Grid.Column="1" Width="90" VerticalAlignment="Bottom"
                                                  ItemsSource="{x:Bind PixelScaleUnits}"
                                                  SelectedItem="{x:Bind ViewModel.PixelScaleUnit, Mode=TwoWay}" />
                                    </Grid>
                                    <CheckBox x:Uid="Search_SpatialCutoutCheck" Content="Spatial cutout" IsChecked="{x:Bind ViewModel.SpatialCutout, Mode=TwoWay}" />
                                </StackPanel>

                                <!-- Col 3: Temporal -->
                                <StackPanel Grid.Column="2" Spacing="8">
                                    <TextBlock x:Uid="Search_TemporalSection" Text="Temporal" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <Grid ColumnSpacing="4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" x:Uid="Search_ObsDateBox" Header="Observation Date" PlaceholderText="e.g. 2020..2021"
                                                 Text="{x:Bind ViewModel.ObservationDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <ComboBox Grid.Column="1" Width="110" VerticalAlignment="Bottom"
                                                  SelectedItem="{x:Bind ViewModel.DatePreset, Mode=TwoWay}">
                                            <x:String></x:String>
                                            <x:String>Last24h</x:String>
                                            <x:String>LastWeek</x:String>
                                            <x:String>LastMonth</x:String>
                                        </ComboBox>
                                    </Grid>
                                    <Grid ColumnSpacing="4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" x:Uid="Search_IntegrationTimeBox" Header="Integration Time" PlaceholderText="e.g. 100..3600"
                                                 Text="{x:Bind ViewModel.IntegrationTimeMin, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <ComboBox Grid.Column="1" Width="60" VerticalAlignment="Bottom"
                                                  ItemsSource="{x:Bind TimeUnits}"
                                                  SelectedItem="{x:Bind ViewModel.IntegrationTimeUnit, Mode=TwoWay}" />
                                    </Grid>
                                    <Grid ColumnSpacing="4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" x:Uid="Search_TimeSpanBox" Header="Time Span" PlaceholderText="e.g. 1..10"
                                                 Text="{x:Bind ViewModel.TimeSpan, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <ComboBox Grid.Column="1" Width="60" VerticalAlignment="Bottom"
                                                  ItemsSource="{x:Bind TimeUnits}"
                                                  SelectedItem="{x:Bind ViewModel.TimeSpanUnit, Mode=TwoWay}" />
                                    </Grid>
                                </StackPanel>

                                <!-- Col 4: Spectral -->
                                <StackPanel Grid.Column="3" Spacing="8">
                                    <TextBlock x:Uid="Search_SpectralSection" Text="Spectral" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <Grid ColumnSpacing="4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" x:Uid="Search_SpectralCoverageBox" Header="Spectral Coverage" PlaceholderText="e.g. 400..700"
                                                 Text="{x:Bind ViewModel.SpectralCoverage, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <ComboBox Grid.Column="1" Width="80" VerticalAlignment="Bottom"
                                                  ItemsSource="{x:Bind SpectralUnits}"
                                                  SelectedItem="{x:Bind ViewModel.SpectralCoverageUnit, Mode=TwoWay}" />
                                    </Grid>
                                    <Grid ColumnSpacing="4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" x:Uid="Search_SpectralSamplingBox" Header="Spectral Sampling"
                                                 Text="{x:Bind ViewModel.SpectralSampling, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <ComboBox Grid.Column="1" Width="80" VerticalAlignment="Bottom"
                                                  ItemsSource="{x:Bind SpectralUnits}"
                                                  SelectedItem="{x:Bind ViewModel.SpectralSamplingUnit, Mode=TwoWay}" />
                                    </Grid>
                                    <TextBox x:Uid="Search_ResolvingPowerBox" Header="Resolving Power" PlaceholderText="e.g. 1000..5000"
                                             Text="{x:Bind ViewModel.ResolvingPower, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <Grid ColumnSpacing="4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" x:Uid="Search_BandpassWidthBox" Header="Bandpass Width"
                                                 Text="{x:Bind ViewModel.BandpassWidth, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <ComboBox Grid.Column="1" Width="80" VerticalAlignment="Bottom"
                                                  ItemsSource="{x:Bind SpectralUnits}"
                                                  SelectedItem="{x:Bind ViewModel.BandpassWidthUnit, Mode=TwoWay}" />
                                    </Grid>
                                    <Grid ColumnSpacing="4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0" x:Uid="Search_RestFrameEnergyBox" Header="Rest Frame Energy"
                                                 Text="{x:Bind ViewModel.RestFrameEnergy, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <ComboBox Grid.Column="1" Width="80" VerticalAlignment="Bottom"
                                                  ItemsSource="{x:Bind SpectralUnits}"
                                                  SelectedItem="{x:Bind ViewModel.RestFrameEnergyUnit, Mode=TwoWay}" />
                                    </Grid>
                                    <CheckBox x:Uid="Search_SpectralCutoutCheck" Content="Spectral cutout" IsChecked="{x:Bind ViewModel.SpectralCutout, Mode=TwoWay}" />
                                </StackPanel>
                            </Grid>

                            <!-- Data Train (below the 4 columns) — lazy loaded on expand -->
                            <Expander x:Name="ConstraintsExpander" x:Uid="Search_ConstraintsExpander" Header="Additional Constraints" IsExpanded="False"
                                      HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                                <StackPanel Spacing="8">
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0"><TextBlock x:Uid="Search_TrainBandLabel" Text="Band" Style="{StaticResource CaptionTextBlockStyle}" Margin="0,0,0,2" />
                                            <ListView x:Name="BandList" MaxHeight="180" SelectionMode="Multiple" SelectionChanged="OnTrainSelectionChanged" Tag="0" /></StackPanel>
                                        <StackPanel Grid.Column="1"><TextBlock x:Uid="Search_TrainCollectionLabel" Text="Collection" Style="{StaticResource CaptionTextBlockStyle}" Margin="0,0,0,2" />
                                            <ListView x:Name="CollectionList" MaxHeight="180" SelectionMode="Multiple" SelectionChanged="OnTrainSelectionChanged" Tag="1" /></StackPanel>
                                        <StackPanel Grid.Column="2"><TextBlock x:Uid="Search_TrainInstrumentLabel" Text="Instrument" Style="{StaticResource CaptionTextBlockStyle}" Margin="0,0,0,2" />
                                            <ListView x:Name="InstrumentList" MaxHeight="180" SelectionMode="Multiple" SelectionChanged="OnTrainSelectionChanged" Tag="2" /></StackPanel>
                                        <StackPanel Grid.Column="3"><TextBlock x:Uid="Search_TrainFilterLabel" Text="Filter" Style="{StaticResource CaptionTextBlockStyle}" Margin="0,0,0,2" />
                                            <ListView x:Name="FilterList" MaxHeight="180" SelectionMode="Multiple" SelectionChanged="OnTrainSelectionChanged" Tag="3" /></StackPanel>
                                        <StackPanel Grid.Column="4"><TextBlock x:Uid="Search_TrainCalLevelLabel" Text="Cal. Level" Style="{StaticResource CaptionTextBlockStyle}" Margin="0,0,0,2" />
                                            <ListView x:Name="CalLevelList" MaxHeight="180" SelectionMode="Multiple" SelectionChanged="OnTrainSelectionChanged" Tag="4" /></StackPanel>
                                        <StackPanel Grid.Column="5"><TextBlock x:Uid="Search_TrainDataTypeLabel" Text="Data Type" Style="{StaticResource CaptionTextBlockStyle}" Margin="0,0,0,2" />
                                            <ListView x:Name="DataTypeList" MaxHeight="180" SelectionMode="Multiple" SelectionChanged="OnTrainSelectionChanged" Tag="5" /></StackPanel>
                                        <StackPanel Grid.Column="6"><TextBlock x:Uid="Search_TrainObsTypeLabel" Text="Obs. Type" Style="{StaticResource CaptionTextBlockStyle}" Margin="0,0,0,2" />
                                            <ListView x:Name="ObsTypeList" MaxHeight="180" SelectionMode="Multiple" SelectionChanged="OnTrainSelectionChanged" Tag="6" /></StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Expander>

                        </StackPanel>
                    </ScrollViewer>

                    <!-- Pinned action bar — outside the scroll area -->
                    <Grid Grid.Row="1" RowSpacing="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Height="1" Margin="0,8,0,12"
                                Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                        <Grid Grid.Row="1" ColumnSpacing="12" Padding="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" x:Name="SearchButton" Style="{StaticResource AccentButtonStyle}" Click="OnSearchClick">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE721;" FontSize="14" />
                                    <TextBlock x:Uid="Search_SearchButtonText" Text="Search" />
                                </StackPanel>
                            </Button>
                            <Button Grid.Column="1" x:Uid="Search_ResetButton" Click="OnClearClick" Content="Reset" />
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Bottom">
                                <TextBlock x:Uid="Search_MaxRecordsLabel" Text="Max Records" VerticalAlignment="Center"
                                           Style="{StaticResource CaptionTextBlockStyle}" />
                                <NumberBox Width="100" Value="{x:Bind ViewModel.MaxRecords, Mode=TwoWay}"
                                           Minimum="1" Maximum="30000" SpinButtonPlacementMode="Compact" />
                            </StackPanel>
                            <ProgressRing Grid.Column="3" IsActive="{x:Bind ViewModel.IsSearching, Mode=OneWay}"
                                          Width="24" Height="24" VerticalAlignment="Bottom" />
                        </Grid>

                        <InfoBar Grid.Row="2" x:Uid="Search_ErrorBar"
                                 IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}" Severity="Error"
                                 Title="Error" Message="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}" />
                    </Grid>

                    </Grid>
                </PivotItem>

                <!-- RESULTS -->
                <PivotItem x:Uid="Search_ResultsPivot" Header="Results">
                    <Grid RowSpacing="0" Padding="0,8,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Toolbar -->
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="0,0,0,8">
                            <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                                       Style="{StaticResource BodyTextBlockStyle}" VerticalAlignment="Center" />
                            <Button x:Uid="Search_ColumnsButton" Click="OnColumnsClick" Content="Columns" Padding="8,4" />
                            <Button Click="OnExportCsvClick" Content="CSV" Padding="8,4" />
                            <Button Click="OnExportTsvClick" Content="TSV" Padding="8,4" />
                            <Button x:Name="ApplyFiltersBtn" x:Uid="Search_ApplyFiltersBtn" Click="OnApplyFiltersToAdql" Padding="8,4"
                                    Visibility="Collapsed" ToolTipService.ToolTip="Convert active filters to ADQL query">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE71C;" FontSize="12" />
                                    <TextBlock x:Uid="Search_ApplyFiltersText" Text="Apply to ADQL" />
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <!-- Sticky header (pinned, never scrolls vertically) -->
                        <ScrollViewer Grid.Row="1" x:Name="HeaderScroll"
                                      HorizontalScrollBarVisibility="Hidden"
                                      VerticalScrollBarVisibility="Disabled">
                            <StackPanel x:Name="HeaderPanel" Spacing="0" />
                        </ScrollViewer>

                        <!-- Data rows (scrolls independently) -->
                        <ScrollViewer Grid.Row="2" x:Name="DataScroll"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Auto"
                                      ViewChanged="OnDataScrollViewChanged">
                            <StackPanel x:Name="ResultsPanel" Spacing="0" />
                        </ScrollViewer>

                        <!-- Pagination -->
                        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="12"
                                    Padding="0,8" VerticalAlignment="Center">
                            <TextBlock x:Name="PageStatusText" VerticalAlignment="Center"
                                       Style="{StaticResource CaptionTextBlockStyle}" />
                            <Button x:Uid="Search_FirstPageBtn" Click="OnFirstPage" Padding="8,4" ToolTipService.ToolTip="First page">
                                <FontIcon Glyph="&#xEB9E;" FontSize="12" />
                            </Button>
                            <Button x:Uid="Search_PrevPageBtn" Click="OnPrevPage" Padding="8,4" ToolTipService.ToolTip="Previous page">
                                <FontIcon Glyph="&#xE76B;" FontSize="12" />
                            </Button>
                            <TextBlock x:Name="PageNumberText" VerticalAlignment="Center"
                                       Style="{StaticResource BodyTextBlockStyle}" Margin="4,0" />
                            <Button x:Uid="Search_NextPageBtn" Click="OnNextPage" Padding="8,4" ToolTipService.ToolTip="Next page">
                                <FontIcon Glyph="&#xE76C;" FontSize="12" />
                            </Button>
                            <Button x:Uid="Search_LastPageBtn" Click="OnLastPage" Padding="8,4" ToolTipService.ToolTip="Last page">
                                <FontIcon Glyph="&#xEB9D;" FontSize="12" />
                            </Button>
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <TextBlock x:Uid="Search_RowsPerPageLabel" Text="Rows per page" VerticalAlignment="Center"
                                           Style="{StaticResource CaptionTextBlockStyle}" />
                                <ComboBox x:Name="RowsPerPageCombo" Width="80"
                                          ItemsSource="{x:Bind ViewModel.RowsPerPageOptions}"
                                          SelectionChanged="OnRowsPerPageChanged" />
                            </StackPanel>
                        </StackPanel>
                        <!-- Download progress — overlaid on the bottom of the results list so
                             showing/hiding it never reflows the rows underneath. -->
                        <InfoBar x:Name="DownloadInfoBar" Grid.Row="2"
                                 VerticalAlignment="Bottom" Canvas.ZIndex="10"
                                 IsOpen="False" IsClosable="True"
                                 Severity="Informational" Title="Downloading..."
                                 Margin="0,4,0,0">
                            <InfoBar.Content>
                                <StackPanel Spacing="4">
                                    <ProgressBar x:Name="DownloadProgressBar" Minimum="0" Maximum="100" />
                                    <TextBlock x:Name="DownloadProgressText"
                                               Style="{StaticResource CaptionTextBlockStyle}" />
                                </StackPanel>
                            </InfoBar.Content>
                        </InfoBar>
                    </Grid>
                </PivotItem>

                <!-- ADQL EDITOR -->
                <PivotItem x:Uid="Search_AdqlPivot" Header="ADQL Editor">
                    <Grid RowSpacing="8" Padding="0,8,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBox Grid.Row="0" x:Uid="Search_AdqlBox" AcceptsReturn="True" TextWrapping="Wrap" FontFamily="Consolas" FontSize="13"
                                 Text="{x:Bind ViewModel.AdqlText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 PlaceholderText="Enter ADQL query..." />
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
                            <Button x:Name="ExecuteAdqlButton" Style="{StaticResource AccentButtonStyle}" Click="OnExecuteAdqlClick">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE768;" FontSize="14" />
                                    <TextBlock x:Uid="Search_ExecuteButtonText" Text="Execute" />
                                </StackPanel>
                            </Button>
                            <ProgressRing IsActive="{x:Bind ViewModel.IsSearching, Mode=OneWay}" Width="20" Height="20" />
                        </StackPanel>
                    </Grid>
                </PivotItem>
            </Pivot>
        </Grid>

        <!-- Side panel -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="12">

                <!-- Recent Searches -->
                <Border Padding="12" CornerRadius="8"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <Grid RowSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
                            <TextBlock x:Uid="Search_RecentHeader" Text="Recent Searches" Style="{StaticResource BodyStrongTextBlockStyle}" VerticalAlignment="Center" />
                            <Button x:Uid="Search_ClearAllButton" Content="Clear All" Click="OnClearRecentSearches" Padding="6,2"
                                    FontSize="11" VerticalAlignment="Center" />
                        </StackPanel>
                        <ListView Grid.Row="1" x:Name="RecentSearchList" SelectionMode="None" MaxHeight="280"
                                  ItemsSource="{x:Bind ViewModel.RecentSearches}">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="2,4" ColumnSpacing="4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Summary}" TextTrimming="CharacterEllipsis"
                                                       Style="{StaticResource CaptionTextBlockStyle}" />
                                            <TextBlock Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                       Style="{StaticResource CaptionTextBlockStyle}">
                                                <Run Text="{Binding ResultCount}" /><Run Text=" " /><Run x:Uid="Search_ResultsSuffix" Text="results" />
                                            </TextBlock>
                                        </StackPanel>
                                        <Button Grid.Column="1" x:Uid="Search_LoadRecentBtn" Click="OnLoadRecentSearch" Tag="{Binding}"
                                                Padding="8" ToolTipService.ToolTip="Load into form"
                                                AutomationProperties.Name="Load into search form">
                                            <FontIcon Glyph="&#xE8A5;" FontSize="12" />
                                        </Button>
                                        <Button Grid.Column="2" x:Uid="Search_RemoveRecentBtn" Click="OnRemoveRecentSearch" Tag="{Binding}"
                                                Padding="8" ToolTipService.ToolTip="Remove"
                                                AutomationProperties.Name="Remove from history">
                                            <FontIcon Glyph="&#xE74D;" FontSize="12" />
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>

                <!-- Saved Queries -->
                <Border Padding="12" CornerRadius="8"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <Grid RowSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" x:Uid="Search_SavedHeader" Text="Saved Queries" Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <Grid Grid.Row="1" ColumnSpacing="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" x:Name="SaveQueryName" x:Uid="Search_SaveQueryNameBox" PlaceholderText="Name (optional)" />
                            <Button Grid.Column="1" x:Uid="Search_SaveQueryBtn" Click="OnSaveQuery" ToolTipService.ToolTip="Save current ADQL" Padding="8">
                                <FontIcon Glyph="&#xE74E;" FontSize="14" />
                            </Button>
                        </Grid>
                        <ListView Grid.Row="2" ItemsSource="{x:Bind ViewModel.SavedQueries}" SelectionMode="None" MaxHeight="240">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Padding="2,4" ColumnSpacing="4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <TextBlock Text="{Binding Name}" Style="{StaticResource CaptionTextBlockStyle}"
                                                           VerticalAlignment="Center" />
                                                <controls:AgentBadge Attribution="{Binding AgentAttribution}" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding Adql}" MaxLines="2" TextTrimming="CharacterEllipsis"
                                                       FontFamily="Consolas" Style="{StaticResource CaptionTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                        </StackPanel>
                                        <Button Grid.Column="1" x:Uid="Search_RunSavedBtn" Click="OnRunSavedQuery" Tag="{Binding}"
                                                Padding="8" ToolTipService.ToolTip="Run query"
                                                AutomationProperties.Name="Run query">
                                            <FontIcon Glyph="&#xE768;" FontSize="12" />
                                        </Button>
                                        <Button Grid.Column="2" x:Uid="Search_LoadSavedBtn" Click="OnLoadSavedQuery" Tag="{Binding}"
                                                Padding="8" ToolTipService.ToolTip="Load into ADQL editor"
                                                AutomationProperties.Name="Load into ADQL editor">
                                            <FontIcon Glyph="&#xE8DA;" FontSize="12" />
                                        </Button>
                                        <Button Grid.Column="3" x:Uid="Search_DeleteSavedBtn" Click="OnDeleteSavedQuery" Tag="{Binding}"
                                                Padding="8" ToolTipService.ToolTip="Delete"
                                                AutomationProperties.Name="Delete saved query">
                                            <FontIcon Glyph="&#xE74D;" FontSize="12" />
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        <!-- Run status -->
                        <StackPanel Grid.Row="3" x:Name="QueryRunStatus" Orientation="Horizontal"
                                    Spacing="8" Visibility="Collapsed">
                            <ProgressRing IsActive="True" Width="16" Height="16" />
                            <TextBlock x:Name="QueryRunStatusText"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
