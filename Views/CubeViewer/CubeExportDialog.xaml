<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="CanfarDesktop.Views.CubeViewer.CubeExportDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Export figure"
    CloseButtonText="Close"
    DefaultButton="Close">

    <ContentDialog.Resources>
        <x:Double x:Key="ContentDialogMaxWidth">1280</x:Double>
        <x:Double x:Key="ContentDialogMaxHeight">920</x:Double>
    </ContentDialog.Resources>

    <Grid Width="1000" Height="600" ColumnSpacing="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="264" />
        </Grid.ColumnDefinitions>

        <!-- Off-screen host: a fresh plate is rasterized here at full natural size for export
             (the preview plate is scaled down inside a Viewbox, which would soften the text). -->
        <Canvas x:Name="RasterHost" Grid.ColumnSpan="2" IsHitTestVisible="False" />

        <!-- Live WYSIWYG preview of the figure plate -->
        <Border Grid.Column="0" CornerRadius="6" Padding="14"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="1"
                Background="{ThemeResource LayerFillColorDefaultBrush}">
            <Viewbox x:Name="PreviewBox" Stretch="Uniform" StretchDirection="DownOnly" />
        </Border>

        <!-- Style controls -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollMode="Disabled">
            <StackPanel Spacing="12">

                <StackPanel Spacing="2">
                    <TextBlock Text="Theme" Style="{StaticResource CaptionTextBlockStyle}" />
                    <ComboBox x:Name="ThemeCombo" HorizontalAlignment="Stretch" SelectionChanged="OnStyleChanged">
                        <ComboBoxItem Content="Cockpit dark" />
                        <ComboBoxItem Content="Journal light" />
                    </ComboBox>
                </StackPanel>

                <StackPanel Spacing="2">
                    <TextBlock Text="Font" Style="{StaticResource CaptionTextBlockStyle}" />
                    <ComboBox x:Name="FontCombo" HorizontalAlignment="Stretch" SelectionChanged="OnStyleChanged">
                        <ComboBoxItem Content="Sans" />
                        <ComboBoxItem Content="Mono" />
                        <ComboBoxItem Content="Serif" />
                    </ComboBox>
                </StackPanel>

                <StackPanel Spacing="2">
                    <TextBlock Text="Text color" Style="{StaticResource CaptionTextBlockStyle}" />
                    <ComboBox x:Name="TextColorCombo" HorizontalAlignment="Stretch" SelectionChanged="OnStyleChanged">
                        <ComboBoxItem Content="Auto" />
                        <ComboBoxItem Content="White" />
                        <ComboBoxItem Content="Black" />
                        <ComboBoxItem Content="Cyan" />
                        <ComboBoxItem Content="Amber" />
                    </ComboBox>
                </StackPanel>

                <StackPanel Spacing="2">
                    <TextBlock x:Name="ScaleLabel" Text="Text scale 1.00×" Style="{StaticResource CaptionTextBlockStyle}" />
                    <Slider x:Name="ScaleSlider" Minimum="0.75" Maximum="1.5" StepFrequency="0.05" Value="1.0"
                            ValueChanged="OnScaleChanged" />
                </StackPanel>

                <ToggleSwitch x:Name="AnnotateToggle" Header="Annotations" IsOn="True"
                              OffContent="Off" OnContent="On" Toggled="OnStyleChanged" />
                <ToggleSwitch x:Name="TransparentToggle" Header="Transparent background"
                              OffContent="Off" OnContent="On" Toggled="OnStyleChanged" />

                <StackPanel Spacing="2">
                    <TextBlock Text="Resolution" Style="{StaticResource CaptionTextBlockStyle}" />
                    <ComboBox x:Name="ResCombo" HorizontalAlignment="Stretch">
                        <ComboBoxItem Content="2×" />
                        <ComboBoxItem Content="4×" />
                    </ComboBox>
                </StackPanel>

                <Button Content="Export PNG…" Click="OnExportPng" HorizontalAlignment="Stretch"
                        Style="{StaticResource AccentButtonStyle}" Margin="0,4,0,0" />
                <Button Content="Export PDF…" Click="OnExportPdf" HorizontalAlignment="Stretch" />

                <TextBlock x:Name="StatusLabel" TextWrapping="Wrap"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Style="{StaticResource CaptionTextBlockStyle}" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</ContentDialog>
