<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="CanfarDesktop.Views.CubeViewer.CubeViewerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="#FF050810" RequestedTheme="Dark">
        <Grid.KeyboardAccelerators>
            <KeyboardAccelerator Key="Space" Invoked="OnPlayPauseAccel" />
            <KeyboardAccelerator Key="Left" Invoked="OnChannelStepAccel" />
            <KeyboardAccelerator Key="Right" Invoked="OnChannelStepAccel" />
            <KeyboardAccelerator Key="Left" Modifiers="Shift" Invoked="OnChannelStepAccel" />
            <KeyboardAccelerator Key="Right" Modifiers="Shift" Invoked="OnChannelStepAccel" />
        </Grid.KeyboardAccelerators>

        <!-- GPU volume render surface -->
        <SwapChainPanel x:Name="RenderPanel"
                        PointerPressed="OnPointerPressed"
                        PointerMoved="OnPointerMoved"
                        PointerReleased="OnPointerReleased"
                        PointerWheelChanged="OnPointerWheelChanged"
                        SizeChanged="OnPanelSizeChanged" />

        <!-- Wireframe box + WCS axis captions, projected to match the GPU render.
             Hit-test transparent so it never steals orbit/zoom input. -->
        <Canvas x:Name="OverlayCanvas" IsHitTestVisible="False" />

        <!-- Off-screen host: the export figure plate is parented here, laid out, and
             rasterized via RenderTargetBitmap, then removed. Children are positioned
             far off-screen so they never appear in the live UI. -->
        <Canvas x:Name="ExportHost" IsHitTestVisible="False" />

        <!-- 2D slice (single channel at native resolution), shown in Slice mode.
             Click to probe the spectrum at a spaxel; wheel-zoom toward the cursor, drag to pan,
             double-tap to reset. Hovering shows a floating value + WCS readout chip. The viewport
             (not the Image) takes pointer input so the letterbox area still hit-tests, and it is
             clipped so the zoomed slice never spills over the surrounding panels. -->
        <Grid x:Name="SliceViewport" Visibility="Collapsed" Background="Transparent"
              Margin="60,72,264,96"
              SizeChanged="OnSliceViewportSizeChanged"
              PointerPressed="OnSlicePointerPressed"
              PointerMoved="OnSlicePointerMoved"
              PointerReleased="OnSlicePointerReleased"
              PointerExited="OnSlicePointerExited"
              PointerWheelChanged="OnSlicePointerWheel"
              DoubleTapped="OnSliceDoubleTapped">
            <Image x:Name="SliceImage" Stretch="Uniform">
                <Image.RenderTransform>
                    <CompositeTransform x:Name="SliceTransform" />
                </Image.RenderTransform>
            </Image>
            <!-- Floating cursor readout (sky + spectral + value), positioned near the pointer -->
            <Canvas IsHitTestVisible="False">
                <Border x:Name="CursorChip" Visibility="Collapsed"
                        CornerRadius="6" Padding="8,5"
                        Background="#E0101622" BorderBrush="#50BFD8FF" BorderThickness="1">
                    <StackPanel Spacing="1">
                        <TextBlock x:Name="CursorChipLon" Foreground="#FFE0E0E0" FontFamily="Consolas" FontSize="11" />
                        <TextBlock x:Name="CursorChipLat" Foreground="#FFE0E0E0" FontFamily="Consolas" FontSize="11" />
                        <TextBlock x:Name="CursorChipSpec" Foreground="#90BFD8FF" FontFamily="Consolas" FontSize="11" />
                        <TextBlock x:Name="CursorChipValue" Foreground="#FFFFA53C" FontFamily="Consolas" FontSize="11" />
                    </StackPanel>
                </Border>
            </Canvas>
        </Grid>

        <!-- Slice coordinate bar: persistent sky/value/spectral readout for the hovered spaxel.
             Top-center (under the mode toggle) — the bottom band is taken by the scrubber +
             spectrum probe, unlike macOS where the bar sits below the image. -->
        <Border x:Name="SliceCoordBar" Visibility="Collapsed" IsHitTestVisible="False"
                HorizontalAlignment="Center" VerticalAlignment="Top"
                Margin="0,64,0,0" Padding="12,4" CornerRadius="6"
                Background="#C0101622" BorderBrush="#40FFFFFF" BorderThickness="1">
            <TextBlock x:Name="SliceCoordText" Foreground="#A0E0E0E0" FontFamily="Consolas"
                       Style="{StaticResource CaptionTextBlockStyle}" />
        </Border>

        <!-- View-mode toggle (top center) -->
        <Border x:Name="ViewModeBar" HorizontalAlignment="Center" VerticalAlignment="Top"
                Margin="0,16,0,0" CornerRadius="6" Padding="3"
                Background="#C0101622" BorderBrush="#40FFFFFF" BorderThickness="1">
            <StackPanel Orientation="Horizontal" Spacing="2">
                <ToggleButton x:Name="VolumeModeButton" x:Uid="Cube_VolumeModeButton" Content="Volume" IsChecked="True"
                              MinWidth="84" Click="OnVolumeModeClick" />
                <ToggleButton x:Name="SliceModeButton" x:Uid="Cube_SliceModeButton" Content="Slice"
                              MinWidth="84" Click="OnSliceModeClick" />
            </StackPanel>
        </Border>

        <!-- Fallback message shown if the GPU device can't be created -->
        <TextBlock x:Name="FallbackText"
                   Visibility="Collapsed"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   TextAlignment="Center" MaxWidth="420"
                   Foreground="#FFE0E0E0"
                   TextWrapping="Wrap"
                   Style="{StaticResource BodyTextBlockStyle}" />

        <!-- Title / status -->
        <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top"
                    Margin="20" Spacing="2" IsHitTestVisible="False">
            <TextBlock x:Uid="Cube_Title" Text="Cube Viewer" FontWeight="Bold"
                       Foreground="#FFF0F0F0"
                       Style="{StaticResource SubtitleTextBlockStyle}" />
            <TextBlock x:Uid="Cube_OrbitHint" Text="Drag to orbit · Scroll to zoom"
                       Foreground="#80FFFFFF"
                       Style="{StaticResource CaptionTextBlockStyle}" />
        </StackPanel>

        <!-- Cube info / metadata panel (bottom-left) -->
        <Border x:Name="InfoPanel" Visibility="Collapsed"
                HorizontalAlignment="Left" VerticalAlignment="Bottom"
                Margin="20" Padding="14,10" CornerRadius="8" MaxWidth="320"
                Background="#C0101622" BorderBrush="#40FFFFFF" BorderThickness="1"
                IsHitTestVisible="False">
            <StackPanel Spacing="3">
                <TextBlock x:Name="InfoObject" FontWeight="SemiBold"
                           Foreground="#FFF0F0F0" TextTrimming="CharacterEllipsis"
                           Style="{StaticResource BodyStrongTextBlockStyle}" />
                <TextBlock x:Name="InfoInstrument" Foreground="#90BFD8FF"
                           Visibility="Collapsed" TextTrimming="CharacterEllipsis"
                           Style="{StaticResource CaptionTextBlockStyle}" />
                <Grid Margin="0,4,0,0" ColumnSpacing="10" RowSpacing="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock x:Uid="Cube_InfoDimsLabel" Grid.Row="0" Grid.Column="0" Text="DIMENSIONS"
                               Foreground="#70BFD8FF" Style="{StaticResource CaptionTextBlockStyle}" />
                    <TextBlock x:Name="InfoDims" Grid.Row="0" Grid.Column="1"
                               Foreground="#FFE0E0E0" FontFamily="Consolas"
                               Style="{StaticResource CaptionTextBlockStyle}" />

                    <TextBlock x:Name="InfoUnitLabel" x:Uid="Cube_InfoUnitLabel" Grid.Row="1" Grid.Column="0" Text="UNIT"
                               Foreground="#70BFD8FF" Style="{StaticResource CaptionTextBlockStyle}" />
                    <TextBlock x:Name="InfoUnit" Grid.Row="1" Grid.Column="1"
                               Foreground="#FFE0E0E0" FontFamily="Consolas"
                               Style="{StaticResource CaptionTextBlockStyle}" />

                    <TextBlock x:Uid="Cube_InfoRangeLabel" Grid.Row="2" Grid.Column="0" Text="RANGE"
                               Foreground="#70BFD8FF" Style="{StaticResource CaptionTextBlockStyle}" />
                    <TextBlock x:Name="InfoRange" Grid.Row="2" Grid.Column="1"
                               Foreground="#FFE0E0E0" FontFamily="Consolas" TextTrimming="CharacterEllipsis"
                               Style="{StaticResource CaptionTextBlockStyle}" />

                    <TextBlock x:Uid="Cube_InfoMinMaxLabel" Grid.Row="3" Grid.Column="0" Text="MIN / MAX"
                               Foreground="#70BFD8FF" Style="{StaticResource CaptionTextBlockStyle}" />
                    <TextBlock x:Name="InfoMinMax" Grid.Row="3" Grid.Column="1"
                               Foreground="#FFE0E0E0" FontFamily="Consolas" TextTrimming="CharacterEllipsis"
                               Style="{StaticResource CaptionTextBlockStyle}" />

                    <TextBlock x:Uid="Cube_InfoMedianLabel" Grid.Row="4" Grid.Column="0" Text="MEDIAN"
                               Foreground="#70BFD8FF" Style="{StaticResource CaptionTextBlockStyle}" />
                    <TextBlock x:Name="InfoMedian" Grid.Row="4" Grid.Column="1"
                               Foreground="#FFE0E0E0" FontFamily="Consolas"
                               Style="{StaticResource CaptionTextBlockStyle}" />

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="NaN"
                               Foreground="#70BFD8FF" Style="{StaticResource CaptionTextBlockStyle}" />
                    <TextBlock x:Name="InfoNan" Grid.Row="5" Grid.Column="1"
                               Foreground="#FFE0E0E0" FontFamily="Consolas"
                               Style="{StaticResource CaptionTextBlockStyle}" />

                    <TextBlock x:Uid="Cube_InfoModeLabel" Grid.Row="6" Grid.Column="0" Text="MODE"
                               Foreground="#70BFD8FF" Style="{StaticResource CaptionTextBlockStyle}" />
                    <TextBlock x:Name="InfoMode" Grid.Row="6" Grid.Column="1"
                               Foreground="#FFE0E0E0" FontFamily="Consolas" TextTrimming="CharacterEllipsis"
                               Style="{StaticResource CaptionTextBlockStyle}" />
                </Grid>
            </StackPanel>
        </Border>

        <!-- Control panel -->
        <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="20" Padding="16,14" CornerRadius="8"
                Background="#C0101622" BorderBrush="#40FFFFFF" BorderThickness="1">
            <ScrollViewer x:Name="ControlScroll" VerticalScrollBarVisibility="Auto"
                          VerticalScrollMode="Auto" HorizontalScrollMode="Disabled">
            <StackPanel Spacing="12" Width="228">

                <!-- ── DISPLAY ── -->
                <TextBlock x:Uid="Cube_DisplayHeader" Text="DISPLAY" FontWeight="SemiBold"
                           Foreground="#90BFD8FF"
                           Style="{StaticResource CaptionTextBlockStyle}" />

                <StackPanel Spacing="2">
                    <Grid>
                        <TextBlock x:Uid="Cube_WindowLabel" Text="Window" Foreground="#FFE0E0E0" HorizontalAlignment="Left"
                                   Style="{StaticResource CaptionTextBlockStyle}" />
                        <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Right">
                            <Button x:Uid="Cube_WindowMinMaxButton" Content="Min/Max" Padding="6,1" FontSize="11" Click="OnWindowMinMax" />
                            <Button Content="99%" Padding="6,1" FontSize="11" Click="OnWindowP99" />
                        </StackPanel>
                    </Grid>
                    <Slider x:Name="WindowLoSlider" Minimum="0" Maximum="1"
                            StepFrequency="0.005" Value="0"
                            ValueChanged="OnWindowLoChanged" />
                    <Slider x:Name="WindowHiSlider" Minimum="0" Maximum="1"
                            StepFrequency="0.005" Value="1"
                            ValueChanged="OnWindowHiChanged" />
                </StackPanel>

                <StackPanel Spacing="2">
                    <TextBlock x:Uid="Cube_StretchLabel" Text="Stretch" Foreground="#FFE0E0E0"
                               Style="{StaticResource CaptionTextBlockStyle}" />
                    <ComboBox x:Name="StretchCombo" HorizontalAlignment="Stretch"
                              SelectionChanged="OnStretchChanged">
                        <ComboBoxItem x:Uid="Cube_StretchLinear" Content="Linear" Tag="Linear" IsSelected="True" />
                        <ComboBoxItem x:Uid="Cube_StretchLog" Content="Log" Tag="Log" />
                        <ComboBoxItem x:Uid="Cube_StretchSqrt" Content="Sqrt" Tag="Sqrt" />
                        <ComboBoxItem x:Uid="Cube_StretchSquared" Content="Squared" Tag="Squared" />
                        <ComboBoxItem x:Uid="Cube_StretchAsinh" Content="Asinh" Tag="Asinh" />
                    </ComboBox>
                </StackPanel>

                <StackPanel Spacing="2">
                    <TextBlock x:Uid="Cube_ColormapLabel" Text="Colormap" Foreground="#FFE0E0E0"
                               Style="{StaticResource CaptionTextBlockStyle}" />
                    <ComboBox x:Name="ColormapCombo" HorizontalAlignment="Stretch"
                              SelectionChanged="OnColormapChanged" />
                    <!-- Live colorbar: active colormap across the window range -->
                    <Rectangle x:Name="ColorbarRect"
                            Height="14" Margin="0,4,0,0" RadiusX="3" RadiusY="3"
                            Stroke="#30FFFFFF" StrokeThickness="1" />
                    <Grid>
                        <TextBlock x:Name="ColorbarLo" HorizontalAlignment="Left"
                                   Foreground="#A0E0E0E0" FontFamily="Consolas"
                                   Style="{StaticResource CaptionTextBlockStyle}" />
                        <TextBlock x:Name="ColorbarHi" HorizontalAlignment="Right"
                                   Foreground="#A0E0E0E0" FontFamily="Consolas"
                                   Style="{StaticResource CaptionTextBlockStyle}" />
                    </Grid>
                </StackPanel>

                <StackPanel Spacing="2">
                    <TextBlock x:Uid="Cube_BackgroundLabel" Text="Background" Foreground="#FFE0E0E0"
                               Style="{StaticResource CaptionTextBlockStyle}" />
                    <ComboBox x:Name="BackgroundCombo" HorizontalAlignment="Stretch"
                              SelectionChanged="OnBackgroundChanged">
                        <ComboBoxItem x:Uid="Cube_BgDark" Content="Dark" IsSelected="True" />
                        <ComboBoxItem x:Uid="Cube_BgBlack" Content="Black" />
                        <ComboBoxItem x:Uid="Cube_BgLight" Content="Light" />
                    </ComboBox>
                </StackPanel>

                <!-- ── VOLUME ── (hidden in Slice mode) -->
                <StackPanel x:Name="VolumeSection" Spacing="12">
                    <TextBlock x:Uid="Cube_VolumeHeader" Text="VOLUME" FontWeight="SemiBold" Margin="0,4,0,0"
                               Foreground="#90BFD8FF"
                               Style="{StaticResource CaptionTextBlockStyle}" />

                    <StackPanel Spacing="2">
                        <TextBlock x:Uid="Cube_RenderModeLabel" Text="Render mode" Foreground="#FFE0E0E0"
                                   Style="{StaticResource CaptionTextBlockStyle}" />
                        <ComboBox x:Name="RenderModeCombo" HorizontalAlignment="Stretch"
                                  SelectionChanged="OnRenderModeChanged">
                            <ComboBoxItem x:Uid="Cube_RenderEmission" Content="Emission" IsSelected="True" />
                            <ComboBoxItem x:Uid="Cube_RenderMip" Content="Max-Intensity" />
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Spacing="2">
                        <TextBlock x:Uid="Cube_DensityLabel" Text="Density" Foreground="#FFE0E0E0"
                                   Style="{StaticResource CaptionTextBlockStyle}" />
                        <Slider x:Name="DensitySlider" Minimum="0.1" Maximum="3.0"
                                StepFrequency="0.05" Value="1.0"
                                ValueChanged="OnDensityChanged" />
                    </StackPanel>

                    <StackPanel Spacing="2">
                        <TextBlock x:Uid="Cube_SpectralLabel" Text="Spectral scale" Foreground="#FFE0E0E0"
                                   Style="{StaticResource CaptionTextBlockStyle}" />
                        <Slider x:Name="SpectralSlider" Minimum="0.5" Maximum="4.0"
                                StepFrequency="0.05" Value="1.5"
                                ValueChanged="OnSpectralChanged" />
                    </StackPanel>

                    <StackPanel Spacing="2">
                        <TextBlock x:Uid="Cube_StepsLabel" Text="Quality (steps)" Foreground="#FFE0E0E0"
                                   Style="{StaticResource CaptionTextBlockStyle}" />
                        <Slider x:Name="StepsSlider" Minimum="96" Maximum="768"
                                StepFrequency="16" Value="384"
                                ValueChanged="OnStepsChanged" />
                    </StackPanel>

                    <ToggleSwitch x:Name="AutoOrbitToggle" x:Uid="Cube_AutoOrbitToggle" Header="Idle auto-orbit"
                                  OffContent="Off" OnContent="On"
                                  Foreground="#FFE0E0E0"
                                  Toggled="OnAutoOrbitToggled" />

                    <ToggleSwitch x:Name="CaptionsToggle" x:Uid="Cube_CaptionsToggle" Header="Axis captions"
                                  OffContent="Off" OnContent="On" IsOn="True"
                                  Foreground="#FFE0E0E0"
                                  Toggled="OnCaptionsToggled" />

                    <ToggleSwitch x:Name="SlicePlaneToggle" x:Uid="Cube_SlicePlaneToggle" Header="Slice-plane marker"
                                  OffContent="Off" OnContent="On" IsOn="True"
                                  Foreground="#FFE0E0E0"
                                  Toggled="OnSlicePlaneToggled" />

                    <!-- Opacity transfer-function editor: drag points, click to add, right-click
                         to remove (endpoints are pinned in value). Feeds the renderer's alpha ramp. -->
                    <StackPanel Spacing="2">
                        <Grid>
                            <TextBlock x:Uid="Cube_OpacityLabel" Text="Opacity curve" Foreground="#FFE0E0E0" VerticalAlignment="Center"
                                       Style="{StaticResource CaptionTextBlockStyle}" />
                            <Button x:Uid="Cube_TransferResetButton" Content="Reset" Padding="6,1" FontSize="11" HorizontalAlignment="Right"
                                    Click="OnTransferReset" />
                        </Grid>
                        <Canvas x:Name="TransferCanvas" Height="120" Background="#30000000"
                                SizeChanged="OnTransferCanvasSizeChanged"
                                PointerPressed="OnTransferPointerPressed"
                                PointerMoved="OnTransferPointerMoved"
                                PointerReleased="OnTransferPointerReleased"
                                RightTapped="OnTransferRightTapped" />
                        <TextBlock x:Uid="Cube_TransferHint" Text="Drag points · click adds · right-click removes"
                                   Foreground="#70BFD8FF" Style="{StaticResource CaptionTextBlockStyle}" />
                    </StackPanel>

                    <Button x:Uid="Cube_ResetViewButton" Content="Reset view" HorizontalAlignment="Stretch"
                            Click="OnResetView" />
                </StackPanel>

                <Button x:Name="ExportButton" x:Uid="Cube_ExportButton" Content="Export figure…" HorizontalAlignment="Stretch"
                        Click="OnExportClick" />
            </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Cube load progress (bottom-center): stepped indicator + progress bar -->
        <Border x:Name="LoadingPanel" Visibility="Collapsed" IsHitTestVisible="False"
                HorizontalAlignment="Center" VerticalAlignment="Bottom"
                Margin="0,0,0,40" Padding="22,16" CornerRadius="10" MinWidth="360"
                Background="#EA0C1018" BorderBrush="#55BFD8FF" BorderThickness="1">
            <StackPanel Spacing="10">
                <TextBlock x:Name="LoadingTitle" FontWeight="SemiBold" Foreground="#FFF0F0F0"
                           HorizontalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="380"
                           Style="{StaticResource BodyStrongTextBlockStyle}" />
                <ProgressBar x:Name="LoadingBar" Minimum="0" Maximum="1" Value="0" Width="360" />
                <StackPanel x:Name="LoadingSteps" Spacing="4" Margin="0,2,0,0" />
            </StackPanel>
        </Border>

        <!-- Transient status / error snackbar (bottom-center) — mirrors the loading panel style -->
        <Border x:Name="StatusSnack" Visibility="Collapsed"
                HorizontalAlignment="Center" VerticalAlignment="Bottom"
                Margin="0,0,0,40" Padding="18,12" CornerRadius="10" MinWidth="320" MaxWidth="600"
                Background="#EA0C1018" BorderBrush="#55BFD8FF" BorderThickness="1">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <FontIcon x:Name="StatusSnackIcon" Grid.Column="0" FontSize="16" VerticalAlignment="Center"
                          Glyph="&#xE946;" Foreground="#FF56C8FF" />
                <TextBlock x:Name="StatusSnackText" Grid.Column="1" VerticalAlignment="Center"
                           TextWrapping="Wrap" Foreground="#FFF0F0F0"
                           Style="{StaticResource BodyTextBlockStyle}" />
                <Button x:Name="StatusSnackClose" Grid.Column="2" Content="✕" Padding="7,1" FontSize="12"
                        Background="Transparent" BorderThickness="0" VerticalAlignment="Center"
                        Click="OnStatusSnackClose" />
            </Grid>
        </Border>

        <!-- Spectrum probe (slice mode): flux vs channel at the clicked spaxel -->
        <Border x:Name="SpectrumPanel" Visibility="Collapsed"
                HorizontalAlignment="Center" VerticalAlignment="Bottom"
                Margin="0,0,0,94" Padding="14,10" CornerRadius="8" Width="448"
                Background="#D8101622" BorderBrush="#50BFD8FF" BorderThickness="1">
            <StackPanel Spacing="6">
                <Grid>
                    <TextBlock x:Name="SpectrumTitle" Foreground="#FFE0E0E0" VerticalAlignment="Center"
                               Style="{StaticResource CaptionTextBlockStyle}" />
                    <Button Content="✕" HorizontalAlignment="Right" Padding="6,0" FontSize="12"
                            Background="Transparent" BorderThickness="0" Click="OnSpectrumClose" />
                </Grid>
                <Canvas x:Name="SpectrumCanvas" Width="420" Height="92" Background="#30000000"
                        PointerPressed="OnSpectrumCanvasPressed" />
            </StackPanel>
        </Border>

        <!-- Channel scrubber + playback (slice mode) -->
        <Border x:Name="SliceBar" Visibility="Collapsed"
                HorizontalAlignment="Center" VerticalAlignment="Bottom"
                Margin="0,0,0,20" Padding="14,8" CornerRadius="8"
                Background="#C0101622" BorderBrush="#40FFFFFF" BorderThickness="1">
            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <Button x:Name="PlayButton" x:Uid="Cube_PlayButton" Click="OnPlayPause" Width="42" Padding="0"
                        ToolTipService.ToolTip="Play / Pause (Space)">
                    <FontIcon x:Name="PlayIcon" Glyph="&#xE768;" FontSize="16" />
                </Button>
                <StackPanel VerticalAlignment="Center">
                    <!-- Cube-mean per-channel waveform backdrop (the macOS ChannelScrubber) -->
                    <Canvas x:Name="WaveformCanvas" Width="340" Height="20" IsHitTestVisible="False" />
                    <Slider x:Name="ChannelSlider" Width="340" Minimum="0" Maximum="0"
                            StepFrequency="1" ValueChanged="OnChannelChanged" VerticalAlignment="Center" />
                </StackPanel>
                <TextBlock x:Name="ChannelLabel" VerticalAlignment="Center" MinWidth="180"
                           Foreground="#FFE0E0E0" FontFamily="Consolas"
                           Style="{StaticResource CaptionTextBlockStyle}" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
