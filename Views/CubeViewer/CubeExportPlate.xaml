<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="CanfarDesktop.Views.CubeViewer.CubeExportPlate"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border x:Name="RootBorder" Padding="26">
        <StackPanel x:Name="Stack" Spacing="0">

            <!-- Header: brand · title (left), filename · date (right), divider -->
            <Grid x:Name="HeaderGrid">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="BrandTitle" Grid.Column="0" VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock x:Name="FileDate" Grid.Column="1" VerticalAlignment="Center"
                           Margin="16,0,0,0" />
            </Grid>
            <Rectangle x:Name="Divider" Height="1" Margin="0,6,0,12" />

            <!-- Framed render (volume + box + captions already composited in) -->
            <Border x:Name="FrameBorder" BorderThickness="1" HorizontalAlignment="Center">
                <Image x:Name="FrameImage" Stretch="None" />
            </Border>

            <!-- Footer: legend | axis ranges | colorbar -->
            <Grid x:Name="FooterGrid" Margin="0,14,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel x:Name="LegendPanel" Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                    <TextBlock x:Name="LegendTitle" TextTrimming="CharacterEllipsis" />
                    <TextBlock x:Name="LegendSubtitle" TextTrimming="CharacterEllipsis" />
                    <TextBlock x:Name="LegendFacts" TextTrimming="CharacterEllipsis" />
                </StackPanel>

                <StackPanel x:Name="AxisRangesPanel" Grid.Column="1" Spacing="2"
                            Margin="24,0,24,0" VerticalAlignment="Center" />

                <StackPanel x:Name="ColorbarPanel" Grid.Column="2" Spacing="3" VerticalAlignment="Center">
                    <TextBlock x:Name="CbStretch" HorizontalAlignment="Right" />
                    <Rectangle x:Name="ColorbarRect" Height="10" />
                    <Grid>
                        <TextBlock x:Name="CbMin" HorizontalAlignment="Left" />
                        <TextBlock x:Name="CbMax" HorizontalAlignment="Right" />
                    </Grid>
                </StackPanel>
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
