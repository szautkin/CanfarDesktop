<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="CanfarDesktop.Views.ObservationDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Persistent header -->
        <Grid Grid.Row="0" Padding="16,10"
              Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              BorderThickness="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <StackPanel Spacing="0" VerticalAlignment="Center">
                    <TextBlock x:Name="HeaderObsId" Style="{StaticResource BodyStrongTextBlockStyle}"
                               TextTrimming="CharacterEllipsis"
                               AutomationProperties.HeadingLevel="Level2" />
                    <TextBlock x:Name="HeaderCollection" Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
                <StackPanel x:Name="HeaderChips" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <HyperlinkButton x:Name="ViewOnCadcButton" Click="OnViewOnCadc"
                                 ToolTipService.ToolTip="View on CADC"
                                 AutomationProperties.Name="View observation on CADC website">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE71B;" FontSize="14" />
                        <TextBlock Text="View on CADC" />
                    </StackPanel>
                </HyperlinkButton>
                <Button Click="OnClose" Background="Transparent" BorderThickness="0" Padding="6,4"
                        AutomationProperties.Name="Close observation detail"
                        ToolTipService.ToolTip="Close (Back)">
                    <FontIcon Glyph="&#xE711;" FontSize="14" />
                </Button>
            </StackPanel>
        </Grid>

        <!-- Status bars -->
        <StackPanel Grid.Row="1">
            <InfoBar x:Name="ErrorBar" IsOpen="False" IsClosable="False" Severity="Error"
                     Title="Could not load observation">
                <InfoBar.ActionButton>
                    <Button Content="Retry" Click="OnRetry" />
                </InfoBar.ActionButton>
            </InfoBar>
            <InfoBar x:Name="DownloadBar" IsOpen="False" IsClosable="True">
                <StackPanel Margin="0,4,0,8" Spacing="4" MinWidth="320">
                    <ProgressBar x:Name="DownloadProgress" IsIndeterminate="True" />
                    <TextBlock x:Name="DownloadText" Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </InfoBar>
        </StackPanel>

        <!-- Body (state-swapped) -->
        <Grid Grid.Row="2">
            <StackPanel x:Name="LoadingPanel" HorizontalAlignment="Center" VerticalAlignment="Center"
                        Spacing="12" Visibility="Collapsed">
                <ProgressRing Width="48" Height="48" IsActive="True" />
                <TextBlock Text="Loading observation…" HorizontalAlignment="Center"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <StackPanel x:Name="AuthPanel" HorizontalAlignment="Center" VerticalAlignment="Center"
                        Spacing="12" MaxWidth="400" Visibility="Collapsed">
                <FontIcon Glyph="&#xE72E;" FontSize="56" HorizontalAlignment="Center"
                          Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
                <TextBlock Text="Sign in to view" Style="{StaticResource TitleTextBlockStyle}"
                           HorizontalAlignment="Center" />
                <TextBlock TextWrapping="Wrap" TextAlignment="Center"
                           Style="{StaticResource BodyTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Text="This observation is from a proprietary collection. Sign in with your CADC account to access the details." />
                <Button Content="Sign in" Style="{StaticResource AccentButtonStyle}"
                        HorizontalAlignment="Center" Click="OnSignIn"
                        AutomationProperties.Name="Sign in to view proprietary observation" />
            </StackPanel>

            <StackPanel x:Name="NotFoundPanel" HorizontalAlignment="Center" VerticalAlignment="Center"
                        Spacing="12" MaxWidth="400" Visibility="Collapsed">
                <FontIcon Glyph="&#xE783;" FontSize="56" HorizontalAlignment="Center"
                          Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                <TextBlock Text="Observation not found" Style="{StaticResource TitleTextBlockStyle}"
                           HorizontalAlignment="Center" />
                <TextBlock x:Name="NotFoundText" TextWrapping="Wrap" TextAlignment="Center"
                           Style="{StaticResource BodyTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <Pivot x:Name="DetailPivot" Visibility="Collapsed" Padding="16,4,16,0">
                <PivotItem Header="Overview">
                    <ScrollViewer><StackPanel x:Name="OverviewPanel" Spacing="12" Padding="0,12" /></ScrollViewer>
                </PivotItem>
                <PivotItem Header="Coverage">
                    <ScrollViewer><StackPanel x:Name="CoveragePanel" Spacing="12" Padding="0,12" /></ScrollViewer>
                </PivotItem>
                <PivotItem Header="Files">
                    <ScrollViewer><StackPanel x:Name="FilesPanel" Spacing="12" Padding="0,12" /></ScrollViewer>
                </PivotItem>
                <PivotItem Header="Provenance">
                    <ScrollViewer><StackPanel x:Name="ProvenancePanel" Spacing="12" Padding="0,12" /></ScrollViewer>
                </PivotItem>
                <PivotItem Header="Raw">
                    <ScrollViewer><StackPanel x:Name="RawPanel" Spacing="4" Padding="0,12" /></ScrollViewer>
                </PivotItem>
            </Pivot>
        </Grid>
    </Grid>
</UserControl>
