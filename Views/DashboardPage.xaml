<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CanfarDesktop.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:CanfarDesktop.Converters"
    NavigationCacheMode="Enabled">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Padding="24" RowSpacing="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Top row: Sessions + Storage -->
            <Grid Grid.Row="0" ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="4*" />
                    <ColumnDefinition Width="*" MinWidth="220" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" x:Name="SessionListContainer" MinHeight="200" />
                <Grid Grid.Column="1" RowSpacing="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" x:Name="StorageContainer" />
                    <Border Grid.Row="1" x:Name="BatchJobsContainer" />
                </Grid>
            </Grid>

            <!-- Bottom row: Launch Form + Platform Load -->
            <Grid Grid.Row="1" ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="2*" MinWidth="250" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" x:Name="LaunchFormContainer" />
                <Grid Grid.Column="1" RowSpacing="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" x:Name="RecentLaunchesContainer" />
                    <Border Grid.Row="1" x:Name="PlatformLoadContainer" />
                </Grid>
            </Grid>
        </Grid>
    </ScrollViewer>
</Page>
