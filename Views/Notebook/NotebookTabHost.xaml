<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="CanfarDesktop.Views.Notebook.NotebookTabHost"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CanfarDesktop.Views.Notebook"
    KeyDown="OnKeyDown">

    <Grid RowDefinitions="Auto,*">

        <!-- Shared toolbar (applies to active tab) -->
        <StackPanel x:Name="ToolbarPanel" Grid.Row="0" Orientation="Horizontal" Spacing="4" Padding="12,6"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="0,0,0,1">
            <Button Click="OnNewNotebook" ToolTipService.ToolTip="New Notebook (Ctrl+N)" Padding="8,4"
                    AutomationProperties.Name="New notebook">
                <FontIcon Glyph="&#xE8A5;" FontSize="14" />
            </Button>
            <Button Click="OnOpenFile" ToolTipService.ToolTip="Open (Ctrl+O)" Padding="8,4"
                    AutomationProperties.Name="Open notebook">
                <FontIcon Glyph="&#xE8E5;" FontSize="14" />
            </Button>
            <Button Click="OnSave" ToolTipService.ToolTip="Save (Ctrl+S)" Padding="8,4"
                    AutomationProperties.Name="Save">
                <FontIcon Glyph="&#xE74E;" FontSize="14" />
            </Button>
            <Button Click="OnSaveAs" ToolTipService.ToolTip="Save As (Ctrl+Shift+S)" Padding="8,4"
                    AutomationProperties.Name="Save as">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <FontIcon Glyph="&#xE792;" FontSize="14" />
                    <TextBlock Text="Save As" />
                </StackPanel>
            </Button>
            <AppBarSeparator />
            <Button Click="OnAddCodeCell" ToolTipService.ToolTip="Add Code Cell" Padding="8,4">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <FontIcon Glyph="&#xE710;" FontSize="14" />
                    <TextBlock Text="Code" />
                </StackPanel>
            </Button>
            <Button Click="OnAddMarkdownCell" ToolTipService.ToolTip="Add Markdown Cell" Padding="8,4">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <FontIcon Glyph="&#xE8A4;" FontSize="14" />
                    <TextBlock Text="Markdown" />
                </StackPanel>
            </Button>
            <AppBarSeparator />
            <Button Click="OnMoveCellUp" ToolTipService.ToolTip="Move Up" Padding="8,4"
                    AutomationProperties.Name="Move cell up">
                <FontIcon Glyph="&#xE74A;" FontSize="14" />
            </Button>
            <Button Click="OnMoveCellDown" ToolTipService.ToolTip="Move Down" Padding="8,4"
                    AutomationProperties.Name="Move cell down">
                <FontIcon Glyph="&#xE74B;" FontSize="14" />
            </Button>
            <Button Click="OnDeleteCell" ToolTipService.ToolTip="Delete Cell" Padding="8,4"
                    AutomationProperties.Name="Delete cell">
                <FontIcon Glyph="&#xE74D;" FontSize="14"
                          Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
            </Button>
            <AppBarSeparator />
            <Button Click="OnRunCell" ToolTipService.ToolTip="Run Cell (Ctrl+Enter)" Padding="8,4">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <FontIcon Glyph="&#xE768;" FontSize="14"
                              Foreground="{ThemeResource SystemFillColorSuccessBrush}" />
                    <TextBlock Text="Run" />
                </StackPanel>
            </Button>
            <Button Click="OnRunAll" ToolTipService.ToolTip="Run All" Padding="8,4">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <FontIcon Glyph="&#xE768;" FontSize="14" />
                    <TextBlock Text="Run All" />
                </StackPanel>
            </Button>
            <Button Click="OnInterrupt" ToolTipService.ToolTip="Interrupt" Padding="8,4"
                    AutomationProperties.Name="Interrupt kernel">
                <FontIcon Glyph="&#xE71A;" FontSize="14" />
            </Button>
            <Button Click="OnRestart" ToolTipService.ToolTip="Restart Kernel" Padding="8,4"
                    AutomationProperties.Name="Restart kernel">
                <FontIcon Glyph="&#xE72C;" FontSize="14" />
            </Button>
            <AppBarSeparator />
            <Button Click="OnClearAllOutputs" ToolTipService.ToolTip="Clear All Outputs" Padding="8,4">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <FontIcon Glyph="&#xE894;" FontSize="14" />
                    <TextBlock Text="Clear" />
                </StackPanel>
            </Button>
            <AppBarSeparator />
            <Button Click="OnSettings" ToolTipService.ToolTip="Settings" Padding="8,4"
                    AutomationProperties.Name="Settings">
                <FontIcon Glyph="&#xE713;" FontSize="14" />
            </Button>
        </StackPanel>

        <!-- Welcome page (shown when no tabs open) -->
        <local:WelcomePage x:Name="Welcome" Grid.Row="1" Visibility="Collapsed" />

        <!-- Tab view -->
        <TabView x:Name="TabViewControl" Grid.Row="1"
                 IsAddTabButtonVisible="True"
                 AddTabButtonClick="OnAddTab"
                 TabCloseRequested="OnTabCloseRequested"
                 SelectionChanged="OnTabSelectionChanged" />
    </Grid>
</UserControl>
