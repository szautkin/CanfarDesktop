<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="CanfarDesktop.Views.Notebook.MarkdownCellControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border CornerRadius="8"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            PointerPressed="OnCellPointerPressed"
            MinHeight="40">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Selection accent border -->
            <Border x:Name="AccentBorder"
                    Grid.Column="0"
                    CornerRadius="8,0,0,8"
                    Background="Transparent" />

            <!-- Content area: rendered or edit mode -->
            <Grid Grid.Column="1" Padding="12,8">
                <!-- Rendered markdown (placeholder: plain text) -->
                <TextBlock x:Name="RenderedView"
                           TextWrapping="Wrap"
                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                           Tapped="OnRenderedTapped"
                           DoubleTapped="OnRenderedDoubleTapped"
                           Visibility="Visible" />

                <!-- Edit mode: raw markdown source -->
                <TextBox x:Name="SourceEditor"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         FontFamily="Consolas"
                         FontSize="13"
                         MinHeight="36"
                         BorderThickness="0"
                         Background="Transparent"
                         PlaceholderText="Type markdown here..."
                         Visibility="Collapsed"
                         GotFocus="OnEditorGotFocus"
                         LostFocus="OnEditorLostFocus"
                         TextChanged="OnSourceTextChanged"
                         KeyDown="OnEditorKeyDown" />
            </Grid>
        </Grid>
    </Border>
</UserControl>
