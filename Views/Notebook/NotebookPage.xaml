<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="CanfarDesktop.Views.Notebook.NotebookPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CanfarDesktop.Views.Notebook"
    xmlns:vm="using:CanfarDesktop.ViewModels.Notebook"
    KeyDown="OnKeyDown">

    <UserControl.Resources>
        <local:CellTemplateSelector x:Key="CellSelector"
            CodeCellTemplate="{StaticResource CodeCellTemplate}"
            MarkdownCellTemplate="{StaticResource MarkdownCellTemplate}" />

        <DataTemplate x:Key="CodeCellTemplate" x:DataType="vm:CodeCellViewModel">
            <local:CodeCellControl />
        </DataTemplate>

        <DataTemplate x:Key="MarkdownCellTemplate" x:DataType="vm:MarkdownCellViewModel">
            <local:MarkdownCellControl />
        </DataTemplate>
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,Auto,*,Auto" Padding="0">

        <!-- Title bar area -->
        <Grid Grid.Row="0" Padding="16,8"
              Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <FontIcon Grid.Column="0" Glyph="&#xE70B;" FontSize="18"
                      Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                      VerticalAlignment="Center" Margin="0,0,8,0" />
            <TextBlock Grid.Column="1" x:Name="TitleText"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       VerticalAlignment="Center" />
            <TextBlock Grid.Column="2" x:Name="DirtyIndicator" Text=" *"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                       Visibility="Collapsed"
                       VerticalAlignment="Center" />
        </Grid>

        <!-- Toolbar -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="4" Padding="12,6"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="0,0,0,1">
            <Button Click="OnSave" ToolTipService.ToolTip="Save (Ctrl+S)" Padding="8,4"
                    AutomationProperties.Name="Save">
                <FontIcon Glyph="&#xE74E;" FontSize="14" />
            </Button>
            <AppBarSeparator />
            <Button Click="OnAddCodeCell" ToolTipService.ToolTip="Add Code Cell" Padding="8,4">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <FontIcon Glyph="&#xE710;" FontSize="14" />
                    <TextBlock Text="Code" />
                </StackPanel>
            </Button>
            <Button Click="OnAddMarkdownCell" ToolTipService.ToolTip="Add Markdown Cell" Padding="8,4">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <FontIcon Glyph="&#xE8A4;" FontSize="14" />
                    <TextBlock Text="Markdown" />
                </StackPanel>
            </Button>
            <AppBarSeparator />
            <Button Click="OnMoveCellUp" ToolTipService.ToolTip="Move Up" Padding="8,4"
                    AutomationProperties.Name="Move cell up">
                <FontIcon Glyph="&#xE74A;" FontSize="14" />
            </Button>
            <Button Click="OnMoveCellDown" ToolTipService.ToolTip="Move Down" Padding="8,4"
                    AutomationProperties.Name="Move cell down">
                <FontIcon Glyph="&#xE74B;" FontSize="14" />
            </Button>
            <Button Click="OnDeleteCell" ToolTipService.ToolTip="Delete Cell" Padding="8,4"
                    AutomationProperties.Name="Delete cell">
                <FontIcon Glyph="&#xE74D;" FontSize="14"
                          Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
            </Button>
            <AppBarSeparator />
            <Button Click="OnRunCell" ToolTipService.ToolTip="Run Cell (Ctrl+Enter)" Padding="8,4">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <FontIcon Glyph="&#xE768;" FontSize="14"
                              Foreground="{ThemeResource SystemFillColorSuccessBrush}" />
                    <TextBlock Text="Run" />
                </StackPanel>
            </Button>
            <Button Click="OnRunAll" ToolTipService.ToolTip="Run All" Padding="8,4">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <FontIcon Glyph="&#xE768;" FontSize="14" />
                    <TextBlock Text="Run All" />
                </StackPanel>
            </Button>
            <Button Click="OnInterrupt" ToolTipService.ToolTip="Interrupt" Padding="8,4"
                    AutomationProperties.Name="Interrupt kernel">
                <FontIcon Glyph="&#xE71A;" FontSize="14" />
            </Button>
            <Button Click="OnRestart" ToolTipService.ToolTip="Restart Kernel" Padding="8,4"
                    AutomationProperties.Name="Restart kernel">
                <FontIcon Glyph="&#xE72C;" FontSize="14" />
            </Button>
            <AppBarSeparator />
            <Button Click="OnClearAllOutputs" ToolTipService.ToolTip="Clear All Outputs" Padding="8,4">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <FontIcon Glyph="&#xE894;" FontSize="14" />
                    <TextBlock Text="Clear" />
                </StackPanel>
            </Button>
        </StackPanel>

        <!-- Cell list -->
        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ItemsRepeater
                x:Name="CellList"
                Margin="40,16,40,16"
                ItemTemplate="{StaticResource CellSelector}">
                <ItemsRepeater.Layout>
                    <StackLayout Spacing="8" />
                </ItemsRepeater.Layout>
            </ItemsRepeater>
        </ScrollViewer>

        <!-- Status bar -->
        <Grid Grid.Row="3" Padding="12,6"
              Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              BorderThickness="0,1,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
                <Ellipse x:Name="KernelDot" Width="8" Height="8" VerticalAlignment="Center" />
                <TextBlock x:Name="KernelLabel"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
            </StackPanel>
            <TextBlock Grid.Column="1" x:Name="StatusLabel"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       HorizontalAlignment="Center" />
            <TextBlock Grid.Column="2" x:Name="CellCountLabel"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
        </Grid>
    </Grid>
</UserControl>
