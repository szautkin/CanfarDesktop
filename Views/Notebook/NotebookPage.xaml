<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="CanfarDesktop.Views.Notebook.NotebookPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CanfarDesktop.Views.Notebook"
    xmlns:vm="using:CanfarDesktop.ViewModels.Notebook">

    <UserControl.Resources>
        <local:CellTemplateSelector x:Key="CellSelector"
            CodeCellTemplate="{StaticResource CodeCellTemplate}"
            MarkdownCellTemplate="{StaticResource MarkdownCellTemplate}" />

        <DataTemplate x:Key="CodeCellTemplate" x:DataType="vm:CodeCellViewModel">
            <local:CodeCellControl />
        </DataTemplate>

        <DataTemplate x:Key="MarkdownCellTemplate" x:DataType="vm:MarkdownCellViewModel">
            <local:MarkdownCellControl />
        </DataTemplate>
    </UserControl.Resources>

    <Grid RowDefinitions="*,Auto">

        <!-- Cell list -->
        <ScrollViewer Grid.Row="0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
                <ItemsRepeater
                    x:Name="CellList"
                    Margin="40,16,40,0"
                    ItemTemplate="{StaticResource CellSelector}">
                    <ItemsRepeater.Layout>
                        <StackLayout Spacing="8" />
                    </ItemsRepeater.Layout>
                </ItemsRepeater>
                <!-- Extra space below last cell so user can always scroll past output -->
                <Border Height="800" />
            </StackPanel>
        </ScrollViewer>

        <!-- Status bar -->
        <Grid Grid.Row="1" Padding="12,6"
              Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              BorderThickness="0,1,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6">
                <Ellipse x:Name="KernelDot" Width="8" Height="8" VerticalAlignment="Center" />
                <TextBlock x:Name="KernelLabel"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
            </StackPanel>
            <TextBlock Grid.Column="1" x:Name="StatusLabel"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       HorizontalAlignment="Center" />
            <TextBlock Grid.Column="2" x:Name="CellCountLabel"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
        </Grid>
    </Grid>
</UserControl>
