<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="CanfarDesktop.Views.Notebook.CodeCellControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border CornerRadius="8"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            PointerPressed="OnCellPointerPressed">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4" />
                <ColumnDefinition Width="56" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Selection accent border (left strip) -->
            <Border x:Name="AccentBorder"
                    Grid.Column="0" Grid.RowSpan="2"
                    CornerRadius="8,0,0,8"
                    Background="Transparent" />

            <!-- Gutter: execution count -->
            <StackPanel Grid.Column="1" Grid.Row="0"
                        VerticalAlignment="Top" Padding="4,10,4,4"
                        HorizontalAlignment="Center">
                <TextBlock x:Name="ExecutionLabel"
                           Text="[ ]"
                           FontFamily="Consolas"
                           FontSize="12"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                           HorizontalAlignment="Center" />
            </StackPanel>

            <!-- Source editor + syntax highlight overlay -->
            <Grid Grid.Column="2" Grid.Row="0">
                <!-- Syntax-highlighted view (shown when not editing) -->
                <RichTextBlock x:Name="SyntaxView"
                               FontFamily="Consolas" FontSize="13"
                               Padding="12,8" IsTextSelectionEnabled="False"
                               TextWrapping="Wrap" Visibility="Visible"
                               Tapped="OnSyntaxViewTapped" />
                <!-- TextBox editor (shown when editing) -->
                <TextBox x:Name="SourceEditor"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         FontFamily="Consolas"
                         FontSize="13"
                         MinHeight="36"
                         Padding="12,8"
                         BorderThickness="0"
                         Background="Transparent"
                         PlaceholderText="Type Python code here..."
                         Visibility="Collapsed"
                         GotFocus="OnEditorGotFocus"
                         LostFocus="OnEditorLostFocus"
                         TextChanged="OnSourceTextChanged"
                         KeyDown="OnEditorKeyDown" />
            </Grid>

            <!-- Output area — ManipulationMode=System ensures scroll passes through -->
            <Border x:Name="OutputArea"
                    Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="1"
                    Visibility="Collapsed"
                    Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,8,8"
                    Padding="0"
                    ManipulationMode="System">
                <StackPanel>
                    <!-- Collapse toggle -->
                    <Button x:Name="CollapseToggle" Click="OnToggleOutputCollapse"
                            Padding="8,2" Background="Transparent" BorderThickness="0"
                            HorizontalAlignment="Left"
                            AutomationProperties.Name="Toggle output">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <FontIcon x:Name="CollapseIcon" Glyph="&#xE76B;" FontSize="10" />
                            <TextBlock x:Name="CollapseLabel" Text="Output"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                        </StackPanel>
                    </Button>
                    <!-- Output content -->
                    <StackPanel x:Name="OutputStack" Spacing="4" Padding="12,4,12,8" />
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
