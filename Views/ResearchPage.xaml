<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="CanfarDesktop.Views.ResearchPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Padding="24" ColumnSpacing="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left: file list -->
        <Border Grid.Column="0" Padding="12" CornerRadius="8"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
            <Grid RowSpacing="8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="Downloads" Style="{StaticResource SubtitleTextBlockStyle}" />
                    <TextBlock x:Name="CountText" Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
                </StackPanel>

                <TextBox Grid.Row="1" x:Name="FilterBox" PlaceholderText="Filter..."
                         TextChanged="OnFilterChanged" />

                <ListView Grid.Row="2" x:Name="FileList" SelectionMode="Single"
                          SelectionChanged="OnFileSelected">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="4,6" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding TargetName}" FontSize="13"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis">
                                        <Run Text="{Binding Collection}" /> —
                                        <Run Text="{Binding Instrument}" />
                                    </TextBlock>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="{Binding FormattedSize}"
                                           FontSize="11" Foreground="{ThemeResource TextFillColorTertiaryBrush}" VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <!-- Right: detail or empty state -->
        <Border Grid.Column="1" Padding="16" CornerRadius="8"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
            <Grid>
                <!-- Empty state -->
                <StackPanel x:Name="EmptyState" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
                    <FontIcon Glyph="&#xE8B7;" FontSize="48" Foreground="{ThemeResource TextFillColorTertiaryBrush}" HorizontalAlignment="Center" />
                    <TextBlock Text="Select an observation" Style="{StaticResource SubtitleTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" />
                    <TextBlock Text="Downloaded observations from CADC archive search appear here."
                               Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                               HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="300" />
                </StackPanel>

                <!-- Detail view -->
                <ScrollViewer x:Name="DetailPanel" Visibility="Collapsed"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="16" x:Name="DetailContent" />
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
