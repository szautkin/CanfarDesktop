<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CanfarDesktop.Views.AiGuidePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:CanfarDesktop.ViewModels"
    xmlns:converters="using:CanfarDesktop.Converters"
    mc:Ignorable="d"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="24" Spacing="16" MaxWidth="1080" HorizontalAlignment="Stretch">

            <!-- Header + stats + search -->
            <StackPanel Spacing="6">
                <TextBlock Text="AI Guide" Style="{StaticResource TitleTextBlockStyle}" />
                <TextBlock TextWrapping="Wrap" Style="{StaticResource BodyTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Text="Re-tune how the AI agent sees each tool, and add your own read-only guide tools it can call for instructions. Changes apply live to the MCP server." />
                <TextBlock Text="{x:Bind ViewModel.StatsText, Mode=OneWay}"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                <TextBox PlaceholderText="Search tools…" Margin="0,4,0,0"
                         Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>

            <!-- My guide tools -->
            <Border CornerRadius="8" Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="10">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="My guide tools" Style="{StaticResource SubtitleTextBlockStyle}" />
                            <TextBlock Text="Read-only instructions the agent can call by name."
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                        <Button Grid.Column="1" VerticalAlignment="Center" Click="OnAddGuideClick">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE710;" FontSize="14" />
                                <TextBlock Text="Add guide" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <TextBlock Text="No guide tools yet. Add one to give the agent reusable instructions."
                               Style="{StaticResource CaptionTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                               Visibility="{x:Bind ViewModel.HasGuides, Mode=OneWay, Converter={StaticResource BoolToVis}, ConverterParameter=Invert}" />

                    <ItemsControl ItemsSource="{x:Bind ViewModel.Guides, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:AiGuideGuideRowViewModel">
                                <Grid ColumnSpacing="12" Padding="0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Spacing="2">
                                        <TextBlock Text="{x:Bind Name}" FontFamily="Consolas" />
                                        <TextBlock Text="{x:Bind Description}" TextWrapping="Wrap"
                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Top">
                                        <Button Click="OnEditGuideClick" ToolTipService.ToolTip="Edit" Padding="8,4">
                                            <FontIcon Glyph="&#xE70F;" FontSize="13" />
                                        </Button>
                                        <Button Click="OnDeleteGuideClick" ToolTipService.ToolTip="Delete" Padding="8,4">
                                            <FontIcon Glyph="&#xE74D;" FontSize="13"
                                                      Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Tool categories -->
            <ItemsControl ItemsSource="{x:Bind ViewModel.Categories, Mode=OneWay}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:AiGuideCategoryGroup">
                        <Border CornerRadius="8" Padding="16" Margin="0,0,0,12"
                                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                                Visibility="{x:Bind IsVisible, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                            <StackPanel Spacing="8">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <FontIcon Grid.Column="0" Glyph="{x:Bind Glyph}" FontSize="20" VerticalAlignment="Center"
                                              Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <TextBlock Text="{x:Bind Title}" Style="{StaticResource SubtitleTextBlockStyle}" />
                                        <TextBlock Text="{x:Bind Summary}" TextWrapping="Wrap"
                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                    <Border Grid.Column="2" VerticalAlignment="Center" CornerRadius="10" Padding="8,2"
                                            Background="{ThemeResource AccentFillColorSecondaryBrush}"
                                            Visibility="{x:Bind HasOverrides, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="{x:Bind OverriddenBadgeText, Mode=OneWay}"
                                                   Style="{StaticResource CaptionTextBlockStyle}" />
                                    </Border>
                                </Grid>

                                <ItemsControl ItemsSource="{x:Bind Tools, Mode=OneWay}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:AiGuideToolRowViewModel">
                                            <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                                      Margin="0,2" IsExpanded="{x:Bind IsExpanded, Mode=TwoWay}"
                                                      Visibility="{x:Bind IsVisible, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                                                <Expander.Header>
                                                    <Grid ColumnSpacing="10" Padding="0,6">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                            <TextBlock Text="{x:Bind Name}" FontFamily="Consolas" VerticalAlignment="Center" />
                                                            <Border CornerRadius="8" Padding="6,1" VerticalAlignment="Center"
                                                                    Background="{ThemeResource AccentFillColorSecondaryBrush}"
                                                                    Visibility="{x:Bind IsOverridden, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                                                                <TextBlock Text="Overridden" Style="{StaticResource CaptionTextBlockStyle}" />
                                                            </Border>
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="1" Text="{x:Bind EffectiveDescription, Mode=OneWay}"
                                                                   TextTrimming="CharacterEllipsis" VerticalAlignment="Center"
                                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                    </Grid>
                                                </Expander.Header>
                                                <StackPanel Spacing="8" Padding="0,4">
                                                    <TextBlock Text="Built-in default" Style="{StaticResource CaptionTextBlockStyle}"
                                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                                    <TextBlock Text="{x:Bind DefaultDescription}" TextWrapping="Wrap" IsTextSelectionEnabled="True"
                                                               Style="{StaticResource CaptionTextBlockStyle}"
                                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                    <TextBox Header="Your description" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="80"
                                                             Text="{x:Bind EditText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             PlaceholderText="Describe this tool the way you want the agent to read it" />
                                                    <Grid>
                                                        <TextBlock Text="{x:Bind ErrorMessage, Mode=OneWay}" TextWrapping="Wrap"
                                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                                   Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                                                   Visibility="{x:Bind HasError, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                                                        <TextBlock Text="{x:Bind CharCountText, Mode=OneWay}" HorizontalAlignment="Right"
                                                                   Style="{StaticResource CaptionTextBlockStyle}"
                                                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                                    </Grid>
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <Button Content="Save" Click="OnSaveOverrideClick"
                                                                Style="{StaticResource AccentButtonStyle}" />
                                                        <Button Content="Reset to default" Click="OnResetOverrideClick"
                                                                Visibility="{x:Bind IsOverridden, Mode=OneWay, Converter={StaticResource BoolToVis}}" />
                                                        <Button Content="Cancel" Click="OnCancelEditClick" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </Expander>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </ScrollViewer>
</Page>
