<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="CanfarDesktop.Views.FitsViewer.FitsViewerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid RowDefinitions="*,Auto">

        <!-- Main content: header panel + image canvas -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="HeaderColumn" Width="0" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Header panel (collapsible) -->
            <Border Grid.Column="0" Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="0,0,1,0">
                <Grid RowDefinitions="Auto,*">
                    <TextBox Grid.Row="0" x:Name="HeaderFilter"
                             PlaceholderText="Search headers..."
                             Margin="4" TextChanged="OnHeaderFilterChanged" />
                    <ListView Grid.Row="1" x:Name="HeaderList" SelectionMode="None"
                              Padding="4">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="100,*,*" Padding="2">
                                    <TextBlock Grid.Column="0" Text="{Binding Keyword}"
                                               FontFamily="Consolas" FontSize="11"
                                               FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="1" Text="{Binding Value}"
                                               FontFamily="Consolas" FontSize="11"
                                               Margin="8,0" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="2" Text="{Binding Comment}"
                                               FontSize="11"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                               TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <!-- Image canvas: manual zoom/pan via CompositeTransform -->
            <Grid Grid.Column="1" Background="Black" x:Name="ImageCanvas"
                  PointerPressed="OnCanvasPointerPressed"
                  PointerMoved="OnCanvasPointerMoved"
                  PointerReleased="OnCanvasPointerReleased"
                  PointerCanceled="OnCanvasPointerReleased"
                  PointerWheelChanged="OnCanvasWheelChanged">
                <Image x:Name="FitsImage"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       RenderTransformOrigin="0.5,0.5">
                    <Image.RenderTransform>
                        <CompositeTransform x:Name="ImageTransform" />
                    </Image.RenderTransform>
                </Image>

                <!-- Blink overlay (fades on top of main image, never changes transforms) -->
                <Image x:Name="BlinkImage"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       RenderTransformOrigin="0.5,0.5"
                       Opacity="0"
                       IsHitTestVisible="False"
                       Visibility="Collapsed">
                    <Image.RenderTransform>
                        <CompositeTransform x:Name="BlinkTransform" />
                    </Image.RenderTransform>
                </Image>

                <!-- Crosshair overlay (click to place) -->
                <Canvas x:Name="CrosshairCanvas" IsHitTestVisible="False">
                    <!-- Linked crosshair (from other tabs, dashed) -->
                    <Line x:Name="LinkedCrosshairH"
                          Stroke="{ThemeResource SystemFillColorCautionBrush}"
                          StrokeDashArray="4,4"
                          StrokeThickness="1" Visibility="Collapsed" />
                    <Line x:Name="LinkedCrosshairV"
                          Stroke="{ThemeResource SystemFillColorCautionBrush}"
                          StrokeDashArray="4,4"
                          StrokeThickness="1" Visibility="Collapsed" />
                    <!-- Primary crosshair (user-placed) -->
                    <Line x:Name="CrosshairH"
                          Stroke="{ThemeResource SystemFillColorAttentionBrush}"
                          StrokeThickness="1" Visibility="Collapsed" />
                    <Line x:Name="CrosshairV"
                          Stroke="{ThemeResource SystemFillColorAttentionBrush}"
                          StrokeThickness="1" Visibility="Collapsed" />
                    <Border x:Name="CrosshairLabel" Visibility="Collapsed"
                            Background="{ThemeResource AcrylicInAppFillColorDefaultBrush}"
                            CornerRadius="4" Padding="6,2">
                        <TextBlock x:Name="CrosshairText"
                                   Foreground="{ThemeResource SystemFillColorAttentionBrush}"
                                   FontFamily="Consolas" FontSize="11" />
                    </Border>
                </Canvas>
            </Grid>
        </Grid>

        <!-- Status bar -->
        <Grid Grid.Row="1" Padding="12,4"
              Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              BorderThickness="0,1,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" x:Name="StatusLabel"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <TextBlock Grid.Column="1" x:Name="CoordLabel"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       HorizontalAlignment="Center" />
            <TextBlock Grid.Column="2" x:Name="PixelLabel"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Margin="16,0" />
            <TextBlock Grid.Column="3" x:Name="ZoomLabel"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
        </Grid>
    </Grid>
</UserControl>
