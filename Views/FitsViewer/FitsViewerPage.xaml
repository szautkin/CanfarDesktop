<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="CanfarDesktop.Views.FitsViewer.FitsViewerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Padding="12,6"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="0,0,0,1">

            <Button Click="OnOpenFile" ToolTipService.ToolTip="Open FITS" Padding="8,4"
                    AutomationProperties.Name="Open FITS file">
                <FontIcon Glyph="&#xE8E5;" FontSize="14" />
            </Button>
            <AppBarSeparator />

            <!-- Stretch -->
            <ComboBox x:Name="StretchCombo" Header="Stretch" Width="120"
                      SelectionChanged="OnStretchChanged">
                <ComboBoxItem Content="Linear" Tag="Linear" IsSelected="True" />
                <ComboBoxItem Content="Log" Tag="Log" />
                <ComboBoxItem Content="Sqrt" Tag="Sqrt" />
                <ComboBoxItem Content="Squared" Tag="Squared" />
                <ComboBoxItem Content="Asinh" Tag="Asinh" />
            </ComboBox>

            <!-- Colormap -->
            <ComboBox x:Name="ColormapCombo" Header="Colormap" Width="120"
                      SelectionChanged="OnColormapChanged">
                <ComboBoxItem Content="Grayscale" Tag="Grayscale" IsSelected="True" />
                <ComboBoxItem Content="Inverted" Tag="Inverted" />
                <ComboBoxItem Content="Heat" Tag="Heat" />
                <ComboBoxItem Content="Cool" Tag="Cool" />
                <ComboBoxItem Content="Viridis" Tag="Viridis" />
            </ComboBox>

            <AppBarSeparator />

            <!-- Min/Max cuts -->
            <StackPanel Orientation="Vertical" Spacing="2" VerticalAlignment="Center">
                <TextBlock Text="Min Cut" Style="{StaticResource CaptionTextBlockStyle}" />
                <Slider x:Name="MinCutSlider" Width="120" Minimum="0" Maximum="100"
                        ValueChanged="OnMinCutChanged" />
            </StackPanel>
            <StackPanel Orientation="Vertical" Spacing="2" VerticalAlignment="Center">
                <TextBlock Text="Max Cut" Style="{StaticResource CaptionTextBlockStyle}" />
                <Slider x:Name="MaxCutSlider" Width="120" Minimum="0" Maximum="100" Value="100"
                        ValueChanged="OnMaxCutChanged" />
            </StackPanel>

            <AppBarSeparator />
            <Button Click="OnResetStretch" Content="Reset" Padding="8,4" />
            <Button Click="OnToggleHeader" Content="Header" Padding="8,4" />

            <ProgressRing x:Name="LoadingRing" IsActive="False" Width="20" Height="20"
                          VerticalAlignment="Center" />
        </StackPanel>

        <!-- Main content: header panel + image canvas -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="HeaderColumn" Width="0" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Header panel (collapsible) -->
            <Border Grid.Column="0" Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="0,0,1,0">
                <Grid RowDefinitions="Auto,*">
                    <TextBox Grid.Row="0" x:Name="HeaderFilter"
                             PlaceholderText="Search headers..."
                             Margin="4" TextChanged="OnHeaderFilterChanged" />
                    <ListView Grid.Row="1" x:Name="HeaderList" SelectionMode="None"
                              Padding="4">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="100,*,*" Padding="2">
                                    <TextBlock Grid.Column="0" Text="{Binding Keyword}"
                                               FontFamily="Consolas" FontSize="11"
                                               FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="1" Text="{Binding Value}"
                                               FontFamily="Consolas" FontSize="11"
                                               Margin="8,0" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Column="2" Text="{Binding Comment}"
                                               FontSize="11"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                               TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <!-- Image canvas -->
            <ScrollViewer Grid.Column="1"
                          x:Name="ImageScroller"
                          ZoomMode="Enabled"
                          MinZoomFactor="0.1"
                          MaxZoomFactor="20"
                          HorizontalScrollMode="Enabled"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          Background="Black"
                          PointerPressed="OnCanvasPointerPressed"
                          PointerMoved="OnCanvasPointerMoved"
                          PointerReleased="OnCanvasPointerReleased"
                          PointerCanceled="OnCanvasPointerReleased">
                <Image x:Name="FitsImage"
                       Stretch="None"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
            </ScrollViewer>
        </Grid>

        <!-- Status bar -->
        <Grid Grid.Row="2" Padding="12,4"
              Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              BorderThickness="0,1,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" x:Name="StatusLabel"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <TextBlock Grid.Column="1" x:Name="CoordLabel"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                       HorizontalAlignment="Center" />
            <TextBlock Grid.Column="2" x:Name="PixelLabel"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                       Margin="16,0" />
            <TextBlock Grid.Column="3" x:Name="ZoomLabel"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
        </Grid>
    </Grid>
</UserControl>
