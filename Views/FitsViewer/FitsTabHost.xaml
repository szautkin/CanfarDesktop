<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="CanfarDesktop.Views.FitsViewer.FitsTabHost"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    KeyDown="OnKeyDown">

    <Grid RowDefinitions="Auto,*">

        <!-- Shared toolbar -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Padding="12,6"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="0,0,0,1">

            <Button x:Uid="Fits_OpenButton" Click="OnOpenFile" ToolTipService.ToolTip="Open FITS" Padding="8,4"
                    AutomationProperties.Name="Open FITS file">
                <FontIcon Glyph="&#xE8E5;" FontSize="14" />
            </Button>
            <AppBarSeparator />

            <!-- Stretch -->
            <ComboBox x:Name="StretchCombo" x:Uid="Fits_StretchCombo" Header="Stretch" Width="120"
                      SelectionChanged="OnStretchChanged">
                <ComboBoxItem x:Uid="Fits_StretchLinear" Content="Linear" Tag="Linear" IsSelected="True" />
                <ComboBoxItem x:Uid="Fits_StretchLog" Content="Log" Tag="Log" />
                <ComboBoxItem x:Uid="Fits_StretchSqrt" Content="Sqrt" Tag="Sqrt" />
                <ComboBoxItem x:Uid="Fits_StretchSquared" Content="Squared" Tag="Squared" />
                <ComboBoxItem x:Uid="Fits_StretchAsinh" Content="Asinh" Tag="Asinh" />
            </ComboBox>

            <!-- Colormap -->
            <ComboBox x:Name="ColormapCombo" x:Uid="Fits_ColormapCombo" Header="Colormap" Width="120"
                      SelectionChanged="OnColormapChanged">
                <ComboBoxItem x:Uid="Fits_CmapGrayscale" Content="Grayscale" Tag="Grayscale" IsSelected="True" />
                <ComboBoxItem x:Uid="Fits_CmapInverted" Content="Inverted" Tag="Inverted" />
                <ComboBoxItem x:Uid="Fits_CmapHeat" Content="Heat" Tag="Heat" />
                <ComboBoxItem x:Uid="Fits_CmapCool" Content="Cool" Tag="Cool" />
                <ComboBoxItem x:Uid="Fits_CmapViridis" Content="Viridis" Tag="Viridis" />
            </ComboBox>

            <AppBarSeparator />

            <!-- Min/Max cuts -->
            <StackPanel Orientation="Vertical" Spacing="2" VerticalAlignment="Center">
                <TextBlock x:Uid="Fits_MinCutLabel" Text="Min Cut" Style="{StaticResource CaptionTextBlockStyle}" />
                <Slider x:Name="MinCutSlider" Width="120" Minimum="0" Maximum="100"
                        ValueChanged="OnMinCutChanged" />
            </StackPanel>
            <StackPanel Orientation="Vertical" Spacing="2" VerticalAlignment="Center">
                <TextBlock x:Uid="Fits_MaxCutLabel" Text="Max Cut" Style="{StaticResource CaptionTextBlockStyle}" />
                <Slider x:Name="MaxCutSlider" Width="120" Minimum="0" Maximum="100" Value="100"
                        ValueChanged="OnMaxCutChanged" />
            </StackPanel>

            <AppBarSeparator />
            <Button x:Uid="Fits_ResetButton" Click="OnResetStretch" Padding="8,4"
                    ToolTipService.ToolTip="Reset stretch and view"
                    AutomationProperties.Name="Reset stretch and view">
                <FontIcon Glyph="&#xE72C;" FontSize="14" />
            </Button>
            <Button x:Uid="Fits_HeaderButton" Click="OnToggleHeader" Padding="8,4"
                    ToolTipService.ToolTip="Toggle FITS header panel"
                    AutomationProperties.Name="Toggle FITS header panel">
                <FontIcon Glyph="&#xE8A7;" FontSize="14" />
            </Button>
            <ToggleButton x:Name="NorthUpToggle" x:Uid="Fits_NorthUpToggle" Click="OnToggleNorthUp" Padding="8,4"
                          ToolTipService.ToolTip="Orient North Up"
                          AutomationProperties.Name="Toggle North up orientation">
                <FontIcon Glyph="&#xE816;" FontSize="14" />
            </ToggleButton>

            <AppBarSeparator />

            <!-- Crosshair menu (consolidated to save toolbar space) -->
            <DropDownButton x:Uid="Fits_CrosshairButton" Padding="8,4"
                            AutomationProperties.Name="Crosshair actions"
                            ToolTipService.ToolTip="Crosshair tools">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <FontIcon Glyph="&#xE81D;" FontSize="14" />
                    <TextBlock x:Uid="Fits_CrosshairLabel" Text="Crosshair" />
                </StackPanel>
                <DropDownButton.Flyout>
                    <MenuFlyout>
                        <MenuFlyoutItem x:Uid="Fits_CopyCoordsItem" Text="Copy RA/Dec" Click="OnCopyCoords">
                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8C8;" /></MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Uid="Fits_SearchAtPositionItem" Text="Search at Position" Click="OnSearchAtPosition">
                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE721;" /></MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Uid="Fits_SaveBookmarkItem" Text="Save Bookmark" Click="OnSaveCrosshair">
                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE74E;" /></MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem x:Uid="Fits_ClearCrosshairItem" Text="Clear Crosshair" Click="OnClearCrosshair">
                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE894;" /></MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                    </MenuFlyout>
                </DropDownButton.Flyout>
            </DropDownButton>

            <!-- Blink comparison -->
            <DropDownButton x:Uid="Fits_BlinkButton" Padding="8,4"
                            ToolTipService.ToolTip="Blink comparison between two images"
                            AutomationProperties.Name="Blink comparison">
                <FontIcon Glyph="&#xE786;" FontSize="14" />
                <DropDownButton.Flyout>
                    <MenuFlyout Opening="OnBlinkFlyoutOpening" />
                </DropDownButton.Flyout>
            </DropDownButton>
            <Slider x:Name="BlinkIntervalSlider" x:Uid="Fits_BlinkIntervalSlider" Width="80" Minimum="500" Maximum="5000" Value="2000"
                    Visibility="Collapsed" ToolTipService.ToolTip="Fade speed (ms per cycle)"
                    AutomationProperties.Name="Blink fade speed"
                    ValueChanged="OnBlinkIntervalChanged" />
            <Button x:Name="StopBlinkButton" x:Uid="Fits_StopBlinkButton" Visibility="Collapsed" Click="OnStopBlink" Padding="8,4"
                    ToolTipService.ToolTip="Stop blinking (Escape)"
                    AutomationProperties.Name="Stop blink comparison"
                    Background="{ThemeResource SystemFillColorCriticalBackgroundBrush}">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <FontIcon Glyph="&#xE71A;" FontSize="14" />
                    <TextBlock x:Uid="Fits_StopBlinkLabel" Text="Stop Blink" />
                </StackPanel>
            </Button>

            <!-- Sync zoom toggle -->
            <ToggleButton x:Name="SyncZoomToggle" x:Uid="Fits_SyncZoomToggle"
                          Click="OnToggleSyncZoom" Padding="8,4"
                          ToolTipService.ToolTip="Sync zoom across tabs (match angular extent)"
                          AutomationProperties.Name="Sync zoom across tabs">
                <FontIcon Glyph="&#xE740;" FontSize="14" />
            </ToggleButton>

            <!-- Linked crosshair toggle -->
            <ToggleButton x:Name="LinkedCrosshairToggle" x:Uid="Fits_LinkedCrosshairToggle" IsChecked="True"
                          Click="OnToggleLinkedCrosshair" Padding="8,4"
                          ToolTipService.ToolTip="Link crosshair across tabs"
                          AutomationProperties.Name="Link crosshair across tabs">
                <FontIcon Glyph="&#xE71B;" FontSize="14" />
            </ToggleButton>

            <!-- Bookmarks toggle -->
            <Button x:Uid="Fits_CoordPanelButton" Click="OnToggleCoordPanel" Padding="8,4"
                    ToolTipService.ToolTip="Saved Coordinates panel"
                    AutomationProperties.Name="Toggle saved coordinates panel">
                <FontIcon Glyph="&#xE728;" FontSize="14" />
            </Button>

            <AppBarSeparator />

            <!-- Zoom preset dropdown -->
            <ComboBox x:Name="ZoomPresetCombo" x:Uid="Fits_ZoomCombo" Width="95"
                          SelectionChanged="OnZoomPresetChanged"
                          TextSubmitted="OnZoomTextSubmitted"
                          IsEditable="True"
                          Text="100%"
                          AutomationProperties.Name="Zoom level"
                          ToolTipService.ToolTip="Zoom level — type a value or pick from list">
                    <ComboBoxItem Content="25%" Tag="25" />
                    <ComboBoxItem Content="50%" Tag="50" />
                    <ComboBoxItem Content="75%" Tag="75" />
                    <ComboBoxItem Content="100%" Tag="100" />
                    <ComboBoxItem Content="150%" Tag="150" />
                    <ComboBoxItem Content="200%" Tag="200" />
                    <ComboBoxItem Content="300%" Tag="300" />
                    <ComboBoxItem Content="400%" Tag="400" />
                    <ComboBoxItem Content="500%" Tag="500" />
                    <ComboBoxItem Content="800%" Tag="800" />
                    <ComboBoxItem Content="1200%" Tag="1200" />
                </ComboBox>

            <ProgressRing x:Name="LoadingRing" IsActive="False" Width="20" Height="20"
                          VerticalAlignment="Center" />
        </StackPanel>

        <!-- Tab view + coordinate panel -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="CoordPanelColumn" Width="0" />
            </Grid.ColumnDefinitions>

            <TabView x:Name="TabViewControl" Grid.Column="0"
                     IsAddTabButtonVisible="True"
                     AddTabButtonClick="OnAddTab"
                     TabCloseRequested="OnTabCloseRequested"
                     SelectionChanged="OnTabSelectionChanged" />

            <!-- Warns when crosshair/zoom sync is on but a file lacks a precise WCS (e.g. a raw
                 DAO frame with only a pointing): the linked position/zoom will be approximate. -->
            <InfoBar x:Name="WcsSyncWarningBar" Grid.Column="0"
                     Severity="Warning" IsOpen="False" IsClosable="True"
                     VerticalAlignment="Top" Margin="8,8,8,0"
                     x:Uid="Fits_WcsSyncWarningBar"
                     Title="Approximate WCS"
                     Message="One or more images have no precise WCS solution, so crosshair and zoom sync are approximate." />

            <!-- Saved coordinates panel (collapsible) -->
            <Border Grid.Column="1"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="1,0,0,0">
                <Grid RowDefinitions="Auto,Auto,Auto,*" Margin="10,8,10,8">

                    <!-- Current crosshair readout + save -->
                    <Border Grid.Row="0" Padding="8" CornerRadius="6"
                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                        <StackPanel Spacing="4">
                            <TextBlock x:Uid="Fits_CurrentCrosshairHeader" Text="Current Crosshair"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            <TextBlock x:Name="PanelCrosshairText" FontFamily="Consolas" FontSize="11"
                                       Text="No crosshair placed"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                            <TextBox x:Name="CoordLabelBox" x:Uid="Fits_CoordLabelBox" PlaceholderText="Label (optional)"
                                     FontSize="12" Margin="0,4,0,0"
                                     AutomationProperties.Name="Bookmark label" />
                            <Button x:Uid="Fits_SavePanelButton" Click="OnSaveCrosshairFromPanel" HorizontalAlignment="Stretch"
                                    ToolTipService.ToolTip="Save crosshair as bookmark"
                                    Padding="8,6" Margin="0,4,0,0"
                                    AutomationProperties.Name="Save crosshair bookmark">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE74E;" FontSize="14" />
                                    <TextBlock x:Uid="Fits_SaveBookmarkLabel" Text="Save Bookmark" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Go To coordinate -->
                    <StackPanel Grid.Row="1" Spacing="4" Margin="0,12,0,0">
                        <TextBlock x:Uid="Fits_GoToHeader" Text="Go To (degrees)"
                                   Style="{StaticResource CaptionTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6" RowSpacing="4"
                              RowDefinitions="Auto,Auto">
                            <TextBlock x:Uid="Fits_RaLabel" Grid.Row="0" Grid.Column="0" Text="RA"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       VerticalAlignment="Center" Width="28" />
                            <TextBox Grid.Row="0" Grid.Column="1" x:Name="ManualRaBox" x:Uid="Fits_ManualRaBox"
                                     PlaceholderText="e.g. 19.8" FontSize="12"
                                     AutomationProperties.Name="Right ascension in degrees" />
                            <TextBlock x:Uid="Fits_DecLabel" Grid.Row="1" Grid.Column="0" Text="Dec"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       VerticalAlignment="Center" Width="28" />
                            <TextBox Grid.Row="1" Grid.Column="1" x:Name="ManualDecBox" x:Uid="Fits_ManualDecBox"
                                     PlaceholderText="e.g. 42.1" FontSize="12"
                                     AutomationProperties.Name="Declination in degrees" />
                        </Grid>
                        <Button x:Uid="Fits_GoToButton" Click="OnGoToManual" HorizontalAlignment="Stretch"
                                ToolTipService.ToolTip="Navigate to coordinate"
                                Padding="8,6"
                                AutomationProperties.Name="Go to coordinate">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE81D;" FontSize="14" />
                                <TextBlock x:Uid="Fits_GoToLabel" Text="Go To" />
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Bookmarks header -->
                    <TextBlock x:Uid="Fits_BookmarksHeader" Grid.Row="2" Text="Bookmarks" Margin="0,14,0,4"
                               Style="{StaticResource BodyStrongTextBlockStyle}" />

                    <!-- Bookmarks list -->
                    <ListView Grid.Row="3" x:Name="CoordListView" SelectionMode="None"
                              Padding="0">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="0,3" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="2">
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="1">
                                        <TextBlock Text="{Binding Label}" FontSize="12"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding FormattedCoords}"
                                                   FontFamily="Consolas" FontSize="10"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding SourceFile}" FontSize="11"
                                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <Button x:Uid="Fits_GoToSavedButton" Grid.Column="1" Click="OnGoToSaved" Tag="{Binding}"
                                            Padding="5" ToolTipService.ToolTip="Go to coordinate"
                                            AutomationProperties.Name="Go to saved coordinate">
                                        <FontIcon Glyph="&#xE81D;" FontSize="11" />
                                    </Button>
                                    <Button x:Uid="Fits_DeleteCoordButton" Grid.Column="2" Click="OnDeleteCoord" Tag="{Binding}"
                                            Padding="5" ToolTipService.ToolTip="Delete"
                                            AutomationProperties.Name="Delete saved coordinate">
                                        <FontIcon Glyph="&#xE74D;" FontSize="11" />
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
