<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="CanfarDesktop.Views.LocalFileBrowserPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:CanfarDesktop.Models">

    <Grid Background="{ThemeResource LayerFillColorDefaultBrush}"
          BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
          BorderThickness="0,0,1,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header: title + action buttons -->
        <Grid Grid.Row="0" Padding="12,8"
              Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Explorer"
                       Style="{StaticResource BodyStrongTextBlockStyle}"
                       VerticalAlignment="Center" />
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2">
                <Button Click="OnOpenFolder" Padding="4" Background="Transparent" BorderThickness="0"
                        ToolTipService.ToolTip="Open Folder" AutomationProperties.Name="Open folder">
                    <FontIcon Glyph="&#xE8DA;" FontSize="12" />
                </Button>
                <Button Click="OnFolderUp" Padding="4" Background="Transparent" BorderThickness="0"
                        ToolTipService.ToolTip="Go Up" AutomationProperties.Name="Go up one folder">
                    <FontIcon Glyph="&#xE74A;" FontSize="12" />
                </Button>
                <Button Click="OnNewFile" Padding="4" Background="Transparent" BorderThickness="0"
                        ToolTipService.ToolTip="New File" AutomationProperties.Name="New file">
                    <FontIcon Glyph="&#xE8A5;" FontSize="12" />
                </Button>
                <Button Click="OnNewFolder" Padding="4" Background="Transparent" BorderThickness="0"
                        ToolTipService.ToolTip="New Folder" AutomationProperties.Name="New folder">
                    <FontIcon Glyph="&#xE8F4;" FontSize="12" />
                </Button>
                <Button Click="OnToggleSort" Padding="4" Background="Transparent" BorderThickness="0"
                        ToolTipService.ToolTip="Sort by name/date" AutomationProperties.Name="Toggle sort">
                    <FontIcon Glyph="&#xE8CB;" FontSize="12" />
                </Button>
                <Button Click="OnRefresh" Padding="4" Background="Transparent" BorderThickness="0"
                        ToolTipService.ToolTip="Refresh" AutomationProperties.Name="Refresh">
                    <FontIcon Glyph="&#xE72C;" FontSize="12" />
                </Button>
            </StackPanel>
        </Grid>

        <!-- Breadcrumb bar -->
        <ScrollViewer Grid.Row="1"
                      x:Name="BreadcrumbScroller"
                      HorizontalScrollMode="Auto"
                      HorizontalScrollBarVisibility="Hidden"
                      VerticalScrollBarVisibility="Disabled"
                      Padding="8,2">
            <ItemsRepeater x:Name="BreadcrumbRepeater" ItemsSource="{x:Bind ViewModel.Breadcrumbs, Mode=OneWay}">
                <ItemsRepeater.Layout>
                    <StackLayout Orientation="Horizontal" />
                </ItemsRepeater.Layout>
                <DataTemplate x:DataType="models:BreadcrumbSegment">
                    <StackPanel Orientation="Horizontal">
                        <HyperlinkButton Content="{x:Bind Label}"
                                         Padding="2,0"
                                         FontSize="11"
                                         Click="OnBreadcrumbClick"
                                         Tag="{x:Bind}" />
                        <TextBlock Text="/" VerticalAlignment="Center"
                                   FontSize="11"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    </StackPanel>
                </DataTemplate>
            </ItemsRepeater>
        </ScrollViewer>

        <!-- Filter bar -->
        <AutoSuggestBox Grid.Row="2" x:Name="FilterBox"
                        PlaceholderText="Filter files..."
                        Margin="8,4"
                        QueryIcon="Find"
                        TextChanged="OnFilterChanged" />

        <!-- Tree view -->
        <TreeView Grid.Row="3" x:Name="FileTree"
                  SelectionMode="Single"
                  ItemInvoked="OnItemSelected"
                  Expanding="OnNodeExpanding"
                  KeyDown="OnTreeKeyDown"
                  Padding="4,0">
            <TreeView.ItemTemplate>
                <DataTemplate x:DataType="models:LocalFileNode">
                    <TreeViewItem ItemsSource="{x:Bind Children, Mode=OneWay}"
                                  HasUnrealizedChildren="{x:Bind HasUnrealizedChildren, Mode=OneWay}"
                                  AutomationProperties.Name="{x:Bind Name}">
                        <StackPanel Orientation="Horizontal" Spacing="8" Padding="2,4"
                                    IsTabStop="False"
                                    DoubleTapped="OnItemDoubleTapped">
                            <FontIcon Glyph="{x:Bind Icon}" FontSize="14"
                                      Foreground="{x:Bind IconForeground}" />
                            <TextBlock Text="{x:Bind Name}" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{x:Bind FormattedSize}"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <TreeViewItem.ContextFlyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Text="Open" Click="OnOpenItem">
                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8E5;" /></MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem Text="Copy Path" Click="OnCopyPath">
                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8C8;" /></MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem Text="Show in Explorer" Click="OnShowInExplorer">
                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xEC50;" /></MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutSeparator />
                                <MenuFlyoutItem Text="Rename" Click="OnRenameItem">
                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8AC;" /></MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem Text="Delete" Click="OnDeleteItem">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE74D;"
                                                  Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </TreeViewItem.ContextFlyout>
                    </TreeViewItem>
                </DataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>
    </Grid>
</UserControl>
