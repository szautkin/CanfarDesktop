<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="CanfarDesktop.Views.LocalFileBrowserPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Background="{ThemeResource LayerFillColorDefaultBrush}"
          BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
          BorderThickness="0,0,1,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Padding="12,8"
              Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Explorer"
                       Style="{StaticResource BodyStrongTextBlockStyle}"
                       VerticalAlignment="Center" />
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2">
                <Button Click="OnNewFile" Padding="4" Background="Transparent" BorderThickness="0"
                        ToolTipService.ToolTip="New File" AutomationProperties.Name="New file">
                    <FontIcon Glyph="&#xE8A5;" FontSize="12" />
                </Button>
                <Button Click="OnNewFolder" Padding="4" Background="Transparent" BorderThickness="0"
                        ToolTipService.ToolTip="New Folder" AutomationProperties.Name="New folder">
                    <FontIcon Glyph="&#xE8F4;" FontSize="12" />
                </Button>
                <Button Click="OnRefresh" Padding="4" Background="Transparent" BorderThickness="0"
                        ToolTipService.ToolTip="Refresh" AutomationProperties.Name="Refresh">
                    <FontIcon Glyph="&#xE72C;" FontSize="12" />
                </Button>
            </StackPanel>
        </Grid>

        <!-- Filter bar -->
        <TextBox Grid.Row="1" x:Name="FilterBox"
                 PlaceholderText="Filter files..."
                 Margin="8,4" Padding="6,4"
                 BorderThickness="1"
                 TextChanged="OnFilterChanged" />

        <!-- Tree view -->
        <TreeView Grid.Row="2" x:Name="FileTree"
                  SelectionMode="Single"
                  ItemInvoked="OnItemInvoked"
                  Expanding="OnNodeExpanding"
                  Padding="4,0">
            <TreeView.ItemTemplate>
                <DataTemplate>
                    <TreeViewItem ItemsSource="{Binding Children}"
                                  HasUnrealizedChildren="{Binding HasUnrealizedChildren}"
                                  AutomationProperties.Name="{Binding Name}">
                        <StackPanel Orientation="Horizontal" Spacing="8" Padding="2,4">
                            <FontIcon Glyph="{Binding Icon}" FontSize="14" />
                            <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding FormattedSize}"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                       Style="{StaticResource CaptionTextBlockStyle}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <TreeViewItem.ContextFlyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Text="Open" Click="OnOpenItem">
                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8E5;" /></MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutItem Text="Copy Path" Click="OnCopyPath">
                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8C8;" /></MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                                <MenuFlyoutSeparator />
                                <MenuFlyoutItem Text="Delete" Click="OnDeleteItem">
                                    <MenuFlyoutItem.Icon>
                                        <FontIcon Glyph="&#xE74D;"
                                                  Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                                    </MenuFlyoutItem.Icon>
                                </MenuFlyoutItem>
                            </MenuFlyout>
                        </TreeViewItem.ContextFlyout>
                    </TreeViewItem>
                </DataTemplate>
            </TreeView.ItemTemplate>
        </TreeView>
    </Grid>
</UserControl>
