<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="CanfarDesktop.Views.StorageBrowserPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:CanfarDesktop.Converters"
    AllowDrop="True" DragOver="OnDragOver" DragLeave="OnDragLeave" Drop="OnDrop">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />

        <MenuFlyout x:Key="ItemContextMenu">
            <MenuFlyoutItem Text="Download" Click="OnDownload">
                <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE896;" /></MenuFlyoutItem.Icon>
            </MenuFlyoutItem>
            <MenuFlyoutItem Text="Copy Path" Click="OnCopyPath">
                <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8C8;" /></MenuFlyoutItem.Icon>
            </MenuFlyoutItem>
            <MenuFlyoutSeparator />
            <MenuFlyoutItem Text="Delete" Click="OnDelete">
                <MenuFlyoutItem.Icon>
                    <FontIcon Glyph="&#xE74D;" Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                </MenuFlyoutItem.Icon>
            </MenuFlyoutItem>
        </MenuFlyout>
    </UserControl.Resources>

    <Grid Padding="24" RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0" Text="VOSpace Storage" Style="{StaticResource TitleTextBlockStyle}" />

        <!-- Breadcrumb -->
        <BreadcrumbBar Grid.Row="1" x:Name="PathBreadcrumb" ItemClicked="OnBreadcrumbClicked" />

        <!-- Toolbar -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" Padding="12,6"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    BorderThickness="0,0,0,1" CornerRadius="8,8,0,0">
            <Button Click="OnGoUp" ToolTipService.ToolTip="Up" Padding="8,4"
                    AutomationProperties.Name="Navigate up">
                <FontIcon Glyph="&#xE74A;" FontSize="14" />
            </Button>
            <Button Click="OnRefresh" ToolTipService.ToolTip="Refresh" Padding="8,4"
                    AutomationProperties.Name="Refresh folder">
                <FontIcon Glyph="&#xE72C;" FontSize="14" />
            </Button>
            <Button Click="OnNewFolder" Padding="8,4">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE8F4;" FontSize="14" />
                    <TextBlock Text="New Folder" />
                </StackPanel>
            </Button>
            <Button Click="OnUpload" Padding="8,4">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE898;" FontSize="14" />
                    <TextBlock Text="Upload" />
                </StackPanel>
            </Button>
            <Button Click="OnDownload" Padding="8,4">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE896;" FontSize="14" />
                    <TextBlock Text="Download" />
                </StackPanel>
            </Button>
            <Button Click="OnDelete" Padding="8,4"
                    AutomationProperties.Name="Delete selected item">
                <FontIcon Glyph="&#xE74D;" FontSize="14" Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
            </Button>
            <ProgressRing x:Name="LoadingRing" IsActive="False" Width="20" Height="20" VerticalAlignment="Center" />
        </StackPanel>

        <!-- Column headers -->
        <Grid Grid.Row="3" Padding="16,6,16,6"
              Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
              CornerRadius="8,8,0,0" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1,1,1,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="32" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="100" />
                <ColumnDefinition Width="140" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="1" Text="Name" Style="{StaticResource CaptionTextBlockStyle}"
                       FontWeight="SemiBold" Tapped="OnSortByName" />
            <TextBlock Grid.Column="2" Text="Size" Style="{StaticResource CaptionTextBlockStyle}"
                       FontWeight="SemiBold" Tapped="OnSortBySize" />
            <TextBlock Grid.Column="3" Text="Modified" Style="{StaticResource CaptionTextBlockStyle}"
                       FontWeight="SemiBold" Tapped="OnSortByDate" />
        </Grid>

        <!-- File list -->
        <Border Grid.Row="4" CornerRadius="0,0,8,8"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1,0,1,1">
            <Grid>
                <ListView x:Name="FileList" SelectionMode="Single"
                          SelectionChanged="OnFileSelected" DoubleTapped="OnFileDoubleTapped"
                          ContextFlyout="{StaticResource ItemContextMenu}">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="4,6" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="140" />
                                </Grid.ColumnDefinitions>
                                <FontIcon Grid.Column="0" Glyph="{Binding Icon}" FontSize="16" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="2" Text="{Binding FormattedSize}" VerticalAlignment="Center"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Style="{StaticResource CaptionTextBlockStyle}" />
                                <TextBlock Grid.Column="3" Text="{Binding FormattedDate}" VerticalAlignment="Center"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Style="{StaticResource CaptionTextBlockStyle}" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- Empty state -->
                <StackPanel x:Name="EmptyState" VerticalAlignment="Center" HorizontalAlignment="Center"
                            Spacing="12" Visibility="Collapsed">
                    <FontIcon Glyph="&#xE8B7;" FontSize="48"
                              Foreground="{ThemeResource TextFillColorTertiaryBrush}" HorizontalAlignment="Center" />
                    <TextBlock Text="This folder is empty" Style="{StaticResource SubtitleTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" />
                </StackPanel>

                <!-- Drop overlay -->
                <Border x:Name="DropOverlay" Visibility="Collapsed" CornerRadius="8"
                        Background="{ThemeResource AcrylicBackgroundFillColorBaseBrush}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
                        <FontIcon Glyph="&#xE898;" FontSize="48"
                                  Foreground="{ThemeResource AccentFillColorDefaultBrush}" />
                        <TextBlock Text="Drop files here to upload"
                                   Style="{StaticResource SubtitleTextBlockStyle}" HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>

                <InfoBar x:Name="ErrorBar" IsOpen="False" Severity="Error" Title="Error" VerticalAlignment="Top" />
            </Grid>
        </Border>

        <!-- Status bar -->
        <Grid Grid.Row="5" Padding="12,6"
              Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
              BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
              BorderThickness="0,1,0,0"
              CornerRadius="0,0,8,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" x:Name="ItemCountText"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <TextBlock Grid.Column="1" x:Name="SelectionText"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       HorizontalAlignment="Center" />
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                <ProgressRing x:Name="TransferRing" IsActive="False" Width="14" Height="14" />
                <TextBlock x:Name="TransferText"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
