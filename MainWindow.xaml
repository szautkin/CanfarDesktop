<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="CanfarDesktop.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Verbinal - a CANFAR Science Portal Companion and Research Platform">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Grid x:Name="TitleBarRow" Grid.Row="0" Padding="16,8" Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Left: branding + home -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Button x:Name="BackButton" x:Uid="MainWindow_BackButton" Click="OnBackClick" ToolTipService.ToolTip="Back"
                        Padding="6,4" Background="Transparent" BorderThickness="0"
                        Visibility="Collapsed"
                        AutomationProperties.Name="Go back">
                    <FontIcon Glyph="&#xE72B;" FontSize="16" />
                </Button>
                <Image Source="Assets/Verbinal_icon.png" Height="28" />
                <TextBlock Text="Verbinal" Style="{StaticResource SubtitleTextBlockStyle}" VerticalAlignment="Center" />
                <Button x:Uid="MainWindow_HomeButton" Click="OnHomeClick" ToolTipService.ToolTip="Home" Padding="6,4"
                        Background="Transparent" BorderThickness="0"
                        AutomationProperties.Name="Go to home">
                    <FontIcon Glyph="&#xE80F;" FontSize="16" />
                </Button>
                <Button x:Uid="MainWindow_ExplorerButton" Click="OnToggleFilePanel" ToolTipService.ToolTip="Explorer (Ctrl+B)" Padding="6,4"
                        Background="Transparent" BorderThickness="0"
                        AutomationProperties.Name="Toggle file explorer">
                    <FontIcon Glyph="&#xED25;" FontSize="16" />
                </Button>
            </StackPanel>

            <!-- Center: status -->
            <TextBlock Grid.Column="1" x:Name="StatusText" VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Style="{StaticResource CaptionTextBlockStyle}" />

            <!-- Right: auth area -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Button x:Uid="MainWindow_SettingsButton" ToolTipService.ToolTip="Settings" Padding="6,4"
                        Background="Transparent" BorderThickness="0"
                        AutomationProperties.Name="Settings" Click="OnOpenSettingsClick">
                    <FontIcon Glyph="&#xE713;" FontSize="16" />
                </Button>
                <Button x:Uid="MainWindow_AboutButton" Click="OnAboutClick" ToolTipService.ToolTip="About" Padding="6,4"
                        Background="Transparent" BorderThickness="0"
                        AutomationProperties.Name="About Verbinal">
                    <FontIcon Glyph="&#xE946;" FontSize="16" />
                </Button>
                <!-- Agent proposals (visible while the MCP server runs; badge = pending count) -->
                <Button x:Name="ProposalsButton" x:Uid="MainWindow_ProposalsButton" Click="OnProposalsClick" Padding="6,4"
                        Background="Transparent" BorderThickness="0" Visibility="Collapsed"
                        ToolTipService.ToolTip="Agent proposals"
                        AutomationProperties.Name="Agent proposals">
                    <Grid>
                        <FontIcon Glyph="&#xE99A;" FontSize="16" />
                        <InfoBadge x:Name="ProposalsBadge" HorizontalAlignment="Right" VerticalAlignment="Top"
                                   Margin="0,-6,-8,0" Visibility="Collapsed" />
                    </Grid>
                </Button>
                <ProgressRing x:Name="AuthProgress" IsActive="False" Width="20" Height="20"
                              Visibility="Collapsed" />
                <Button x:Name="LoginButton" x:Uid="MainWindow_LoginButton" Content="Login" Click="OnLoginClick"
                        Style="{StaticResource AccentButtonStyle}" />
                <DropDownButton x:Name="UserButton" Visibility="Collapsed">
                    <DropDownButton.Flyout>
                        <MenuFlyout>
                            <!-- Non-interactive identity header (display name + email), populated in UpdateAuthUI -->
                            <MenuFlyoutItem x:Name="UserNameMenuItem" IsEnabled="False" />
                            <MenuFlyoutItem x:Name="UserEmailMenuItem" IsEnabled="False" Visibility="Collapsed" />
                            <MenuFlyoutSeparator />
                            <MenuFlyoutItem x:Uid="MainWindow_LogoutMenuItem" Text="Logout" Click="OnLogoutClick">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE7E8;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                        </MenuFlyout>
                    </DropDownButton.Flyout>
                </DropDownButton>
            </StackPanel>
        </Grid>

        <!-- Content: file browser panel + main content area -->
        <Grid x:Name="ContentRow" Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="FilePanelColumn" Width="0" MinWidth="0" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- File browser side panel (collapsible) -->
            <Border x:Name="FilePanelContainer" Grid.Column="0" />

            <!-- Main content: overlapping containers, visibility-toggled -->
            <Grid Grid.Column="1">
                <Border x:Name="LandingContainer" />
                <Border x:Name="PortalContainer" Visibility="Collapsed" />
                <Border x:Name="SearchContainer" Visibility="Collapsed" />
                <Border x:Name="ResearchContainer" Visibility="Collapsed" />
                <Border x:Name="StorageContainer" Visibility="Collapsed" />
                <Border x:Name="NotebookContainer" Visibility="Collapsed" />
                <Border x:Name="FitsViewerContainer" Visibility="Collapsed" />
                <Border x:Name="ObsDetailContainer" Visibility="Collapsed" />
                <Border x:Name="CubeViewerContainer" Visibility="Collapsed" />
                <Border x:Name="AiGuideContainer" Visibility="Collapsed" />
                <Border x:Name="WorkflowsContainer" Visibility="Collapsed" />
            </Grid>
        </Grid>

        <!-- Transient "agent is working" indicator: pulses while an MCP agent invokes tools and
             auto-hides ~2.5s after activity stops. Floats over the content; non-interactive. -->
        <Border x:Name="AgentActivityIndicator" x:Uid="MainWindow_AgentActivityIndicator" Grid.Row="1"
                HorizontalAlignment="Center" VerticalAlignment="Top"
                Margin="0,12,0,0" Padding="12,6"
                Background="{ThemeResource AccentFillColorDefaultBrush}"
                CornerRadius="14" Canvas.ZIndex="900"
                Visibility="Collapsed" IsHitTestVisible="False"
                AutomationProperties.Name="Agent activity">
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <ProgressRing IsActive="True" Width="16" Height="16"
                              Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" />
                <TextBlock x:Name="AgentActivityText" x:Uid="MainWindow_AgentActivityText" Text="Agent is working&#x2026;"
                           VerticalAlignment="Center"
                           Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                           Style="{StaticResource CaptionTextBlockStyle}" />
            </StackPanel>
        </Border>

        <!-- Terms-of-Use gate: full-window blocking overlay shown on first launch.
             Opaque background blocks all interaction with the app behind it until
             the user Accepts; it is not a ContentDialog so it cannot be light-dismissed. -->
        <Grid x:Name="TermsGateOverlay" Grid.Row="0" Grid.RowSpan="2"
              Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
              Canvas.ZIndex="1000" Visibility="Collapsed">
            <Border MaxWidth="640" MaxHeight="640" Margin="24"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="24">
                <Grid RowSpacing="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="TermsTitle" Grid.Row="0"
                               Style="{StaticResource TitleTextBlockStyle}" />
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <TextBlock x:Name="TermsBody" TextWrapping="Wrap"
                                   IsTextSelectionEnabled="True"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </ScrollViewer>
                    <StackPanel Grid.Row="2" Orientation="Horizontal"
                                HorizontalAlignment="Right" Spacing="8">
                        <Button x:Name="TermsDeclineButton" x:Uid="MainWindow_TermsDeclineButton" Content="Decline &amp; Exit"
                                Click="OnTermsDecline" />
                        <Button x:Name="TermsAcceptButton" x:Uid="MainWindow_TermsAcceptButton" Content="Accept"
                                Style="{StaticResource AccentButtonStyle}"
                                Click="OnTermsAccept" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
